\"Error fetching finance data:\", error);\r\n            setLoading(false);\r\n        }\r\n    };\r\n\r\n    useEffect(() => {\r\n        fetchFinance();\r\n    }, []);\r\n\r\n    const handleWithdraw = async (e) => {\r\n        e.preventDefault();\r\n        const amount = parseFloat(withdrawAmount);\r\n        if (!amount || amount <= 0 || amount > finance.balance) {\r\n            alert('SГҹв•—ГҰ tiГҹв•—Гјn rв”ңв•‘t khв”ңв”Өng hГҹв•—Гәp lГҹв•—Г§ hoГҹв•‘ГҖc vГЈв–‘Гҹв•—Гәt quв”ңГӯ sГҹв•—ГҰ dГЈв–‘.');\r\n            return;\r\n        }\r\n\r\n        setSubmitting(true);\r\n        try {\r\n            // GГҹв•—ВЎi yв”ңВ¬u cГҹв•‘Вәu rв”ңв•‘t tiГҹв•—Гјn vв”ңГЎo SQL\r\n            await api.post('/courses/instructor-courses/request_withdrawal/', { amount });\r\n            alert('Yв”ңВ¬u cГҹв•‘Вәu rв”ңв•‘t tiГҹв•—Гјn в”ҖГҰв”ңГә в”ҖГҰГЈв–‘Гҹв•—Гәc gГҹв•—ВЎi thв”ңГЎnh cв”ңв”Өng! Admin sГҹв•‘Вў xГҹв•—ВЎ lв”ңВў trong vв”ңв–“ng 24h.');\r\n            setWithdrawAmount('');\r\n            fetchFinance(); // Refresh balance\r\n        } catch (error) {\r\n            alert('Cв”ңв”Ӯ lГҹв•—Г№i xГҹв•‘Гәy ra khi gГҹв•—ВЎi yв”ңВ¬u cГҹв•‘Вәu.');\r\n        } finally {\r\n            setSubmitting(false);\r\n        }\r\n    };\r\n\r\n    return (\r\n        <div className=\"instructor-container\">\r\n            <InstructorSidebar />\r\n\r\n            <main className=\"instructor-main\">\r\n                <header className=\"instructor-header\">\r\n                    <div>\r\n                        <h1>QuГҹв•‘Гәn lв”ңВў thu nhГҹв•‘ВЎp</h1>\r\n                        <p style={{color: '#64748b'}}>Theo dв”ңГҒi doanh thu vв”ңГЎ quГҹв•‘Гәn lв”ңВў cв”ңГӯc yв”ңВ¬u cГҹв•‘Вәu thanh toв”ңГӯn cГҹв•—Вәa bГҹв•‘Гӯn.</p>\r\n                    </div>\r\n                </header>\r\n\r\n                <div className=\"stats-grid\">\r\n                    <div className=\"stat-card\" style={{background: 'linear-gradient(135deg, #0056d2 0%, #003a91 100%)', color: 'white'}}>\r\n             