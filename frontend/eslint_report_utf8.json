instructor-header\">\r\n                    <div>\r\n                        <h1>в”ҖГүв”ңГӯnh giв”ңГӯ & PhГҹв•‘Гәn hГҹв•—Гҙi</h1>\r\n                        <p style={{color: '#64748b'}}>LГҹв•‘В»ng nghe в”ңВў kiГҹв•‘в”җn cГҹв•—Вәa hГҹв•—Г¬c viв”ңВ¬n в”ҖГҰГҹв•—Гў hoв”ңГЎn thiГҹв•—Г§n khв”ңв”Ӯa hГҹв•—Г¬c.</p>\r\n                    </div>\r\n                </header>\r\n\r\n                <div className=\"reviews-list\">\r\n                    {loading ? <p>в”ҖГүang tГҹв•‘Гәi...</p> : (\r\n                        reviews.map(rev => (\r\n                            <div key={rev.id} className=\"content-card\" style={{marginBottom: '20px'}}>\r\n                                <div style={{display: 'flex', justifyContent: 'space-between', marginBottom: '10px'}}>\r\n                                    <div style={{display: 'flex', alignItems: 'center'}}>\r\n                                        <div style={{fontWeight: 700, marginRight: '10px'}}>{rev.user}</div>\r\n                                        <div style={{color: '#f59e0b'}}>\r\n                                            {'Г”ГҝГ '.repeat(rev.rating)}{'Г”ГҝГҘ'.repeat(5-rev.rating)}\r\n                                        </div>\r\n                                    </div>\r\n                                    <div style={{fontSize: '0.85rem', color: '#64748b'}}>{new Date(rev.created_at).toLocaleDateString('vi-VN')}</div>\r\n                                </div>\r\n                                <div style={{fontSize: '0.9rem', color: '#64748b', marginBottom: '10px'}}>Khв”ңв”Ӯa hГҹв•—Г¬c: <span style={{color: '#1e293b', fontWeight: 600}}>{rev.course_title || 'Khв”ңв”Ӯa hГҹв•—Г¬c'}</span></div>\r\n                                <p style={{lineHeight: 1.6}}>{rev.comment}</p>\r\n                                \r\n                                {rev.instructor_reply && (\r\n                                    <div style={{marginTop: '15px', padding: '15px', background: '#f8fafc', borderRadius: '8px', borderLeft: '4px solid #0056d2'}}>\r\n                                        <div style={{fontWeight: 600, fontSize: '0.85rem', marginBottom: '5px'}}>BГҹв•‘Гӯn в”ҖГҰв”ңГә phГҹв•‘Гәn hГҹв•—Гҙi:</div>\r\n                                        <p style={{fontSize: '0.9rem', color: '#475569'}}>{rev.instructor_reply}</p>\r\n                                    </div>\r\n                                )}\r\n\r\n                                {!rev.instructor_reply && (\r\n                                    <div style={{marginTop: '15px', paddingTop: '15px', borderTop: '1px solid #f1f5f9'}}>\r\n                                        <div style={{display: 'flex', gap: '10px'}}>\r\n                                            <input \r\n                                                type=\"text\" \r\n                                                placeholder=\"NhГҹв•‘ВЎp phГҹв•‘Гәn hГҹв•—Гҙi cГҹв•—Вәa bГҹв•‘Гӯn...\"\r\n                                                value={replyMap[rev.id] || ''}\r\n                                                onChange={(e) => setReplyMap({...replyMap, [rev.id]: e.target.value})}\r\n                                                style={{flex: 1, padding: '10px', borderRadius: '8px', border: '1px solid #e2e8f0', outline: 'none'}}\r\n                                            />\r\n                                            <button \r\n                                                onClick={() => handleReply(rev.id)}\r\n                                                style={{padding: '10px 20px', borderRadius: '8px', border: 'none', background: '#0056d2', color: 'white', fontWeight: 600, cursor: 'pointer'}}\r\n                                            >\r\n                                                GГҹв•—ВЎi\r\n                                            </button>\r\n                                        </div>\r\n                                    </div>\r\n                                )}\r\n                            </div>\r\n                        ))\r\n                    )}\r\n                </div>\r\n            </main>\r\n        </div>\r\n    );\r\n};\r\n\r\nexport default InstructorReviews;\r\n","usedDeprecatedRules":[]},{"filePath":"D:\\ThГЈв–‘ГЈГӯng mГҹв•‘Гӯi в”ҖГҰiГҹв•—Г§n tГҹв•—ВЎ\\frontend\\src\\pages\\InstructorSettings.jsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"D:\\ThГЈв–‘ГЈГӯng mГҹв•‘Гӯi в”ҖГҰiГҹв•—Г§n tГҹв•—ВЎ\\frontend\\src\\pages\\InstructorStudents.jsx","messages":[{"ruleId":"no-unused-vars","severity":2,"message":"'loading' is assigned a value but never used. Allowed unused vars must match /^[A-Z_]/u.","line":9,"column":12,"nodeType":"Identifier","messageId":"unusedVar","endLine":9,"endColumn":19,"suggestions":[{"messageId":"removeVar","data":{"varName":"loading"},"fix":{"range":[340,347],"text":""},"desc":"Remove unused variable 'loading'."}]}],"suppressedMessages":[],"errorCount":1,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"source":"import React, { useState, useEffect } from 'react';\r\nimport { Link } from 'react-router-dom';\r\nimport api from '../api/axios';\r\nimport InstructorSidebar from '../components/InstructorSidebar';\r\nimport '../assets/instructor-dashboard.css';\r\n\r\nconst InstructorStudents = () => {\r\n    const [students, setStudents] = useState([]);\r\n    const [loading, setLoading] = useState(true);\r\n\r\n    useEffect(() => {\r\n        const fetchStudents = async () => {\r\n            try {\r\n                // API lГҹв•‘Г‘y danh sв”ңГӯch hГҹв•—Г¬c viв”ңВ¬n thГҹв•‘ВЎt\r\n                const res = await api.get('/courses/instructor-courses/my_students/');\r\n                setStudents(res.data);\r\n                setLoading(false);\r\n            } catch (error) {\r\n                console.error(\"Error fetching students:\", error);\r\n                setLoading(false);\r\n            }\r\n        };\r\n        fetchStudents();\r\n    }, []);\r\n\r\n    return (\r\n        <div className=\"instructor-container\">\r\n            <InstructorSidebar />\r\n\r\n            <main className=\"instructor-main\">\r\n                <header className=\"instructor-header\">\r\n                    <div>\r\n                        <h1>QuГҹв•‘Гәn lв”ңВў hГҹв•—Г¬c viв”ңВ¬n</h1>\r\n                        <p style={{color: '#64748b'}}>Theo dв”ңГҒi tiГҹв•‘в”җn в”ҖГҰГҹв•—Г– vв”ңГЎ tГЈв–‘ГЈГӯng tв”ңГӯc vГҹв•—Гёi cв”ңГӯc hГҹв•—Г¬c viв”ңВ¬n cГҹв•—Вәa bГҹв•‘Гӯn.</p>\r\n                    </div>\r\n                </header>\r\n\r\n                <div className=\"content-card\">\r\n                    <div style={{display: 'flex', justifyContent: 'space-between', marginBottom: '20px'}}>\r\n                        <div className=\"crs-search\" style={{width: '300px', background: '#f8fafc'}}>\r\n                            <span className=\"crs-search-icon\">ВӯЖ’Г¶Г¬</span>\r\n                            <input type=\"text\" placeholder=\"Tв”ңВјm tв”ңВ¬n hГҹв•—Г¬c viв”ңВ¬n...\" style={{border: 'none', background: 'transparent', width: '100%', padding: '8px'}} />\r\n                        </div>\r\n                    </div>\r\n\r\n                    <table className=\"course-table\">\r\n                        <thead>\r\n                            <tr>\r\n                                <th>HГҹв•—Г¬c viв”ңВ¬n</th>\r\n                                <th>Khв”ңв”Ӯa hГҹв•—Г¬c</th>\r\n                                <th>Ngв”ңГЎy tham gia</th>\r\n                                <th>TiГҹв•‘в”җn в”ҖГҰГҹв•—Г– hГҹв•—Г¬c tГҹв•‘ВЎp</th>\r\n                                <th>Thao tв”ңГӯc</th>\r\n                            </tr>\r\n                        </thead>\r\n                        <tbody>\r\n                            {students.map(s => (\r\n                                <tr key={s.id}>\r\n                                    <td>\r\n                                        <div style={{display: 'flex', alignItems: 'center'}}>\r\n                                            <div style={{width: '32px', height: '32px', background: '#0056d2', color: 'white', borderRadius: '50%', display: 'flex', alignItems: 'center', justifyContent: 'center', marginRight: '10px', fontSize: '0.8rem'}}>\r\n                                                {s.student_name[0]}\r\n                                            </div>\r\n                                            <div>\r\n                                                <div style={{fontWeight: 600}}>{s.student_name}</div>\r\n                                                <div style={{fontSize: '0.75rem', color: '#64748b'}}>{s.email}</div>\r\n                                            </div>\r\n                                        </div>\r\n                                    </td>\r\n                                    <td>{s.course_title}</td>\r\n                                    <td>{new Date(s.enrolled_at).toLocaleDateString('vi-VN')}</td>\r\n                                    <td>\r\n                                        <div style={{width: '100%', background: '#e2e8f0', borderRadius: '10px', height: '8px', position: 'relative'}}>\r\n                                            <div style={{width: `${s.progress}%`, background: s.progress === 100 ? '#10b981' : '#0056d2', height: '100%', borderRadius: '10px'}}></div>\r\n                                            <span style={{fontSize: '0.7rem', position: 'absolute', right: 0, top: '-15px'}}>{s.progress}%</span>\r\n                                        </div>\r\n                                    </td>\r\n                                    <td>\r\n                                        <button style={{background: 'none', border: 'none', color: '#0056d2', cursor: 'pointer', fontWeight: 600}}>ВӯЖ’ГҶВј NhГҹв•‘В»n tin</button>\r\n                                    </td>\r\n                                </tr>\r\n                            ))}\r\n                        </tbody>\r\n                    </table>\r\n                </div>\r\n            </main>\r\n        </div>\r\n    );\r\n};\r\n\r\nexport default InstructorStudents;\r\n","usedDeprecatedRules":[]},{"filePath":"D:\\ThГЈв–‘ГЈГӯng mГҹв•‘Гӯi в”ҖГҰiГҹв•—Г§n tГҹв•—ВЎ\\frontend\\src\\pages\\Learn.jsx","messages":[{"ruleId":"no-unused-vars","severity":2,"message":"'setSidebarOpen' is assigned a value but never used. Allowed unused vars must match /^[A-Z_]/u.","line":22,"column":23,"nodeType":"Identifier","messageId":"unusedVar","endLine":22,"endColumn":37,"suggestions":[{"messageId":"removeVar","data":{"varName":"setSidebarOpen"},"fix":{"range":[939,955],"text":""},"desc":"Remove unused variable 'setSidebarOpen'."}]},{"ruleId":"react-hooks/exhaustive-deps","severity":1,"message":"React Hook useEffect has missing dependencies: 'fetchData' and 'navigate'. Either include them or remove the dependency array.","line":38,"column":6,"nodeType":"ArrayExpression","endLine":38,"endColumn":35,"suggestions":[{"desc":"Update the dependencies array to be: [courseId, user, authLoading, fetchData, navigate]","fix":{"range":[1501,1530],"text":"[courseId, user, authLoading, fetchData, navigate]"}}]},{"ruleId":"no-unused-vars","severity":2,"message":"'error' is defined but never used.","line":92,"column":14,"nodeType":"Identifier","messageId":"unusedVar","endLine":92,"endColumn":19}],"suppressedMessages":[],"errorCount":2,"fatalErrorCount":0,"warningCount":1,"fixableErrorCount":0,"fixableWarningCount":0,"source":"import { useState, useEffect, useCallback } from 'react';\r\nimport { useParams, useNavigate, Link } from 'react-router-dom';\r\nimport api from '../api/axios';\r\nimport { useAuth } from '../context/AuthContext';\r\nimport { fixText } from '../utils/fixEncoding';\r\nimport usePageSEO from '../hooks/usePageSEO';\r\n\r\nexport default function Learn() {\r\n  const { courseId } = useParams();\r\n  const { user, loading: authLoading } = useAuth();\r\n  const navigate = useNavigate();\r\n\r\n  const [course, setCourse] = useState(null);\r\n  const [lessons, setLessons] = useState([]);\r\n  const [activeLesson, setActiveLesson] = useState(null);\r\n  const [activeQuiz, setActiveQuiz] = useState(null); // Bв”ңГЎi kiГҹв•—Гўm tra в”ҖГҰang lв”ңГЎm\r\n  \r\n  const [progress, setProgress] = useState({});\r\n  const [loading, setLoading] = useState(true);\r\n  const [errorStatus, setErrorStatus] = useState(null);\r\n  const [markingDone, setMarkingDone] = useState(false);\r\n  const [sidebarOpen, setSidebarOpen] = useState(true);\r\n\r\n  // Quiz states\r\n  const [userAnswers, setUserAnswers] = useState({});\r\n  const [quizResult, setQuizResult] = useState(null);\r\n  const [submittingQuiz, setSubmittingQuiz] = useState(false);\r\n\r\n  usePageSEO({\r\n    title: course ? `в”ҖГүang hГҹв•—Г¬c: ${fixText(course.title)}` : 'HГҹв•—Г¬c tГҹв•‘ВЎp',\r\n    description: course ? `Bв”ңГЎi giГҹв•‘Гәng trГҹв•—в–’c tuyГҹв•‘в”җn: ${fixText(course.title)} tГҹв•‘Гӯi EduVNU` : 'HГҹв•—Г¬c tГҹв•‘ВЎp tГҹв•‘Гӯi EduVNU',\r\n  });\r\n\r\n  useEffect(() => {\r\n    if (authLoading) return;\r\n    if (!user) { navigate('/login'); return; }\r\n    fetchData();\r\n  }, [courseId, user, authLoading]);\r\n\r\n  const fetchData = async () => {\r\n    try {\r\n      setLoading(true);\r\n      setErrorStatus(null);\r\n      const [courseRes, progressRes] = await Promise.all([\r\n        api.get(`/courses/courses/${courseId}/`),\r\n        api.get(`/courses/progress/my_progress/?course_id=${courseId}`).catch(() => ({ data: [] }))\r\n      ]);\r\n      \r\n      const courseData = courseRes.data;\r\n      setCourse(courseData);\r\n      \r\n      const allLessons = [];\r\n      (courseData.chapters || []).forEach(chapter => {\r\n          allLessons.push(...chapter.lessons);\r\n      });\r\n      setLessons(allLessons);\r\n\r\n      const pMap = {};\r\n      (progressRes.data || []).forEach(p => { pMap[p.lesson] = p.status; });\r\n      setProgress(pMap);\r\n      \r\n      if (allLessons.length > 0) setActiveLesson(allLessons[0]);\r\n    } catch (err) {\r\n      setErrorStatus(err.response?.status || 500);\r\n    } finally {\r\n      setLoading(false);\r\n    }\r\n  };\r\n\r\n  const markCompleted = useCallback(async () => {\r\n    if (!activeLesson || markingDone) return;\r\n    try {\r\n      setMarkingDone(true);\r\n      const status = progress[activeLesson.id] === 'completed' ? 'learning' : 'completed';\r\n      await api.post('/courses/progress/update_progress/', { lesson_id: activeLesson.id, status });\r\n      setProgress(prev => ({ ...prev, [activeLesson.id]: status }));\r\n      \r\n      if (status === 'completed') {\r\n        const idx = lessons.findIndex(l => l.id === activeLesson.id);\r\n        if (idx !== -1 && idx < lessons.length - 1) setTimeout(() => setActiveLesson(lessons[idx + 1]), 600);\r\n      }\r\n    } catch (e) { console.error(e); } finally { setMarkingDone(false); }\r\n  }, [activeLesson, markingDone, progress, lessons]);\r\n\r\n  const handleQuizSubmit = async () => {\r\n    if (!activeQuiz) return;\r\n    setSubmittingQuiz(true);\r\n    try {\r\n      const answers = Object.values(userAnswers);\r\n      const res = await api.post(`/courses/quizzes/${activeQuiz.id}/submit/`, { answers });\r\n      setQuizResult(res.data);\r\n    } catch (error) {\r\n      alert('LГҹв•—Г№i khi nГҹв•—Г–p bв”ңГЎi.');\r\n    } finally {\r\n      setSubmittingQuiz(false);\r\n    }\r\n  };\r\n\r\n  const renderPlayer = (url) => {\r\n    if (!url) return <div className=\"lrn-no-video\"><p>Video chГЈв–‘a cГҹв•‘ВЎp nhГҹв•‘ВЎt.</p></div>;\r\n    const vidId = url.includes('v=') ? url.split('v=')[1]?.split('&')[0] : url.split('/').pop();\r\n    return (\r\n      <iframe\r\n        src={`https://www.youtube.com/embed/${vidId}?rel=0`}\r\n        style={{ position: 'absolute', top: 0, left: 0, width: '100%', height: '100%', border: 'none' }}\r\n        allowFullScreen\r\n      />\r\n    );\r\n  };\r\n\r\n  if (authLoading || loading) return <div className=\"lrn-fullscreen-state\"><div className=\"lrn-spinner\" /><p>в”ҖГүang tГҹв•‘Гәi bв”ңГЎi giГҹв•‘Гәng...</p></div>;\r\n  if (errorStatus) return <div className=\"lrn-fullscreen-state\"><h2>LГҹв•—Г№i {errorStatus}</h2></div>;\r\n\r\n  return (\r\n    <div className=\"lrn-root\">\r\n      <header className=\"lrn-topbar\">\r\n        <div className=\"lrn-topbar-left\"><Link to=\"/\" className=\"lrn-logo\">EduVNU</Link> <span className=\"lrn-topbar-sep\">/</span> <span className=\"lrn-topbar-title\">{fixText(course?.title)}</span></div>\r\n        <div className=\"lrn-topbar-progress\">\r\n          <div className=\"lrn-topbar-progress-bar\"><div className=\"lrn-topbar-progress-fill\" style={{ width: `${Math.round((lessons.filter(l => progress[l.id] === 'completed').length / lessons.length) * 100)}%` }} /></div>\r\n          <span>{Math.round((lessons.filter(l => progress[l.id] === 'completed').length / lessons.length) * 100)}%</span>\r\n        </div>\r\n        <div className=\"lrn-topbar-right\"><button className=\"lrn-exit-btn\" onClick={() => navigate('/')}>Г”ВЈГІ Thoв”ңГӯt</button></div>\r\n      </header>\r\n\r\n      <div className=\"lrn-body\">\r\n        <main className=\"lrn-main\">\r\n          {activeQuiz ? (\r\n            <div className=\"quiz-container\" style={{padding: '40px', maxWidth: '800px', margin: '0 auto', background: '#fff', minHeight: '100%'}}>\r\n              <h1 style={{fontSize: '2rem', marginBottom: '10px'}}>{activeQuiz.title}</h1>\r\n              <p style={{color: '#64748b', marginBottom: '30px'}}>{activeQuiz.description || 'Hoв”ңГЎn thв”ңГЎnh bв”ңГЎi kiГҹв•—Гўm tra в”ҖГҰГҹв•—Гў в”ҖГҰв”ңГӯnh giв”ңГӯ kiГҹв•‘в”җn thГҹв•—В®c cГҹв•—Вәa bГҹв•‘Гӯn.'}</p>\r\n\r\n              {quizResult ? (\r\n                <div style={{padding: '30px', background: quizResult.passed ? '#f0fdf4' : '#fef2f2', borderRadius: '12px', border: `2px solid ${quizResult.passed ? '#22c55e' : '#ef4444'}`}}>\r\n                  <h2 style={{color: quizResult.passed ? '#15803d' : '#b91c1c', marginBottom: '10px'}}>{quizResult.passed ? 'ВӯЖ’Г„Г« Chв”ңв•‘c mГҹв•—ВҪng! BГҹв•‘Гӯn в”ҖГҰв”ңГә vГЈв–‘Гҹв•—Гәt qua.' : 'Г”ГҳГ® RГҹв•‘Г‘t tiГҹв•‘в”җc! BГҹв•‘Гӯn chГЈв–‘a в”ҖГҰГҹв•‘Гӯt в”ҖГҰiГҹв•—Гўm yв”ңВ¬u cГҹв•‘Вәu.'}</h2>\r\n                  <div style={{fontSize: '1.5rem', fontWeight: 700}}>в”ҖГүiГҹв•—Гўm cГҹв•—Вәa bГҹв•‘Гӯn: {quizResult.score.toFixed(1)}%</div>\r\n                  <p>SГҹв•—ГҰ cв”ңГіu в”ҖГҰв”ңв•‘ng: {quizResult.correct_count} / {quizResult.total_questions}</p>\r\n                  <button onClick={() => { setQuizResult(null); setUserAnswers({}); }} style={{marginTop: '20px', padding: '10px 20px', borderRadius: '8px', cursor: 'pointer'}}>Lв”ңГЎm lГҹв•‘Гӯi bв”ңГЎi thi</button>\r\n                </div>\r\n              ) : (\r\n                <div style={{display: 'flex', flexDirection: 'column', gap: '30px'}}>\r\n                  {activeQuiz.questions.map((q, idx) => (\r\n                    <div key={q.id} style={{padding: '20px', border: '1px solid #e2e8f0', borderRadius: '12px'}}>\r\n                      <h4 style={{marginBottom: '15px'}}>Cв”ңГіu {idx + 1}: {q.text}</h4>\r\n                      <div style={{display: 'flex', flexDirection: 'column', gap: '10px'}}>\r\n                        {q.choices.map(c => (\r\n                          <label key={c.id} style={{display: 'flex', alignItems: 'center', gap: '12px', padding: '12px', border: '1px solid #f1f5f9', borderRadius: '8px', cursor: 'pointer', background: userAnswers[q.id] === c.id ? '#eff6ff' : '#fff'}}>\r\n                            <input type=\"radio\" name={`q-${q.id}`} checked={userAnswers[q.id] === c.id} onChange={() => setUserAnswers({...userAnswers, [q.id]: c.id})} />\r\n                            {c.text}\r\n                          </label>\r\n                        ))}\r\n                      </div>\r\n                    </div>\r\n                  ))}\r\n                  <button onClick={handleQuizSubmit} disabled={submittingQuiz || Object.keys(userAnswers).length < activeQuiz.questions.length} style={{padding: '15px', background: '#0056d2', color: '#fff', border: 'none', borderRadius: '8px', fontWeight: 700, cursor: 'pointer', opacity: (submittingQuiz || Object.keys(userAnswers).length < activeQuiz.questions.length) ? 0.6 : 1}}>\r\n                    {submittingQuiz ? 'в”ҖГүang chГҹв•‘Г‘m в”ҖГҰiГҹв•—Гўm...' : 'NГҹв•—Г–p bв”ңГЎi kiГҹв•—Гўm tra'}\r\n                  </button>\r\n                </div>\r\n              )}\r\n            </div>\r\n          ) : activeLesson ? (\r\n            <>\r\n              <div className=\"lrn-player-wrap\"><div className=\"lrn-player-ratio\">{renderPlayer(activeLesson.video_url)}</div></div>\r\n              <div className=\"lrn-lesson-info\" style={{padding: '30px'}}>\r\n                <h1 className=\"lrn-lesson-title\">{fixText(activeLesson.title)}</h1>\r\n                <div style={{display: 'flex', gap: '15px', marginTop: '20px'}}>\r\n                  <button className={`lrn-done-btn ${progress[activeLesson.id] === 'completed' ? 'done' : ''}`} onClick={markCompleted} disabled={markingDone}>\r\n                    {progress[activeLesson.id] === 'completed' ? 'Г”ВЈГҙ в”ҖГүв”ңГә hoв”ңГЎn thв”ңГЎnh' : 'в”ҖГүв”ңГӯnh dГҹв•‘Г‘u hoв”ңГЎn thв”ңГЎnh'}\r\n                  </button>\r\n                </div>\r\n                <div className=\"lrn-lesson-content\" style={{marginTop: '30px'}}>\r\n                  <h3>ВӯЖ’ГҙГ» NГҹв•—Г–i dung bв”ңГЎi giГҹв•‘Гәng</h3>\r\n                  <p>{activeLesson.content || 'в”ҖГүang cГҹв•‘ВЎp nhГҹв•‘ВЎt nГҹв•—Г–i dung...'}</p>\r\n                </div>\r\n              </div>\r\n            </>\r\n          ) : null}\r\n        </main>\r\n\r\n        <aside className={`lrn-sidebar ${sidebarOpen ? 'open' : 'closed'}`}>\r\n          <div className=\"lrn-sidebar-header\"><span>NГҹв•—Г–i dung khв”ңв”Ӯa hГҹв•—Г¬c</span></div>\r\n          <div className=\"lrn-sidebar-content\" style={{ overflowY: 'auto', flex: 1 }}>\r\n            {course?.chapters?.map((chapter, cIdx) => (\r\n              <div key={chapter.id} className=\"lrn-chapter-group\" style={{ marginBottom: '15px' }}>\r\n                <div style={{ padding: '12px 20px', background: '#f8fafc', fontSize: '0.75rem', fontWeight: 700, color: '#64748b', textTransform: 'uppercase' }}>ChГЈв–‘ГЈГӯng {cIdx + 1}: {chapter.title}</div>\r\n                {chapter.lessons.map((ls, lIdx) => (\r\n                  <button key={ls.id} className={`lrn-lesson-item ${activeLesson?.id === ls.id && !activeQuiz ? 'active' : ''} ${progress[ls.id] === 'completed' ? 'done' : ''}`} onClick={() => { setActiveLesson(ls); setActiveQuiz(null); }}>\r\n                    <span className=\"lrn-lesson-num\">{progress[ls.id] === 'completed' ? 'Г”ВЈГҙ' : lIdx + 1}</span>\r\n                    <div className=\"lrn-lesson-item-info\"><span className=\"lrn-lesson-item-title\">{fixText(ls.title)}</span></div>\r\n                  </button>\r\n                ))}\r\n                {chapter.quiz && (\r\n                  <button className={`lrn-lesson-item ${activeQuiz?.id === chapter.quiz.id ? 'active' : ''}`} onClick={() => { setActiveQuiz(chapter.quiz); setActiveLesson(null); setQuizResult(null); setUserAnswers({}); }} style={{background: '#f0f9ff', color: '#0369a1', borderLeft: '4px solid #0ea5e9'}}>\r\n                    <span className=\"lrn-lesson-num\">ВӯЖ’ГҙГҳ</span>\r\n                    <div className=\"lrn-lesson-item-info\"><span className=\"lrn-lesson-item-title\"><b>Bв”ңГЎi kiГҹв•—Гўm tra:</b> {chapter.quiz.title}</span></div>\r\n                  </button>\r\n                )}\r\n              </div>\r\n            ))}\r\n          </div>\r\n        </aside>\r\n      </div>\r\n    </div>\r\n  );\r\n}\r\n","usedDeprecatedRules":[]},{"filePath":"D:\\ThГЈв–‘ГЈГӯng mГҹв•‘Гӯi в”ҖГҰiГҹв•—Г§n tГҹв•—ВЎ\\frontend\\src\\pages\\MockMoMo.jsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"D:\\ThГЈв–‘ГЈГӯng mГҹв•‘Гӯi в”ҖГҰiГҹв•—Г§n tГҹв•—ВЎ\\frontend\\src\\pages\\MockVNPay.jsx","messages":[{"ruleId":"no-unused-vars","severity":2,"message":"'navigate' is assigned a value but never used. Allowed unused vars must match /^[A-Z_]/u.","line":10,"column":9,"nodeType":"Identifier","messageId":"unusedVar","endLine":10,"endColumn":17,"suggestions":[{"messageId":"removeVar","data":{"varName":"navigate"},"fix":{"range":[390,421],"text":""},"desc":"Remove unused variable 'navigate'."}]},{"ruleId":"react-hooks/set-state-in-effect","severity":2,"message":"Error: Calling setState synchronously within an effect can trigger cascading renders\n\nEffects are intended to synchronize state between React and external systems such as manually updating the DOM, state management libraries, or other platform APIs. In general, the body of an effect should do one or both of the following:\n* Update external systems with the latest state from React.\n* Subscribe for updates from some external system, calling setState in a callback function when external state changes.\n\nCalling setState synchronously within an effect body causes cascading renders that can hurt performance, and is not recommended. (https://react.dev/learn/you-might-not-need-an-effect).\n\n  23 |   useEffect(() => {\n  24 |     if (!orderId) {\n> 25 |       setError('Mв”ңГә giao dГҹв•—ГҜch khв”ңв”Өng hГҹв•—Гәp lГҹв•—Г§!');\n     |       ^^^^^^^^ Avoid calling setState() directly within an effect\n  26 |     }\n  27 |   }, [orderId]);\n  28 |","line":25,"column":7,"nodeType":null,"endLine":25,"endColumn":15}],"suppressedMessages":[],"errorCount":2,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"source":"import { useState, useEffect } from 'react';\r\nimport { useSearchParams, useNavigate } from 'react-router-dom';\r\nimport api from '../api/axios';\r\nimport usePageSEO from '../hooks/usePageSEO';\r\nimport { Loading } from '../components/LoadingUI';\r\n\r\nexport default function MockVNPay() {\r\n  usePageSEO({ title: 'CГҹв•—ГІng thanh toв”ңГӯn VNPAY (Demo)' });\r\n  const [searchParams] = useSearchParams();\r\n  const navigate = useNavigate();\r\n  const orderId = searchParams.get('order_id');\r\n  const amount = searchParams.get('amount') || '0';\r\n\r\n  const [cardNumber, setCardNumber] = useState('9704198526191432198');\r\n  const [cardName, setCardName] = useState('NGUYEN VAN A');\r\n  const [cardDate, setCardDate] = useState('07/15');\r\n  const [otp, setOtp] = useState('');\r\n  \r\n  const [step, setStep] = useState(1); // 1 = input card, 2 = input otp\r\n  const [loading, setLoading] = useState(false);\r\n  const [error, setError] = useState('');\r\n\r\n  useEffect(() => {\r\n    if (!orderId) {\r\n      setError('Mв”ңГә giao dГҹв•—ГҜch khв”ңв”Өng hГҹв•—Гәp lГҹв•—Г§!');\r\n    }\r\n  }, [orderId]);\r\n\r\n  const handleNext = () => {\r\n    if (!cardNumber || !cardName || !cardDate) {\r\n      setError('Vui lв”ңв–“ng nhГҹв•‘ВЎp в”ҖГҰГҹв•‘Вәy в”ҖГҰГҹв•—Вә thв”ңв”Өng tin thГҹв•‘в•—');\r\n      return;\r\n    }\r\n    setError('');\r\n    setLoading(true);\r\n    setTimeout(() => {\r\n      setLoading(false);\r\n      setStep(2);\r\n    }, 1000);\r\n  };\r\n\r\n  const handleConfirm = async () => {\r\n    if (otp !== '123456') {\r\n      setError('Mв”ңГә OTP khв”ңв”Өng chв”ңВЎnh xв”ңГӯc. NhГҹв•‘ВЎp 123456 в”ҖГҰГҹв•—Гў tiГҹв•‘в”җp tГҹв•—Г‘c.');\r\n      return;\r\n    }\r\n    setError('');\r\n    setLoading(true);\r\n    try {\r\n      // Xв”ңГӯc nhГҹв•‘ВЎn thanh toв”ңГӯn qua API\r\n      await api.post(`/orders/${orderId}/confirm_payment/`, { transaction_id: 'VNPAY_MOCK_SUCCESS' });\r\n      // ChuyГҹв•—Гўn hГЈв–‘Гҹв•—Гёng vГҹв•—Гј trang KГҹв•‘в”җt quГҹв•‘Гә\r\n      window.location.href = `/payment-return?mock=success&order_id=${orderId}`;\r\n    } catch (e) {\r\n      setLoading(false);\r\n      setError('Failed to mock payment confirmation. See console.');\r\n      console.error(e);\r\n    }\r\n  };\r\n\r\n  if (error && !orderId) return <div style={{textAlign:'center', marginTop:50, color:'red'}}>{error}</div>;\r\n\r\n  return (\r\n    <div style={{minHeight:'100vh', background:'#f3f4f6', display:'flex', flexDirection:'column', alignItems:'center', padding:'40px 20px'}}>\r\n      <div style={{background:'white', width:'100%', maxWidth:500, borderRadius:12, boxShadow:'0 10px 25px rgba(0,0,0,0.1)', overflow:'hidden'}}>\r\n        \r\n        {/* Header */}\r\n        <div style={{background:'#0056d2', padding:'20px 30px', display:'flex', justifyContent:'space-between', alignItems:'center'}}>\r\n          <div style={{color:'white', fontWeight:800, fontSize:24, letterSpacing:1}}>VNPAY<span style={{fontWeight:400}}>QR</span></div>\r\n          <div style={{background:'rgba(255,255,255,0.2)', padding:'4px 10px', borderRadius:20, color:'white', fontSize:12, fontWeight:600}}>SANDBOX DEMO</div>\r\n        </div>\r\n\r\n        {/* Amount */}\r\n        <div style={{padding:'20px 30px', borderBottom:'1px solid #e5e7eb', textAlign:'center', background:'#f8fafc'}}>\r\n          <div style={{color:'#64748b', fontSize:14, marginBottom:4}}>SГҹв•—ГҰ tiГҹв•—Гјn thanh toв”ңГӯn</div>\r\n          <div style={{color:'#0f172a', fontSize:28, fontWeight:700}}>{Number(amount).toLocaleString('vi-VN')} VND</div>\r\n        </div>\r\n\r\n        {/* Content */}\r\n        <div style={{padding:'30px'}}>\r\n          {error && <div style={{background:'#fee2e2', color:'#ef4444', padding:12, borderRadius:6, marginBottom:20, fontSize:14}}>{error}</div>}\r\n\r\n          {step === 1 ? (\r\n            <div>\r\n              <div style={{fontWeight:600, marginBottom:20, color:'#1e293b'}}>ВӯЖ’ГҶв”Ӯ Thв”ңв”Өng tin thГҹв•‘в•— ATM NГҹв•—Г–i в”ҖГҰГҹв•—ГҜa</div>\r\n              \r\n              <div style={{marginBottom:16}}>\r\n                <label style={{display:'block', fontSize: