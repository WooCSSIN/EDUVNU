erflow: 'hidden' }}>\r\n                    <button onClick={() => setExpandedModule(expandedModule === mi ? -1 : mi)}\r\n                      style={{ width: '100%', padding: '14px 18px', display: 'flex', alignItems: 'center', justifyContent: 'space-between', background: expandedModule === mi ? '#eff6ff' : '#fff', border: 'none', cursor: 'pointer', textAlign: 'left' }}>\r\n                      <div style={{ display: 'flex', alignItems: 'center', gap: 12 }}>\r\n                        <div style={{ width: 34, height: 34, borderRadius: 8, background: grad, display: 'flex', alignItems: 'center', justifyContent: 'center', color: '#fff', fontWeight: 800, fontSize: 13, flexShrink: 0 }}>{mi + 1}</div>\r\n                        <div>\r\n                          <div style={{ fontWeight: 700, fontSize: 14, color: '#111' }}>{mod.title}</div>\r\n                          <div style={{ fontSize: 12, color: '#6b7280', marginTop: 2 }}>{mod.lessons.length} bв”ңГЎi hГҹв•—Г¬c</div>\r\n                        </div>\r\n                      </div>\r\n                      <span style={{ color: '#6b7280', fontSize: 18, transition: 'transform 0.2s', display: 'inline-block', transform: expandedModule === mi ? 'rotate(90deg)' : 'none' }}>Г”ГҮв•‘</span>\r\n                    </button>\r\n                    {expandedModule === mi && (\r\n                      <ul style={{ listStyle: 'none', margin: 0, padding: '4px 18px 14px 66px', background: '#f9fafb' }}>\r\n                        {mod.lessons.map((lesson, li) => (\r\n                          <li key={li} style={{ padding: '8px 0', borderTop: li > 0 ? '1px solid #f3f4f6' : 'none', display: 'flex', alignItems: 'center', gap: 10 }}>\r\n                            <span style={{ color: '#0056D2', fontSize: 13 }}>Г”Г»ГӮ</span>\r\n                            <span style={{ fontSize: 13, color: '#374151' }}>{lesson}</span>\r\n                          </li>\r\n                        ))}\r\n                      </ul>\r\n                    )}\r\n                  </div>\r\n                ))}\r\n              </div>\r\n            )}\r\n\r\n            {activeTab === 'videos' && (\r\n              <div style={{ display: 'flex', flexDirection: 'column', gap: 14 }}>\r\n                <p style={{ fontSize: 13, color: '#6b7280', marginBottom: 4 }}>Video hГҹв•—Г¬c tГҹв•‘ВЎp liв”ңВ¬n quan в”ҖГҰГЈв–‘Гҹв•—Гәc chГҹв•—Г¬n lГҹв•—Г¬c phв”ңв•Ј hГҹв•—Гәp vГҹв•—Гёi chГЈв–‘ГЈГӯng trв”ңВјnh {program.subject}.</p>\r\n                {(program.videos || []).map((video, i) => (\r\n                  <div key={i} style={{ display: 'flex', alignItems: 'center', gap: 14, padding: '14px 16px', background: '#f9fafb', borderRadius: 10, border: '1px solid #e5e7eb', cursor: 'pointer' }}\r\n                    onMouseEnter={e => e.currentTarget.style.background = '#eff6ff'}\r\n                    onMouseLeave={e => e.currentTarget.style.background = '#f9fafb'}>\r\n                    <div style={{ width: 48, height: 48, borderRadius: 10, background: grad, display: 'flex', alignItems: 'center', justifyContent: 'center', color: '#fff', fontSize: 20, flexShrink: 0 }}>Г”Г»ГӮ</div>\r\n                    <div style={{ flex: 1 }}>\r\n                      <div style={{ fontWeight: 600, fontSize: 14, color: '#111' }}>{video}</div>\r\n                      <div style={{ fontSize: 12, color: '#6b7280', marginTop: 3 }}>ChГҹв•—Вә в”ҖГҰГҹв•—Гј: {program.subject} Г”ГҮГі Dв”ңГЎnh cho hГҹв•—Г¬c viв”ңВ¬n в”ҖГҰв”ҖГўng kв”ңВў</div>\r\n                    </div>\r\n                    <span style={{ background: '#0056D2', color: '#fff', padding: '5px 12px', borderRadius: 20, fontSize: 11, fontWeight: 600, flexShrink: 0 }}>Xem ngay</span>\r\n                  </div>\r\n                ))}\r\n              </div>\r\n            )}\r\n\r\n            {activeTab === 'skills' && (\r\n              <div>\r\n                <p style={{ fontSize: 14, color: '#374151', marginBottom: 18, lineHeight: 1.6 }}>Sau khi hoв”ңГЎn thв”ңГЎnh, bГҹв•‘Гӯn sГҹв•‘Вў в”ҖГҰГЈв–‘Гҹв•—Гәc trang bГҹв•—ГҜ cв”ңГӯc kГҹв•—в•Ј nв”ҖГўng в”ҖГҰГЈв–‘Гҹв•—Гәc ngв”ңГЎnh cв”ңв”Өng nghiГҹв•—Г§p в”ҖГҰв”ңГӯnh giв”ңГӯ cao:</p>\r\n                <div style={{ display: 'flex', flexWrap: 'wrap', gap: 10 }}>\r\n                  {(program.skills || []).map((skill, i) => (\r\n                    <span key={i} style={{ background: '#eff6ff', color: '#1d4ed8', border: '1px solid #bfdbfe', padding: '8px 18px', borderRadius: 20, fontSize: 14, fontWeight: 600 }}>Г”ВЈГҙ {skill}</span>\r\n                  ))}\r\n                </div>\r\n                <div style={{ marginTop: 24, padding: 16, background: '#f0fdf4', borderRadius: 10, border: '1px solid #bbf7d0' }}>\r\n                  <div style={{ fontWeight: 700, color: '#15803d', marginBottom: 8 }}>ВӯЖ’Г…ГҘ ChГҹв•—В®ng chГҹв•—Г« в”ҖГҰГЈв–‘Гҹв•—Гәc cв”ңв”Өng nhГҹв•‘ВЎn</div>\r\n                  <p style={{ fontSize: 13, color: '#374151', lineHeight: 1.6, margin: 0 }}>Sau khi hoв”ңГЎn thв”ңГЎnh, bГҹв•‘Гӯn nhГҹв•‘ВЎn chГҹв•—В®ng chГҹв•—Г« tГҹв•—ВҪ <strong>{program.school}</strong> в”ҖГҰГЈв–‘Гҹв•—Гәc cв”ңв”Өng nhГҹв•‘ВЎn bГҹв•—Ж’i hв”ңГЎng trв”ҖГўm doanh nghiГҹв•—Г§p hв”ңГЎng в”ҖГҰГҹв•‘Вәu. Cв”ңв”Ӯ thГҹв•—Гў chia sГҹв•‘в•— trГҹв•—в–’c tiГҹв•‘в”җp lв”ңВ¬n LinkedIn vв”ңГЎ CV.</p>\r\n                </div>\r\n              </div>\r\n            )}\r\n          </div>\r\n\r\n          {/* FOOTER */}\r\n          <div className=\"deg-modal-btns\" style={{ padding: '16px 28px', borderTop: '1px solid #e5e7eb', background: '#fafafa' }}>\r\n            <button className=\"crs-btn-solid\" style={{ flex: 1, padding: '13px' }} onClick={(e) => { e.stopPropagation(); setShowTrialModal(true); }}>в”ҖГүв”ҖГўng kв”ңВў miГҹв•—Г n phв”ңВЎ</button>\r\n            <button className=\"crs-btn-outline\" style={{ flex: 1, padding: '13px' }} onClick={onClose}>в”ҖГүв”ңв”Ӯng</button>\r\n          </div>\r\n        </div>\r\n      </div>\r\n\r\n      {showTrialModal && (\r\n        <div style={{ position: 'fixed', top: 0, left: 0, width: '100%', height: '100%', background: 'rgba(0,0,0,0.5)', zIndex: 10000, display: 'flex', alignItems: 'center', justifyContent: 'center' }}>\r\n          <div style={{ background: '#fff', width: '90%', maxWidth: 640, borderRadius: 8, padding: '40px', position: 'relative', boxShadow: '0 20px 40px rgba(0,0,0,0.2)', textAlign: 'left' }}>\r\n            <button onClick={() => setShowTrialModal(false)} style={{ position: 'absolute', top: 16, right: 16, background: 'none', border: 'none', fontSize: 28, color: '#9ca3af', cursor: 'pointer', padding: '0 8px' }}>&times;</button>\r\n            <h2 style={{ fontSize: 26, fontWeight: 300, marginBottom: 32, color: '#111' }}>Dв”ңв•Јng thГҹв•—ВЎ miГҹв•—Г n phв”ңВЎ 7 ngв”ңГЎy</h2>\r\n            <div style={{ display: 'flex', flexDirection: 'column', gap: 24, marginBottom: 36 }}>\r\n              {[\r\n                { title: 'Truy cГҹв•‘ВЎp khв”ңв”Өng giГҹв•—Гёi hГҹв•‘Гӯn vв”ңГЎo tГҹв•‘Г‘t cГҹв•‘Гә cв”ңГӯc khв”ңв”Ӯa hГҹв•—Г¬c trong Chuyв”ңВ¬n ngв”ңГЎnh', desc: 'Xem cв”ңГӯc bв”ңГЎi giГҹв•‘Гәng, lв”ңГЎm thГҹв•—ВЎ cв”ңГӯc bв”ңГЎi tГҹв•‘ВЎp, tham gia vв”ңГЎo cв”ңГӯc diГҹв•—Г n в”ҖГҰв”ңГЎn thГҹв•‘Гәo luГҹв•‘ВЎn vв”ңГЎ hГЈГӯn thГҹв•‘в”җ nГҹв•—В»a.' },\r\n                { title: 'HГҹв•—Вәy bГҹв•‘Г‘t cГҹв•—В® lв”ңв•‘c nв”ңГЎo.', desc: 'Khв”ңв”Өng в”ңГӯp phв”ңВЎ phГҹв•‘Гӯt - chГҹв•—Г« cГҹв•‘Вәn hГҹв•—Вәy trГЈв–‘Гҹв•—Гёc khi bГҹв•‘Гәn dв”ңв•Јng thГҹв•—ВЎ kГҹв•‘в”җt thв”ңв•‘c nГҹв•‘в”җu nв”ңв”Ӯ khв”ңв”Өng phв”ңв•Ј hГҹв•—Гәp vГҹв•—Гёi bГҹв•‘Гӯn.' },\r\n                { title: '20 US$ USD mГҹв•—Г№i thв”ңГӯng в”ҖГҰГҹв•—Гў tiГҹв•‘в”җp tГҹв•—Г‘c hГҹв•—Г¬c sau khi bГҹв•‘Гәn dв”ңв•Јng thГҹв•—ВЎ cГҹв•—Вәa bГҹв•‘Гӯn kГҹв•‘в”җt thв”ңв•‘c', desc: 'HГҹв•—Г¬c cв”ңГЎng nhanh cв”ңГЎng tГҹв•—ГҰt - bГҹв•‘Гӯn hГҹв•—Г¬c cв”ңГЎng nhanh, bГҹв•‘Гӯn cв”ңГЎng tiГҹв•‘в”җt kiГҹв•—Г§m в”ҖГҰГЈв–‘Гҹв•—Гәc nhiГҹв•—Гјu.' },\r\n                { title: 'ChГҹв•—В®ng chГҹв•—Г« khi bГҹв•‘Гӯn hoв”ңГЎn thв”ңГЎnh sau khi thГҹв•—Гҳi hГҹв•‘Гӯn dв”ңв•Јng thГҹв•—ВЎ kГҹв•‘в”җt thв”ңв•‘c', desc: 'Chia sГҹв•‘в•— trв”ңВ¬n sГЈГӯ yГҹв•‘в”җu lв”ңВў lГҹв•—ГҜch, LinkedIn vв”ңГЎ CV cГҹв•—Вәa bГҹв•‘Гӯn.' },\r\n              ].map((item, i) => (\r\n                <div key={i} style={{ display: 'flex', gap: 16, alignItems: 'flex-start' }}>\r\n                  <svg width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"#2563eb\" strokeWidth=\"2\" strokeLinecap=\"round\" strokeLinejoin=\"round\" style={{ flexShrink: 0, marginTop: 2 }}>\r\n                    <polyline points=\"20 6 9 17 4 12\"></polyline>\r\n                  </svg>\r\n                  <div>\r\n                    <div style={{ fontWeight: 700, fontSize: 15, color: '#111', marginBottom: 6 }}>{item.title}</div>\r\n                    <div style={{ fontSize: 14, color: '#4b5563', lineHeight: 1.5 }}>{item.desc}</div>\r\n                  </div>\r\n                </div>\r\n              ))}\r\n            </div>\r\n            <button onClick={() => { setShowTrialModal(false); navigate('/checkout?trial=true', { state: { program: program } }); setTimeout(() => onClose(), 100); }}\r\n              style={{ padding: '16px 32px', background: '#0056D2', color: '#fff', border: 'none', borderRadius: 4, fontWeight: 700, fontSize: 16, cursor: 'pointer', width: '100%' }}>\r\n              BГҹв•‘В»t в”ҖГҰГҹв•‘Вәu Dв”ңв•Јng thГҹв•—ВЎ miГҹв•—Г n phв”ңВЎ\r\n            </button>\r\n          </div>\r\n        </div>\r\n      )}\r\n    </>\r\n  );\r\n}\r\n\r\n\r\n\r\n/* Г”Г¶ГҮГ”Г¶ГҮ FILTER DROPDOWN Г”Г¶ГҮГ”Г¶ГҮ */\r\nfunction FilterDropdown({ label, options, selected, onChange }) {\r\n  const [open, setOpen] = useState(false);\r\n  const [temp, setTemp] = useState(selected);\r\n  const ref = useRef(null);\r\n\r\n  useEffect(() => {\r\n    const h = (e) => { if (ref.current && !ref.current.contains(e.target)) setOpen(false); };\r\n    document.addEventListener('mousedown', h);\r\n    return () => document.removeEventListener('mousedown', h);\r\n  }, []);\r\n\r\n  const toggle = (val) => setTemp(p => p.includes(val) ? p.filter(x => x !== val) : [...p, val]);\r\n  const apply = () => { onChange(temp); setOpen(false); };\r\n  const clear = () => { setTemp([]); onChange([]); };\r\n\r\n  return (\r\n    <div className=\"deg-filter-wrap\" ref={ref}>\r\n      <button className={`deg-filter-btn ${open ? 'open' : ''} ${selected.length ? 'has-value' : ''}`} onClick={() => { setTemp(selected); setOpen(v => !v); }}>\r\n        {label} {selected.length > 0 && <span className=\"deg-filter-count\">{selected.length}</span>}\r\n        <span className=\"deg-filter-chevron\">{open ? 'Г”ГӘВә' : 'Г”ГӘВҝ'}</span>\r\n      </button>\r\n\r\n      {open && (\r\n        <div className=\"deg-filter-dropdown\">\r\n          <ul className=\"deg-filter-list\">\r\n            {options.map(opt => (\r\n              <li key={opt} className={`deg-filter-item ${temp.includes(opt) ? 'checked' : ''}`} onClick={() => toggle(opt)}>\r\n                <span className=\"deg-checkbox\">{temp.includes(opt) ? 'Г”ГҝГҰ' : 'Г”ГҝГү'}</span>\r\n                <span>{opt}</span>\r\n              </li>\r\n            ))}\r\n          </ul>\r\n          <div className=\"deg-filter-actions\">\r\n            <button className=\"deg-apply-btn\" onClick={apply}>в”ңГјp dГҹв•—Г‘ng</button>\r\n            <button className=\"deg-clear-btn\" onClick={clear}>Xв”ңв”Ӯa tГҹв•‘Г‘t cГҹв•‘Гә</button>\r\n          </div>\r\n        </div>\r\n      )}\r\n    </div>\r\n  );\r\n}\r\n\r\n/* Г”Г¶ГҮГ”Г¶ГҮ MAIN PAGE Г”Г¶ГҮГ”Г¶ГҮ */\r\nclass ErrorBoundary extends React.Component {\r\n  constructor(props) {\r\n    super(props);\r\n    this.state = { hasError: false, error: null, info: null };\r\n  }\r\n\r\n  static getDerivedStateFromError(error) {\r\n    return { hasError: true, error };\r\n  }\r\n\r\n  componentDidCatch(error, info) {\r\n    console.error(\"Degrees ErrorBoundary caught an error\", error, info);\r\n    this.setState({ error, info });\r\n  }\r\n\r\n  render() {\r\n    if (this.state.hasError) {\r\n      return (\r\n        <div style={{ padding: 40, background: '#fef2f2', color: '#991b1b', fontFamily: 'monospace' }}>\r\n          <h2>Component Crashed</h2>\r\n          <p><strong>Error:</strong> {this.state.error && this.state.error.toString()}</p>\r\n          <pre style={{ overflowX: 'auto', background: '#fee2e2', padding: 16 }}>{this.state.info && this.state.info.componentStack}</pre>\r\n        </div>\r\n      );\r\n    }\r\n    return this.props.children;\r\n  }\r\n}\r\n\r\nfunction Degrees() {\r\n  usePageSEO({ title: 'BГҹв•‘в–’ng cГҹв•‘Г‘p & ChГҹв•—В®ng chГҹв•—Г« chuyв”ңВ¬n nghiГҹв•—Г§p' });\r\n  const [levelFilter, setLevelFilter] = useState([]);\r\n  const [subjectFilter, setSubjectFilter] = useState([]);\r\n  const [selected, setSelected] = useState(null);\r\n  const navigate = useNavigate();\r\n\r\n  const filtered = PROGRAMS.filter(p => {\r\n    const lvlOk = levelFilter.length === 0 || levelFilter.includes(p.level);\r\n    const subOk = subjectFilter.length === 0 || subjectFilter.includes(p.subject);\r\n    return lvlOk && subOk;\r\n  });\r\n\r\n  return (\r\n    <div className=\"deg-page\">\r\n      {/* HERO */}\r\n      <section className=\"deg-hero\">\r\n        <div className=\"deg-hero-inner\">\r\n          <h1>Tв”ңВјm mГҹв•—Г–t chГЈв–‘ГЈГӯng trв”ңВјnh в”ҖГҰв”ңГЎo tГҹв•‘Гӯo trГҹв•—в–’c tuyГҹв•‘в”җn phв”ңв•Ј hГҹв•—Гәp vГҹв•—Гёi mГҹв•—Г‘c tiв”ңВ¬u cГҹв•—Вәa bГҹв•‘Гӯn</h1>\r\n          <p>NhГҹв•‘ВЎn bГҹв•‘в–’ng cГҹв•‘Г‘p tГҹв•—ВҪ cв”ңГӯc trГЈв–‘Гҹв•—Гҳng в”ҖГҰГҹв•‘Гӯi hГҹв•—Г¬c hв”ңГЎng в”ҖГҰГҹв•‘Вәu ViГҹв•—Г§t Nam Г”ГҮГ¶ hoв”ңГЎn toв”ңГЎn trГҹв•—в–’c tuyГҹв•‘в”җn</p>\r\n        </div>\r\n      </section>\r\n\r\n      {/* FILTER BAR */}\r\n      <div className=\"deg-filter-bar\">\r\n        <div className=\"deg-filter-bar-inner\">\r\n          <span className=\"deg-filter-label\">LГҹв•—Г¬c theo</span>\r\n          <FilterDropdown\r\n            label=\"CГҹв•‘Г‘p в”ҖГҰГҹв•—Г– chГЈв–‘ГЈГӯng trв”ңВјnh\"\r\n            options={DEGREE_LEVELS}\r\n            selected={levelFilter}\r\n            onChange={setLevelFilter}\r\n          />\r\n          <FilterDropdown\r\n            label=\"Mв”ңв”Өn hГҹв•—Г¬c\"\r\n            options={SUBJECTS}\r\n            selected={subjectFilter}\r\n            onChange={setSubjectFilter}\r\n          />\r\n          {(levelFilter.length > 0 || subjectFilter.length > 0) && (\r\n            <button className=\"deg-reset-all\" onClick={() => { setLevelFilter([]); setSubjectFilter([]); }}>\r\n              Xв”ңв”Ӯa tГҹв•‘Г‘t cГҹв•‘Гә bГҹв•—Г– lГҹв•—Г¬c\r\n            </button>\r\n          )}\r\n          <span className=\"deg-result-count\">{filtered.length} chГЈв–‘ГЈГӯng trв”ңВјnh</span>\r\n        </div>\r\n      </div>\r\n\r\n      {/* PROGRAM GRID */}\r\n      <div className=\"deg-grid-section\">\r\n        <div className=\"deg-grid\">\r\n          {filtered.length === 0 ? (\r\n            <div className=\"deg-empty\">\r\n              <p>Khв”ңв”Өng tв”ңВјm thГҹв•‘Г‘y chГЈв–‘ГЈГӯng trв”ңВјnh phв”ңв•Ј hГҹв•—Гәp vГҹв•—Гёi bГҹв•—Г– lГҹв•—Г¬c в”ҖГҰв”ңГә chГҹв•—Г¬n.</p>\r\n              <button className=\"crs-btn-outline\" onClick={() => { setLevelFilter([]); setSubjectFilter([]); }}>Xв”ңв”Ӯa bГҹв•—Г– lГҹв•—Г¬c</button>\r\n            </div>\r\n          ) : (\r\n            filtered.map(p => (\r\n              <div key={p.id} className=\"deg-card\" onClick={() => setSelected(p)}>\r\n                <div className=\"deg-card-header\">\r\n                  <div className=\"deg-card-logo\" style={{ background: GRAD_MAP[p.logo] || 'linear-gradient(135deg,#0369a1,#0ea5e9)' }}>\r\n                    {p.logo}\r\n                  </div>\r\n                  <p className=\"deg-card-school\">{p.school}</p>\r\n                </div>\r\n                <div className=\"deg-card-body\">\r\n                  <h3 className=\"deg-card-title\">{p.title}</h3>\r\n                  <div className=\"deg-card-meta\">\r\n                    <span className=\"deg-level-badge\">{p.level}</span>\r\n                    <span className=\"deg-subject-badge\">{p.subject}</span>\r\n                  </div>\r\n                  <div className=\"deg-card-info\">\r\n                    <span>Г”Г…в–’ {p.duration}</span>\r\n                    <span>ВӯЖ’ГҶв–‘ {p.tuition}</span>\r\n                  </div>\r\n                  <p className=\"deg-card-deadline\">\r\n                    <span>ВӯЖ’ГҙГ </span> HГҹв•‘Гӯn nГҹв•—Г–p hГҹв•—Гҙ sГЈГӯ {p.deadline}\r\n                  </p>\r\n                </div>\r\n              </div>\r\n            ))\r\n          )}\r\n        </div>\r\n      </div>\r\n\r\n      {/* DETAIL MODAL */}\r\n      {selected && <DegreeDetail program={selected} onClose={() => setSelected(null)} />}\r\n    </div>\r\n  );\r\n}\r\n\r\nexport default function DegreesWithErrorBoundary() {\r\n  return (\r\n    <ErrorBoundary>\r\n      <Degrees />\r\n    </ErrorBoundary>\r\n  );\r\n}\r\n","usedDeprecatedRules":[]},{"filePath":"D:\\ThГЈв–‘ГЈГӯng mГҹв•‘Гӯi в”ҖГҰiГҹв•—Г§n tГҹв•—ВЎ\\frontend\\src\\pages\\Documents.jsx","messages":[{"ruleId":"react-hooks/exhaustive-deps","severity":1,"message":"React Hook useEffect has a missing dependency: 'navigate'. Either include it or remove the dependency array.","line":27,"column":6,"nodeType":"ArrayExpression","endLine":27,"endColumn":25,"suggestions":[{"desc":"Update the dependencies array to be: [user, authLoading, navigate]","fix":{"range":[1146,1165],"text":"[user, authLoading, navigate]"}}]}],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":1,"fixableErrorCount":0,"fixableWarningCount":0,"source":"import { useState, useEffect } from 'react';\r\nimport { useNavigate } from 'react-router-dom';\r\nimport api from '../api/axios';\r\nimport { useAuth } from '../context/AuthContext';\r\nimport usePageSEO from '../hooks/usePageSEO';\r\n\r\nexport default function Documents() {\r\n  usePageSEO({ title: 'Tв”ңГЎi liГҹв•—Г§u hГҹв•—Г¬c tГҹв•‘ВЎp', description: 'TГҹв•—ВҪ khв”ңв”Ӯa khв”ңв”Ӯa hГҹв•—Г¬c, giв”ңГӯo trв”ңВјnh, slide bв”ңГЎi giГҹв•‘Гәng в”ҖГҰГЈв–‘Гҹв•—Гәc liв”ңВ¬n kГҹв•‘в”җt trГҹв•—в–’c tiГҹв•‘в”җp trв”ңВ¬n khв”ңв”Ӯa hГҹв•—Г¬c cГҹв•—Вәa bГҹв•‘Гӯn.' });\r\n  const { user, loading: authLoading } = useAuth();\r\n  const navigate = useNavigate();\r\n  const [enrollments, setEnrollments] = useState([]);\r\n  const [selectedCourse, setSelectedCourse] = useState(null);\r\n  const [lessons, setLessons] = useState([]);\r\n  const [loading, setLoading] = useState(true);\r\n  const [lessonsLoading, setLessonsLoading] = useState(false);\r\n\r\n  useEffect(() => {\r\n    if (authLoading) return;\r\n    if (!user) { navigate('/login'); return; }\r\n    api.get('/courses/courses/my_courses/')\r\n      .then(res => {\r\n        setEnrollments(res.data);\r\n        if (res.data.length > 0) loadLessons(res.data[0].course);\r\n        else setLoading(false);\r\n      })\r\n      .catch(() => setLoading(false));\r\n  }, [user, authLoading]);\r\n\r\n  const loadLessons = async (course) => {\r\n    setSelectedCourse(course);\r\n    setLessonsLoading(true);\r\n    try {\r\n      const res = await api.get(`/courses/courses/${course.id}/lessons/`);\r\n      setLessons(res.data);\r\n    } catch { setLessons([]); }\r\n    finally { setLessonsLoading(false); }\r\n  };\r\n\r\n  if (loading) return <div className=\"page-loading\">в”ҖГүang tГҹв•‘Гәi tв”ңГЎi liГҹв•—Г§u Г”Г®Гё</div>;\r\n\r\n  return (\r\n    <div className=\"documents-page\">\r\n      <div className=\"page-header\">\r\n        <h2>ВӯЖ’ГҙГӨ Tв”ңГЎi LiГҹв•—Г§u</h2>\r\n        <p>NГҹв•—Г–i dung bв”ңГЎi hГҹв•—Г¬c tГҹв•—ВҪ cв”ңГӯc khв”ңв”Ӯa hГҹв•—Г¬c в”ҖГҰв”ңГә в”ҖГҰв”ҖГўng kв”ңВў</p>\r\n      </div>\r\n\r\n      {enrollments.length === 0 ? (\r\n        <div className=\"page-empty\">\r\n          <div className=\"empty-icon\">ВӯЖ’ГҙГ©</div>\r\n          <p>BГҹв•‘Гӯn chГЈв–‘a cв”ңв”Ӯ tв”ңГЎi liГҹв•—Г§u nв”ңГЎo. Hв”ңГәy в”ҖГҰв”ҖГўng kв”ңВў khв”ңв”Ӯa hГҹв•—Г¬c trГЈв–‘Гҹв•—Гёc.</p>\r\n          <button onClick={() => navigate('/')}>Khв”ңГӯm phв”ңГӯ khв”ңв”Ӯa hГҹв•—Г¬c</button>\r\n        </div>\r\n      ) : (\r\n        <div className=\"documents-layout\">\r\n          {/* SIDEBAR COURSES */}\r\n          <aside className=\"docs-sidebar\">\r\n            <h4>Khв”ңв”Ӯa hГҹв•—Г¬c cГҹв•—Вәa tв”ңв”Өi</h4>\r\n            {enrollments.map(e => (\r\n              <div\r\n                key={e.id}\r\n                className={`docs-course-item ${selectedCourse?.id === e.course.id ? 'active' : ''}`}\r\n                onClick={() => loadLessons(e.course)}\r\n              >\r\n                <div className=\"docs-course-dot\" />\r\n                <span>{e.course.title}</span>\r\n              </div>\r\n            ))}\r\n          </aside>\r\n\r\n          {/* LESSONS LIST */}\r\n          <main className=\"docs-main\">\r\n            {selectedCourse && (\r\n              <>\r\n                <h3 className=\"docs-course-title\">{selectedCourse.title}</h3>\r\n                {lessonsLoading ? (\r\n                  <p>в”ҖГүang tГҹв•‘Гәi bв”ңГЎi hГҹв•—Г¬c...</p>\r\n                ) : lessons.length === 0 ? (\r\n                  <div className=\"docs-empty\">Khв”ңв”Ӯa hГҹв•—Г¬c nв”ңГЎy chГЈв–‘a cв”ңв”Ӯ bв”ңГЎi hГҹв•—Г¬c nв”ңГЎo.</div>\r\n                ) : (\r\n                  <div className=\"docs-lessons\">\r\n                    {lessons.map((lesson, idx) => (\r\n                      <div className=\"docs-lesson-card\" key={lesson.id}>\r\n                        <div className=\"docs-lesson-num\">{idx + 1}</div>\r\n                        <div className=\"docs-lesson-info\">\r\n                          <h4>{lesson.title}</h4>\r\n                          <p className=\"docs-lesson-preview\">\r\n                            {lesson.content?.substring(0, 120)}{lesson.content?.length > 120 ? '...' : ''}\r\n                          </p>\r\n                          {lesson.video_url && (\r\n                            <a href={lesson.video_url} target=\"_blank\" rel=\"noreferrer\" className=\"docs-video-link\">\r\n                              ВӯЖ’Г„Вј Xem video\r\n                            </a>\r\n                          )}\r\n                        </div>\r\n                        <button\r\n                          className=\"go-learn-btn\"\r\n                          onClick={() => navigate(`/learn/${selectedCourse.id}`)}\r\n                        >\r\n                          HГҹв•—Г¬c ngay Г”ГҘГҶ\r\n                        </button>\r\n                      </div>\r\n                    ))}\r\n                  </div>\r\n                )}\r\n              </>\r\n            )}\r\n          </main>\r\n        </div>\r\n      )}\r\n    </div>\r\n  );\r\n}\r\n","usedDeprecatedRules":[]},{"filePath":"D:\\ThГЈв–‘ГЈГӯng mГҹв•‘Гӯi в”ҖГҰiГҹв•—Г§n tГҹв•—ВЎ\\frontend\\src\\pages\\Home.jsx","messages":[{"ruleId":"no-unused-vars","severity":2,"message":"'parseMetadata' is defined but never used. Allowed unused vars must match /^[A-Z_]/u.","line":5,"column":19,"nodeType":"Identifier","messageId":"unusedVar","endLine":5,"endColumn":32,"suggestions":[{"messageId":"removeVar","data":{"varName":"parseMetadata"},"fix":{"range":[214,229],"text":""},"desc":"Remove unused variable 'parseMetadata'."}]},{"ruleId":"react-hooks/exhaustive-deps","severity":1,"message":"React Hook useEffect has a missing dependency: 'fetchCourses'. Either include it or remove the dependency array.","line":42,"column":6,"nodeType":"ArrayExpression","endLine":42,"endColumn":45,"suggestions":[{"desc":"Update the dependencies array to be: [searchQuery, activeCategory, ordering, fetchCourses]","fix":{"range":[1831,1870],"text":"[searchQuery, activeCategory, ordering, fetchCourses]"}}]}],"suppressedMessages":[],"errorCount":1,"fatalErrorCount":0,"warningCount":1,"fixableErrorCount":0,"fixableWarningCount":0,"source":"import { useState, useEffect } from 'react';\r\nimport { useNavigate, Link, useLocation } from 'react-router-dom';\r\nimport api from '../api/axios';\r\nimport { useAuth } from '../context/AuthContext';\r\nimport { fixText, parseMetadata } from '../utils/fixEncoding';\r\nimport { getCourseThumbnail } from '../utils/courseImages';\r\nimport { Loading, SkeletonCard } from '../components/LoadingUI';\r\nimport usePageSEO from '../hooks/usePageSEO';\r\n\r\nexport default function Home() {\r\n  usePageSEO({\r\n    title: 'Trang chГҹв•—Вә',\r\n    description: 'EduVNU - NГҹв•—Гјn tГҹв•‘Гәng hГҹв•—Г¬c trГҹв•—в–’c tuyГҹв•‘в”җn hв”ңГЎng в”ҖГҰГҹв•‘Вәu ViГҹв•—Г§t Nam. 100+ khв”ңв”Ӯa hГҹв•—Г¬c chГҹв•‘Г‘t lГЈв–‘Гҹв•—Гәng cao vГҹв•—Гј AI, Data Science, Business, UX Design tГҹв•—ВҪ cв”ңГӯc в”ҖГҰГҹв•—ГҰi tв”ңГӯc uy tв”ңВЎn quГҹв•—ГҰc tГҹв•‘в”җ.',\r\n    keywords: 'hГҹв•—Г¬c trГҹв•—в–’c tuyГҹв•‘в”җn, khв”ңв”Ӯa hГҹв•—Г¬c online, EduVNU, AI, data science, lГҹв•‘ВЎp trв”ңВјnh, python, UX design',\r\n  });\r\n  const [courses, setCourses] = useState([]);\r\n  const [categories, setCategories] = useState([]);\r\n  const [loading, setLoading] = useState(true);\r\n  const [addingId, setAddingId] = useState(null);\r\n  const [searchQuery, setSearchQuery] = useState('');\r\n  const [activeCategory, setActiveCategory] = useState('');\r\n  const [ordering, setOrdering] = useState(''); // New ordering state\r\n  const [toast, setToast] = useState('');\r\n  const { user } = useAuth();\r\n  const navigate = useNavigate();\r\n  const location = useLocation();\r\n\r\n  // в”ҖГүГҹв•—Г¬c ?q= tГҹв•—ВҪ URL (в”ҖГҰГЈв–‘Гҹв•—Гәc set bГҹв•—Ж’i Header Search Bar)\r\n  useEffect(() => {\r\n    const params = new URLSearchParams(location.search);\r\n    const q = params.get('q');\r\n    if (q) setSearchQuery(q);\r\n  }, [location.search]);\r\n\r\n  useEffect(() => {\r\n    api.get('/courses/categories/').then(res => setCategories(res.data.results || res.data || [])).catch(() => {});\r\n  }, []);\r\n\r\n  useEffect(() => {\r\n    const timer = setTimeout(() => fetchCourses(), 400);\r\n    return () => clearTimeout(timer);\r\n  }, [searchQuery, activeCategory, ordering]);\r\n\r\n  const fetchCourses = async () => {\r\n    setLoading(true);\r\n    try {\r\n      const params = new URLSearchParams();\r\n      if (searchQuery) params.append('q', searchQuery);\r\n      if (activeCategory) params.append('category', activeCategory);\r\n      if (ordering) params.append('ordering', ordering);\r\n      const res = await api.get('/courses/courses/?' + params.toString());\r\n      setCourses(Array.isArray(res.data) ? res.data : (res.data.results || []));\r\n    } catch { setCourses([]); }\r\n    finally { setLoading(false); }\r\n  };\r\n\r\n  const addToCart = async (e, courseId) => {\r\n    e.preventDefault(); e.stopPropagation(); // Ngay chan viec nhay trang vao detail\r\n    if (!user) { navigate('/login'); return; }\r\n    setAddingId(courseId);\r\n    try {\r\n      await api.post('/cart/add_item/', { course_id: courseId });\r\n      setToast('Г”ВЈГ  в”ҖГүв”ңГә thв”ңВ¬m vв”ңГЎo giГҹв•—Г… hв”ңГЎng!');\r\n      setTimeout(() => setToast(''), 3000);\r\n    } catch (err) {\r\n      setToast(err.response?.data?.message || 'Г”ГҳГ® Khв”ңв”Өng thГҹв•—Гў thв”ңВ¬m.');\r\n      setTimeout(() => setToast(''), 3000);\r\n    } finally { setAddingId(null); }\r\n  };\r\n\r\n  return (\r\n    <main className=\"home-wrapper\">\r\n      {/* COURSERA STYLE HERO */}\r\n      <section className=\"hero-section\" style={{position: 'relative', overflow: 'hidden', color: 'white', padding: '120px 64px', minHeight: '550px', display: 'flex', alignItems: 'center'}}>\r\n        {/* LГҹв•—Гёp iframe nГҹв•—Гјn full section (cв”ңв”Ӯ cГҹв•‘В»t phГҹв•‘Вәn dГЈв–‘Гҹв•—Гёi в”ҖГҰГҹв•—Гў giГҹв•‘Г‘u logo Spline) */}\r\n        <div style={{position: 'absolute', top: 0, left: 0, width: '100%', height: '100%', zIndex: 0, overflow: 'hidden'}}>\r\n          <iframe \r\n            src=\"https://my.spline.design/earth-ioVfVKnUbg0yrx8WVxPZmIrd/\" \r\n            frameBorder=\"0\" \r\n            title=\"Trв”ңГӯi в”ҖГҰГҹв•‘Г‘t 3D\"\r\n            style={{width: '100%', height: 'calc(100% + 80px)', border: 'none', display: 'block'}}\r\n          ></iframe>\r\n        </div>\r\n        \r\n        {/* LГҹв•—Гёp phГҹв•—Вә mГҹв•—Гҳ gradient (cho phв”ңВ®p chuГҹв•—Г–t в”ҖГҰв”ңГіm xuyв”ңВ¬n qua vГҹв•—Гёi pointerEvents: 'none' в”ҖГҰГҹв•—Гў tГЈв–‘ГЈГӯng tв”ңГӯc 3D) */}\r\n        <div style={{position: 'absolute', top: 0, left: 0, width: '100%', height: '100%', background: 'linear-gradient(to right, rgba(0,37,91,0.95) 0%, rgba(0,37,91,0.5) 50%, rgba(0,37,91,0.1) 100%)', pointerEvents: 'none', zIndex: 1}}></div>\r\n\r\n        <div className=\"hero-text\" style={{maxWidth: '700px', position: 'relative', zIndex: 2}}>\r\n          <h1 style={{fontSize: '56px', fontWeight: '700', lineHeight: '1.1', marginBottom: '24px'}}>\r\n            HГҹв•—Г¬c tГҹв•‘ВЎp vв”ңГЎ thв”ҖГўng tiГҹв•‘в”җn <br/> sГҹв•—в–’ nghiГҹв•—Г§p cГҹв•—Вәa bГҹв•‘Гӯn\r\n          </h1>\r\n          <p style={{fontSize: '20px', marginBottom: '40px', opacity: 0.9}}>\r\n            HГҹв•—Г¬c cв”ңГӯc chГҹв•—В®ng chГҹв•—Г« trГҹв•—в–’c tuyГҹв•‘в”җn tГҹв•—ВҪ cв”ңГӯc trГЈв–‘Гҹв•—Гҳng в”ҖГҰГҹв•‘Гӯi hГҹв•—Г¬c vв”ңГЎ cв”ңв”Өng ty hв”ңГЎng в”ҖГҰГҹв•‘Вәu thГҹв•‘в”җ giГҹв•—Гёi nhГЈв–‘ Google, IBM, Meta.\r\n          </p>\r\n          <div className=\"hero-buttons\" style={{display: 'flex', gap: '16px'}}>\r\n            <button className=\"btn-join\" style={{padding: '16px 32px', fontSize: '18px', fontWeight: 'bold'}} onClick={()=>navigate('/login')}>Tham gia miГҹв•—Г n phв”ңВЎ</button>\r\n            <button className=\"btn-login\" style={{color: 'black', background: 'rgba(255,255,255,0.9)', borderColor: 'transparent', padding: '16px 32px', fontSize: '18px', fontWeight: 'bold'}} onClick={()=>navigate('/degrees')}>Dв”ңГЎnh cho doanh nghiГҹв•—Г§p</button>\r\n          </div>\r\n        </div>\r\n      </section>\r\n\r\n      <section className=\"container\" style={{maxWidth: '1200px', margin: '0 auto', padding: '48px 20px'}}>\r\n        <nav className=\"filter-row\" aria-label=\"LГҹв•—Г¬c khв”ңв”Ӯa hГҹв•—Г¬c\" style={{display: 'flex', flexWrap: 'wrap', gap: '20px', justifyContent: 'space-between', alignItems: 'center', marginBottom: '40px'}}>\r\n           <div className=\"tabs\" style={{display: 'flex', gap: '24px', overflowX: 'auto', whiteSpace: 'nowrap', paddingBottom: '4px', flex: '1 1 0%', minWidth: 0}} role=\"tablist\">\r\n             <button className={activeCategory === '' ? 'tab active' : 'tab'} \r\n                     style={{border: 'none', background: 'none', cursor: 'pointer', fontWeight: '600', paddingBottom: '8px', borderBottom: activeCategory === '' ? '2px solid #0056d2' : 'none', flexShrink: 0}}\r\n                     onClick={() => setActiveCategory('')}>\r\n                TГҹв•‘Г‘t cГҹв•‘Гә cв”ңГӯc chГҹв•—Вә в”ҖГҰГҹв•—Гј\r\n             </button>\r\n             {categories.map(cat => (\r\n               <button key={cat.id} \r\n                       className={activeCategory === String(cat.id) ? 'tab active' : 'tab'}\r\n                       style={{border: 'none', background: 'none', cursor: 'pointer', fontWeight: '600', paddingBottom: '8px', borderBottom: activeCategory === String(cat.id) ? '2px solid #0056d2' : 'none', flexShrink: 0}}\r\n                       onClick={() => setActiveCategory(String(cat.id))}>\r\n                  {fixText(cat.name)}\r\n               </button>\r\n             ))}\r\n           </div>\r\n           \r\n           <div style={{display: 'flex', gap: '16px'}}>\r\n             <div className=\"search-box\" style={{position: 'relative', width: '250px'}}>\r\n               <input type=\"text\" placeholder=\"BГҹв•‘Гӯn muГҹв•—ГҰn hГҹв•—Г¬c gв”ңВј?\" \r\n                      value={searchQuery}\r\n                      onChange={e => setSearchQuery(e.target.value)}\r\n                      style={{width: '100%', padding: '10px 30px 10px 16px', borderRadius: '4px', border: '1px solid #ccc'}} />\r\n               {searchQuery && (\r\n                 <button onClick={() => { setSearchQuery(''); navigate('/'); }} \r\n            