п»ҝ[{"filePath":"D:\\ThГЈв–‘ГЈГӯng mГҹв•‘Гӯi в”ҖГҰiГҹв•—Г§n tГҹв•—ВЎ\\frontend\\eslint.config.js","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"D:\\ThГЈв–‘ГЈГӯng mГҹв•‘Гӯi в”ҖГҰiГҹв•—Г§n tГҹв•—ВЎ\\frontend\\src\\App.jsx","messages":[{"ruleId":"react-hooks/set-state-in-effect","severity":2,"message":"Error: Calling setState synchronously within an effect can trigger cascading renders\n\nEffects are intended to synchronize state between React and external systems such as manually updating the DOM, state management libraries, or other platform APIs. In general, the body of an effect should do one or both of the following:\n* Update external systems with the latest state from React.\n* Subscribe for updates from some external system, calling setState in a callback function when external state changes.\n\nCalling setState synchronously within an effect body causes cascading renders that can hurt performance, and is not recommended. (https://react.dev/learn/you-might-not-need-an-effect).\n\n  102 |       api.get('/cart/my_cart/').then(r => setCartCount(r.data.items?.length || 0)).catch(() => {});\n  103 |       api.get('/courses/notifications/').then(r => setNotifications(r.data.results || r.data)).catch(() => {});\n> 104 |     } else { setCartCount(0); }\n      |              ^^^^^^^^^^^^ Avoid calling setState() directly within an effect\n  105 |   }, [user]);\n  106 |\n  107 |   useEffect(() => {","line":104,"column":14,"nodeType":null,"endLine":104,"endColumn":26},{"ruleId":"no-unused-vars","severity":2,"message":"'e' is defined but never used.","line":121,"column":14,"nodeType":"Identifier","messageId":"unusedVar","endLine":121,"endColumn":15},{"ruleId":"no-empty","severity":2,"message":"Empty block statement.","line":121,"column":17,"nodeType":"BlockStatement","messageId":"unexpected","endLine":121,"endColumn":19,"suggestions":[{"messageId":"suggestComment","data":{"type":"block"},"fix":{"range":[4944,4944],"text":" /* empty */ "},"desc":"Add comment inside empty block statement."}]}],"suppressedMessages":[],"errorCount":3,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"source":"import { useState, useRef, useEffect } from 'react';\r\nimport { BrowserRouter, Routes, Route, Link, useNavigate } from 'react-router-dom';\r\nimport './App.css';\r\nimport Home from './pages/Home';\r\nimport Auth from './pages/Auth';\r\nimport Profile from './pages/Profile';\r\nimport Cart from './pages/Cart';\r\nimport Learn from './pages/Learn';\r\nimport Schedule from './pages/Schedule';\r\nimport Documents from './pages/Documents';\r\nimport Checkout from './pages/Checkout';\r\nimport PaymentReturn from './pages/PaymentReturn';\r\nimport Orders from './pages/Orders';\r\nimport Degrees from './pages/Degrees';\r\nimport CourseDetail from './pages/CourseDetail';\r\nimport NotFound from './pages/NotFound';\r\nimport Contact from './pages/Contact';\r\nimport MockVNPay from './pages/MockVNPay';\r\nimport MockMoMo from './pages/MockMoMo';\r\nimport SePayCheckout from './pages/SePayCheckout';\r\nimport StripeCheckout from './pages/StripeCheckout';\r\nimport InstructorDashboard from './pages/InstructorDashboard';\r\nimport InstructorCreateCourse from './pages/InstructorCreateCourse';\r\nimport InstructorCourseCurriculum from './pages/InstructorCourseCurriculum';\r\nimport InstructorStudents from './pages/InstructorStudents';\r\nimport InstructorReviews from './pages/InstructorReviews';\r\nimport InstructorFinance from './pages/InstructorFinance';\r\nimport InstructorHelp from './pages/InstructorHelp';\r\nimport InstructorAnalytics from './pages/InstructorAnalytics';\r\nimport InstructorSettings from './pages/InstructorSettings';\r\nimport InstructorLogin from './pages/InstructorLogin';\r\nimport InstructorCourseList from './pages/InstructorCourseList';\r\nimport AdminDashboard from './pages/AdminDashboard';\r\nimport { AuthProvider, useAuth } from './context/AuthContext';\r\nimport api from './api/axios';\r\n\r\n/* Г”Г¶ГҮГ”Г¶ГҮ MEGA MENU DATA Г”Г¶ГҮГ”Г¶ГҮ */\r\nconst EXPLORE_COLS = [\r\n  {\r\n    title: 'Khв”ңГӯm phв”ңГӯ vai trв”ңв–“',\r\n    items: ['Nhв”ңГЎ phв”ңГіn tв”ңВЎch dГҹв•—В» liГҹв•—Г§u','QuГҹв•‘Гәn lв”ңВў dГҹв•—в–’ в”ңГӯn','Nhв”ңГЎ phв”ңГіn tв”ңВЎch An ninh MГҹв•‘Гӯng','Nhв”ңГЎ khoa hГҹв•—Г¬c dГҹв•—В» liГҹв•—Г§u','KГҹв•—в•Ј sГЈв–‘ hГҹв•—Г¬c mв”ңГӯy','ThiГҹв•‘в”җt kГҹв•‘в”җ UX/UI','Chuyв”ңВ¬n gia Marketing sГҹв•—ГҰ'],\r\n  },\r\n  {\r\n    title: 'Khв”ңГӯm phв”ңГӯ danh mГҹв•—Г‘c',\r\n    items: ['Trв”ңВЎ tuГҹв•—Г§ nhв”ңГіn tГҹв•‘Гӯo','Kinh doanh','Khoa hГҹв•—Г¬c dГҹв•—В» liГҹв•—Г§u','Cв”ңв”Өng nghГҹв•—Г§ thв”ңв”Өng tin','Khoa hГҹв•—Г¬c mв”ңГӯy tв”ңВЎnh','Chв”ҖГўm sв”ңв”Ӯc sГҹв•—В®c khГҹв•—Г…e','Phв”ңГӯt triГҹв•—Гўn cв”ңГӯ nhв”ңГіn','HГҹв•—Г¬c ngв”ңв”Өn ngГҹв•—В»'],\r\n  },\r\n  {\r\n    title: 'NhГҹв•‘ВЎn ChГҹв•—В®ng chГҹв•—Г« Chuyв”ңВ¬n mв”ңв”Өn',\r\n    items: ['Kinh doanh','Khoa hГҹв•—Г¬c mв”ңГӯy tв”ңВЎnh','Khoa hГҹв•—Г¬c dГҹв•—В» liГҹв•—Г§u','Cв”ңв”Өng nghГҹв•—Г§ thв”ңв”Өng tin'],\r\n  },\r\n  {\r\n    title: 'KГҹв•—в•Ј nв”ҖГўng thГҹв•—ГҜnh hв”ңГЎnh',\r\n    items: ['Python','Trв”ңВЎ tuГҹв•—Г§ nhв”ңГіn tГҹв•‘Гӯo','Excel','HГҹв•—Г¬c mв”ңГӯy','SQL','QuГҹв•‘Гәn lв”ңВў dГҹв•—в–’ в”ңГӯn','Power BI','TiГҹв•‘в”җp thГҹв•—ГҜ'],\r\n  },\r\n];\r\n\r\nfunction MegaMenu({ onClose }) {\r\n  return (\r\n    <div className=\"mega-menu\" onMouseLeave={onClose}>\r\n      <div className=\"mega-menu-inner\">\r\n        {EXPLORE_COLS.map(col => (\r\n          <div key={col.title} className=\"mega-col\">\r\n            <h4 className=\"mega-col-title\">{col.title}</h4>\r\n            <ul>\r\n              {col.items.map(item => (\r\n                <li key={item}>\r\n                  <Link to={`/?q=${encodeURIComponent(item)}`} className=\"mega-item\" onClick={onClose}>\r\n                    {item}\r\n                  </Link>\r\n                </li>\r\n              ))}\r\n            </ul>\r\n            <Link to=\"/\" className=\"mega-see-all\" onClick={onClose}>Xem tГҹв•‘Г‘t cГҹв•‘Гә</Link>\r\n          </div>\r\n        ))}\r\n      </div>\r\n      <div className=\"mega-footer\">\r\n        <span>Khв”ңв”Өng chГҹв•‘В»c bГҹв•‘В»t в”ҖГҰГҹв•‘Вәu tГҹв•—ВҪ в”ҖГҰв”ңГіu?</span>\r\n        <a href=\"#\">DuyГҹв•—Г§t cв”ңГӯc khв”ңв”Ӯa hГҹв•—Г¬c miГҹв•—Г n phв”ңВЎ</a>\r\n        <span>hoГҹв•‘ГҖc</span>\r\n        <a href=\"#\" className=\"mega-plus-link\">Tв”ңВјm hiГҹв•—Гўu thв”ңВ¬m vГҹв•—Гј EduVNU <span className=\"plus-badge\">PLUS</span></a>\r\n      </div>\r\n    </div>\r\n  );\r\n}\r\n\r\nfunction Header() {\r\n  const [showUserMenu, setShowUserMenu] = useState(false);\r\n  const [showMega, setShowMega] = useState(false);\r\n  const [cartCount, setCartCount] = useState(0);\r\n  const { user, logout } = useAuth();\r\n  const navigate = useNavigate();\r\n  const userMenuRef = useRef(null);\r\n  const megaRef = useRef(null);\r\n\r\n  const [notifications, setNotifications] = useState([]);\r\n  const [showNotifs, setShowNotifs] = useState(false);\r\n  const notifRef = useRef(null);\r\n\r\n  useEffect(() => {\r\n    if (user) {\r\n      api.get('/cart/my_cart/').then(r => setCartCount(r.data.items?.length || 0)).catch(() => {});\r\n      api.get('/courses/notifications/').then(r => setNotifications(r.data.results || r.data)).catch(() => {});\r\n    } else { setCartCount(0); }\r\n  }, [user]);\r\n\r\n  useEffect(() => {\r\n    const h = (e) => {\r\n      if (userMenuRef.current && !userMenuRef.current.contains(e.target)) setShowUserMenu(false);\r\n    };\r\n    document.addEventListener('mousedown', h);\r\n    return () => document.removeEventListener('mousedown', h);\r\n  }, []);\r\n\r\n  const unreadCount = notifications.filter(n => !n.is_read).length;\r\n\r\n  const markRead = async (id) => {\r\n    try {\r\n      await api.post(`/courses/notifications/${id}/mark_as_read/`);\r\n      setNotifications(prev => prev.map(n => n.id === id ? {...n, is_read: true} : n));\r\n    } catch (e) {}\r\n  };\r\n\r\n  return (\r\n    <header className=\"crs-header\">\r\n      <div className=\"crs-header-inner\">\r\n        {/* LEFT ... */}\r\n        <div className=\"crs-nav-left\">\r\n          <Link to=\"/\" className=\"crs-logo\" style={{display: 'flex', alignItems: 'center', marginLeft: '30px', marginRight: '30px'}}>\r\n            <img src=\"/course_images/eduvn.png\" alt=\"EduVNU Logo\" style={{height: '90px', objectFit: 'contain', transform: 'scale(2.8)'}} />\r\n          </Link>\r\n          <div className=\"mega-trigger\" ref={megaRef} onMouseEnter={() => setShowMega(true)}>\r\n            <button className=\"crs-explore-btn\">Khв”ңГӯm phв”ңГӯ Г”Г»ВҘ</button>\r\n            {showMega && <MegaMenu onClose={() => setShowMega(false)} />}\r\n          </div>\r\n          {user && <Link to=\"/schedule\" className=\"crs-nav-link\">ViГҹв•—Г§c hГҹв•—Г¬c cГҹв•—Вәa tв”ңв”Өi</Link>}\r\n          <Link to=\"/degrees\" className=\"crs-nav-link\">Trв”ңВјnh в”ҖГҰГҹв•—Г–</Link>\r\n          <div className=\"crs-search\">\r\n            <span className=\"crs-search-icon\">ВӯЖ’Г¶Г¬</span>\r\n            <input type=\"text\" placeholder=\"BГҹв•‘Гӯn muГҹв•—ГҰn hГҹв•—Г¬c gв”ңВј?\" onKeyDown={e => { if (e.key === 'Enter' && e.target.value.trim()) { navigate(`/?q=${encodeURIComponent(e.target.value.trim())}`); e.target.value = ''; } }} />\r\n          </div>\r\n        </div>\r\n\r\n        <nav className=\"crs-nav-right\" aria-label=\"в”ҖГүiГҹв•—Гјu hГЈв–‘Гҹв•—Гёng phГҹв•—Г‘\">\r\n          {user && (\r\n            <div className=\"notif-bell-container\" ref={notifRef} style={{position: 'relative', marginRight: '15px'}}>\r\n              <button onClick={() => setShowNotifs(!showNotifs)} style={{background: 'none', border: 'none', cursor: 'pointer', position: 'relative', color: '#64748b'}}>\r\n                <svg width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" strokeWidth=\"2\"><path d=\"M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9\"/><path d=\"M13.73 21a2 2 0 0 1-3.46 0\"/></svg>\r\n                {unreadCount > 0 && <span style={{position:'absolute', top:0, right:0, background:'#ef4444', border:'2px solid white', width:12, height:12, borderRadius:'50%'}}></span>}\r\n              </button>\r\n              {showNotifs && (\r\n                <div style={{position:'absolute', top:'100%', right:0, width:320, background:'white', boxShadow:'0 10px 15px -3px rgba(0,0,0,0.1)', borderRadius:'12px', zIndex:2000, marginTop:10, maxHeight:400, overflowY:'auto'}}>\r\n                  <div style={{padding:'15px', borderBottom:'1px solid #f1f5f9', fontWeight:700}}>Thв”ңв”Өng bв”ңГӯo</div>\r\n                  {notifications.length === 0 ? (\r\n                    <div style={{padding:'20px', textAlign:'center', color:'#94a3b8'}}>Khв”ңв”Өng cв”ңв”Ӯ thв”ңв”Өng bв”ңГӯo nв”ңГЎo.</div>\r\n                  ) : (\r\n                    notifications.map(n => (\r\n                      <div key={n.id} onClick={() => { markRead(n.id); if(n.link) navigate(n.link); setShowNotifs(false); }} style={{padding:'15px', borderBottom:'1px solid #f1f5f9', cursor:'pointer', background: n.is_read ? 'transparent' : '#f0f9ff'}}>\r\n                        <div style={{fontSize:'0.9rem', fontWeight: n.is_read ? 400 : 700}}>{n.title}</div>\r\n                        <div style={{fontSize:'0.8rem', color:'#64748b', marginTop:4}}>{n.message}</div>\r\n                        <div style={{fontSize:'0.7rem', color:'#94a3b8', marginTop:8}}>{new Date(n.created_at).toLocaleString()}</div>\r\n                      </div>\r\n                    ))\r\n                  )}\r\n                </div>\r\n              )}\r\n            </div>\r\n          )}\r\n          <Link to=\"/cart\" className=\"crs-cart-icon-btn\" title=\"GiГҹв•—Г… hв”ңГЎng\" style={{position:'relative'}}>\r\n            <svg width=\"22\" height=\"22\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" strokeWidth=\"2\"><circle cx=\"9\" cy=\"21\" r=\"1\"/><circle cx=\"20\" cy=\"21\" r=\"1\"/><path d=\"M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6\"/></svg>\r\n            {cartCount > 0 && <span className=\"cart-badge\">{cartCount}</span>}\r\n          </Link>\r\n          {user ? (\r\n            <div className=\"crs-user-menu\" ref={userMenuRef}>\r\n              <button className=\"crs-avatar-btn\" onClick={() => setShowUserMenu(v => !v)}><span className=\"crs-avatar\">{user.username[0].toUpperCase()}</span></button>\r\n              {showUserMenu && (\r\n                <div className=\"crs-dropdown\">\r\n                  <div className=\"crs-dropdown-header\"><span className=\"crs-avatar lg\">{user.username[0].toUpperCase()}</span><div><p className=\"crs-dd-name\">{user.first_name ? `${user.first_name} ${user.last_name}` : user.username}</p><p className=\"crs-dd-email\">{user.email}</p></div></div>\r\n                  <div className=\"crs-dropdown-divider\" /><Link to=\"/profile\" className=\"crs-dd-item\" onClick={() => setShowUserMenu(false)}>HГҹв•—Гҙ sГЈГӯ</Link>\r\n                  {user.is_instructor && <Link to=\"/instructor\" className=\"crs-dd-item\" style={{color: '#0056d2', fontWeight: 'bold'}} onClick={() => setShowUserMenu(false)}>Dashboard GiГҹв•‘Гәng viв”ңВ¬n</Link>}\r\n                  {user.is_staff && <Link to=\"/admin\" className=\"crs-dd-item\" style={{color: '#dc2626', fontWeight: 'bold'}} onClick={() => setShowUserMenu(false)}>Admin Monitoring</Link>}\r\n                  <Link to=\"/orders\" className=\"crs-dd-item\" onClick={() => setShowUserMenu(false)}>Mua hв”ңГЎng</Link>\r\n                  <button className=\"crs-dd-item logout\" onClick={() => { logout(); setShowUserMenu(false); navigate('/'); }}>в”ҖГүв”ҖГўng xuГҹв•‘Г‘t</button>\r\n                </div>\r\n              )}\r\n            </div>\r\n          ) : (\r\n            <>\r\n              <Link to=\"/login\" className=\"crs-btn-outline\">в”ҖГүв”ҖГўng nhГҹв•‘ВЎp</Link>\r\n              <Link to=\"/login\" className=\"crs-btn-solid\">Tham gia miГҹв•—Г n phв”ңВЎ</Link>\r\n            </>\r\n          )}\r\n        </nav>\r\n      </div>\r\n    </header>\r\n  );\r\n}\r\n\r\nimport { useLocation } from 'react-router-dom';\r\n\r\nfunction AppLayout() {\r\n  const location = useLocation();\r\n  const isInstructorPage = location.pathname.startsWith('/instructor');\r\n  const isAdminPage = location.pathname.startsWith('/admin');\r\n  const isSpecialPage = isInstructorPage || isAdminPage;\r\n\r\n  return (\r\n    <div className=\"crs-app\">\r\n      {!isSpecialPage && <Header />}\r\n      <main className={isSpecialPage ? \"\" : \"crs-main\"}>\r\n        <Routes>\r\n          <Route path=\"/\" element={<Home />} />\r\n          <Route path=\"/login\" element={<Auth />} />\r\n          <Route path=\"/profile\" element={<Profile />} />\r\n          <Route path=\"/cart\" element={<Cart />} />\r\n          <Route path=\"/learn/:courseId\" element={<Learn />} />\r\n          <Route path=\"/course/:courseId\" element={<CourseDetail />} />\r\n          <Route path=\"/schedule\" element={<Schedule />} />\r\n          <Route path=\"/documents\" element={<Documents />} />\r\n          <Route path=\"/checkout\" element={<Checkout />} />\r\n          <Route path=\"/payment-return\" element={<PaymentReturn />} />\r\n          <Route path=\"/orders\" element={<Orders />} />\r\n          <Route path=\"/degrees\" element={<Degrees />} />\r\n          <Route path=\"/contact\" element={<Contact />} />\r\n          <Route path=\"/mock-vnpay\" element={<MockVNPay />} />\r\n          <Route path=\"/mock-momo\" element={<MockMoMo />} />\r\n          <Route path=\"/sepay-checkout\" element={<SePayCheckout />} />\r\n          <Route path=\"/stripe-checkout\" element={<StripeCheckout />} />\r\n          <Route path=\"/instructor/login\" element={<InstructorLogin />} />\r\n          <Route path=\"/instructor\" element={<InstructorDashboard />} />\r\n          <Route path=\"/instructor/courses\" element={<InstructorCourseList />} /> \r\n          <Route path=\"/instructor/students\" element={<InstructorStudents />} />\r\n          <Route path=\"/instructor/reviews\" element={<InstructorReviews />} />\r\n          <Route path=\"/instructor/finance\" element={<InstructorFinance />} />\r\n          <Route path=\"/instructor/analytics\" element={<InstructorAnalytics />} />\r\n          <Route path=\"/instructor/settings\" element={<InstructorSettings />} />\r\n          <Route path=\"/instructor/help\" element={<InstructorHelp />} />\r\n          <Route path=\"/instructor/create-course\" element={<InstructorCreateCourse />} />\r\n          <Route path=\"/instructor/course/:courseId/curriculum\" element={<InstructorCourseCurriculum />} />\r\n          <Route path=\"/admin\" element={<AdminDashboard />} />\r\n          <Route path=\"*\" element={<NotFound />} />\r\n        </Routes>\r\n      </main>\r\n      {!isSpecialPage && (\r\n        <footer className=\"crs-footer\">\r\n          <div className=\"crs-footer-inner\">\r\n            <div className=\"crs-footer-brand\">\r\n              <span className=\"crs-logo white\" style={{display: 'inline-flex', alignItems: 'center', marginLeft: '50px', marginBottom: '20px'}}>\r\n                <img src=\"/course_images/eduvn.png\" alt=\"EduVNU Logo\" style={{height: '120px', objectFit: 'contain', transform: 'scale(3.6)'}} />\r\n              </span>\r\n              <p>NГҹв•—Гјn tГҹв•‘Гәng hГҹв•—Г¬c trГҹв•—в–’c tuyГҹв•‘в”җn hв”ңГЎng в”ҖГҰГҹв•‘Вәu ViГҹв•—Г§t Nam</p>\r\n              <div className=\"crs-footer-socials\">\r\n                <span className=\"social-icon facebook\">f</span>\r\n                <span className=\"social-icon youtube\">Г”Г»ГӮ</span>\r\n                <span className=\"social-icon twitter\">ВӯГҳГІГ…</span>\r\n                <span className=\"social-icon instagram\">ВӯЖ’ГҙГҖ</span>\r\n              </div>\r\n            </div>\r\n            <div className=\"crs-footer-col\">\r\n              <h4>HГҹв•—Г¬c viв”ңВ¬n</h4>\r\n              <Link to=\"/schedule\">ViГҹв•—Г§c hГҹв•—Г¬c cГҹв•—Вәa tв”ңв”Өi</Link>\r\n              <Link to=\"/documents\">Tв”ңГЎi liГҹв•—Г§u</Link>\r\n              <Link to=\"/orders\">LГҹв•—ГҜch sГҹв•—ВЎ giao dГҹв•—ГҜch</Link>\r\n              <Link to=\"/cart\">GiГҹв•—Г… hв”ңГЎng</Link>\r\n            </div>\r\n            <div className=\"crs-footer-col\">\r\n              <h4>Chв”ҖГўm sв”ңв”Ӯc khв”ңГӯch hв”ңГЎng</h4>\r\n              <a href=\"#\">HГЈв–‘Гҹв•—Гёng dГҹв•‘ВҪn thanh toв”ңГӯn</a>\r\n              <a href=\"#\">Chв”ңВЎnh sв”ңГӯch hoв”ңГЎn trГҹв•‘Гә</a>\r\n              <a href=\"#\">Chв”ңВЎnh sв”ңГӯch bГҹв•‘Гәo mГҹв•‘ВЎt</a>\r\n              <a href=\"#\">в”ҖГүiГҹв•—Гјu khoГҹв•‘Гәn sГҹв•—ВЎ dГҹв•—Г‘ng</a>\r\n            </div>\r\n            <div className=\"crs-footer-col\">\r\n              <h4>VГҹв•—Гј chв”ңв•‘ng tв”ңв”Өi</h4>\r\n              <a href=\"#\">GiГҹв•—Гёi thiГҹв•—Г§u</a>\r\n              <a href=\"#\">TuyГҹв•—Гўn dГҹв•—Г‘ng</a>\r\n              <a href=\"#\">TrГҹв•—Гә giв”ңв•‘p</a>\r\n              <Link to=\"/contact\">Liв”ңВ¬n hГҹв•—Г§</Link>\r\n            </div>\r\n          </div>\r\n          <div className=\"crs-footer-bottom\">\r\n            <span>в”¬В® 2026 EduVNU. All rights reserved.</span>\r\n          </div>\r\n        </footer>\r\n      )}\r\n    </div>\r\n  );\r\n}\r\n\r\nexport default function App() {\r\n  return (\r\n    <BrowserRouter>\r\n      <AuthProvider>\r\n        <AppLayout />\r\n      </AuthProvider>\r\n    </BrowserRouter>\r\n  );\r\n}\r\n","usedDeprecatedRules":[]},{"filePath":"D:\\ThГЈв–‘ГЈГӯng mГҹв•‘Гӯi в”ҖГҰiГҹв•—Г§n tГҹв•—ВЎ\\frontend\\src\\api\\axios.js","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"D:\\ThГЈв–‘ГЈГӯng mГҹв•‘Гӯi в”ҖГҰiГҹв•—Г§n tГҹв•—ВЎ\\frontend\\src\\components\\InstructorSidebar.jsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"D:\\ThГЈв–‘ГЈГӯng mГҹв•‘Гӯi в”ҖГҰiГҹв•—Г§n tГҹв•—ВЎ\\frontend\\src\\components\\LoadingUI.jsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"D:\\ThГЈв–‘ГЈГӯng mГҹв•‘Гӯi в”ҖГҰiГҹв•—Г§n tГҹв•—ВЎ\\frontend\\src\\context\\AuthContext.jsx","messages":[{"ruleId":"react-hooks/set-state-in-effect","severity":2,"message":"Error: Calling setState synchronously within an effect can trigger cascading renders\n\nEffects are intended to synchronize state between React and external systems such as manually updating the DOM, state management libraries, or other platform APIs. In general, the body of an effect should do one or both of the following:\n* Update external systems with the latest state from React.\n* Subscribe for updates from some external system, calling setState in a callback function when external state changes.\n\nCalling setState synchronously within an effect body causes cascading renders that can hurt performance, and is not recommended. (https://react.dev/learn/you-might-not-need-an-effect).\n\n  20 |         .finally(() => setLoading(false));\n  21 |     } else {\n> 22 |       setLoading(false);\n     |       ^^^^^^^^^^ Avoid calling setState() directly within an effect\n  23 |     }\n  24 |   }, []);\n  25 |","line":22,"column":7,"nodeType":null,"endLine":22,"endColumn":17},{"ruleId":"react-refresh/only-export-components","severity":2,"message":"Fast refresh only works when a file only exports components. Use a new file to share constants or functions between components.","line":55,"column":14,"nodeType":"Identifier","messageId":"namedExport","endLine":55,"endColumn":21}],"suppressedMessages":[],"errorCount":2,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"source":"import { createContext, useContext, useState, useEffect } from 'react';\r\nimport api from '../api/axios';\r\n\r\nconst AuthContext = createContext(null);\r\n\r\nexport function AuthProvider({ children }) {\r\n  const [user, setUser] = useState(null);\r\n  const [loading, setLoading] = useState(true);\r\n\r\n  // Khi app khГҹв•—Ж’i в”ҖГҰГҹв•—Г–ng, kiГҹв•—Гўm tra token cв”ңв–“n hГҹв•—Гәp lГҹв•—Г§ khв”ңв”Өng\r\n  useEffect(() => {\r\n    const token = localStorage.getItem('access_token');\r\n    if (token) {\r\n      api.get('/accounts/users/me/')\r\n        .then(res => setUser(res.data))\r\n        .catch(() => {\r\n          localStorage.removeItem('access_token');\r\n          localStorage.removeItem('refresh_token');\r\n        })\r\n        .finally(() => setLoading(false));\r\n    } else {\r\n      setLoading(false);\r\n    }\r\n  }, []);\r\n\r\n  const login = async (username, password) => {\r\n    const res = await api.post('/accounts/login/', { username, password });\r\n    localStorage.setItem('access_token', res.data.access);\r\n    localStorage.setItem('refresh_token', res.data.refresh);\r\n    setUser(res.data.user);\r\n    return res.data;\r\n  };\r\n\r\n  const register = async (username, email, password, password2) => {\r\n    const res = await api.post('/accounts/register/', { username, email, password, password2 });\r\n    localStorage.setItem('access_token', res.data.access);\r\n    localStorage.setItem('refresh_token', res.data.refresh);\r\n    setUser(res.data.user);\r\n    return res.data;\r\n  };\r\n\r\n  const logout = () => {\r\n    localStorage.removeItem('access_token');\r\n    localStorage.removeItem('refresh_token');\r\n    setUser(null);\r\n  };\r\n\r\n  return (\r\n    <AuthContext.Provider value={{ user, loading, login, register, logout }}>\r\n      {children}\r\n    </AuthContext.Provider>\r\n  );\r\n}\r\n\r\nexport const useAuth = () => useContext(AuthContext);\r\n","usedDeprecatedRules":[]},{"filePath":"D:\\ThГЈв–‘ГЈГӯng mГҹв•‘Гӯi в”ҖГҰiГҹв•—Г§n tГҹв•—ВЎ\\frontend\\src\\hooks\\usePageSEO.js","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"D:\\ThГЈв–‘ГЈГӯng mГҹв•‘Гӯi в”ҖГҰiГҹв•—Г§n tГҹв•—ВЎ\\frontend\\src\\main.jsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"D:\\ThГЈв–‘ГЈГӯng mГҹв•‘Гӯi в”ҖГҰiГҹв•—Г§n tГҹв•—ВЎ\\frontend\\src\\pages\\Accomplishments.jsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"D:\\ThГЈв–‘ГЈГӯng mГҹв•‘Гӯi в”ҖГҰiГҹв•—Г§n tГҹв•—ВЎ\\frontend\\src\\pages\\AdminDashboard.jsx","messages":[{"ruleId":"react-hooks/immutability","severity":2,"message":"Error: Cannot access variable before it is declared\n\n`fetchData` is accessed before it is declared, which prevents the earlier access from updating when this value changes over time.\n\n  14 |\n  15 |     useEffect(() => {\n> 16 |         fetchData();\n     |         ^^^^^^^^^ `fetchData` accessed before it is declared\n  17 |     }, []);\n  18 |\n  19 |     const fetchData = async () => {\n\n  17 |     }, []);\n  18 |\n> 19 |     const fetchData = async () => {\n     |     ^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^\n> 20 |         try {\n     | ^^^^^^^^^^^^^\n> 21 |             setLoading(true);\n     Г”ГҮВӘ\n     | ^^^^^^^^^^^^^\n> 38 |         }\n     | ^^^^^^^^^^^^^\n> 39 |     };\n     | ^^^^^^^ `fetchData` is declared here\n  40 |\n  41 |     const handleApprove = async (id) => {\n  42 |         try {","line":16,"column":9,"nodeType":null,"endLine":16,"endColumn":18},{"ruleId":"no-unused-vars","severity":2,"message":"'error' is defined but never used.","line":46,"column":18,"nodeType":"Identifier","messageId":"unusedVar","endLine":46,"endColumn":23},{"ruleId":"no-unused-vars","severity":2,"message":"'error' is defined but never used.","line":57,"column":18,"nodeType":"Identifier","messageId":"unusedVar","endLine":57,"endColumn":23}],"suppressedMessages":[],"errorCount":3,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"source":"import React, { useState, useEffect } from 'react';\r\nimport api from '../api/axios';\r\nimport { Link, useNavigate } from 'react-router-dom';\r\n\r\nconst AdminDashboard = () => {\r\n    const [courses, setCourses] = useState([]);\r\n    const [stats, setStats] = useState({ pending: 0, published: 0, users: 0, revenue: 0 });\r\n    const [loading, setLoading] = useState(true);\r\n    const [activeTab, setActiveTab] = useState('pending');\r\n    const [showRejectModal, setShowRejectModal] = useState(false);\r\n    const [selectedCourse, setSelectedCourse] = useState(null);\r\n    const [rejectionReason, setRejectionReason] = useState('');\r\n    const navigate = useNavigate();\r\n\r\n    useEffect(() => {\r\n        fetchData();\r\n    }, []);\r\n\r\n    const fetchData = async () => {\r\n        try {\r\n            setLoading(true);\r\n            // LГҹв•‘Г‘y tГҹв•‘Г‘t cГҹв•‘Гә khв”ңв”Ӯa hГҹв•—Г¬c в”ҖГҰГҹв•—Гў phв”ңГіn loГҹв•‘Гӯi theo tab\r\n            const res = await api.get('/courses/admin-courses/');\r\n            const allCourses = res.data.results || res.data;\r\n            setCourses(allCourses);\r\n            \r\n            // Tв”ңВЎnh toв”ңГӯn stats sГЈГӯ bГҹв•—Г– (Trong thГҹв•—в–’c tГҹв•‘в”җ nв”ңВ¬n cв”ңв”Ӯ 1 API stats riв”ңВ¬ng)\r\n            setStats({\r\n                pending: allCourses.filter(c => c.status === 'pending').length,\r\n                published: allCourses.filter(c => c.status === 'published').length,\r\n                users: 1250, // Mock\r\n                revenue: 45800000 // Mock\r\n            });\r\n            setLoading(false);\r\n        } catch (error) {\r\n            console.error(\"Error fetching data:\", error);\r\n            setLoading(false);\r\n        }\r\n    };\r\n\r\n    const handleApprove = async (id) => {\r\n        try {\r\n            await api.post(`/courses/admin-courses/${id}/approve/`);\r\n            alert('Г”ВЈГ  Phв”ңВ¬ duyГҹв•—Г§t thв”ңГЎnh cв”ңв”Өng!');\r\n            fetchData();\r\n        } catch (error) { alert('LГҹв•—Г№i phв”ңВ¬ duyГҹв•—Г§t.'); }\r\n    };\r\n\r\n    const handleRejectSubmit = async (e) => {\r\n        e.preventDefault();\r\n        try {\r\n            await api.post(`/courses/admin-courses/${selectedCourse.id}/reject/`, { reason: rejectionReason });\r\n            alert('Г”ГҳГ® в”ҖГүв”ңГә tГҹв•—ВҪ chГҹв•—ГҰi khв”ңв”Ӯa hГҹв•—Г¬c.');\r\n            setShowRejectModal(false);\r\n            setRejectionReason('');\r\n            fetchData();\r\n        } catch (error) { alert('LГҹв•—Г№i thГҹв•—в–’c thi.'); }\r\n    };\r\n\r\n    const filteredCourses = courses.filter(c => {\r\n        if (activeTab === 'all') return true;\r\n        return c.status === activeTab;\r\n    });\r\n\r\n    return (\r\n        <div style={{ display: 'flex', minHeight: '100vh', background: '#0f172a', color: '#f8fafc', fontFamily: \"'Inter', sans-serif\" }}>\r\n            \r\n            {/* SIDEBAR ADMIN (GIAO DIГҹв•—ГҘN PREMIUM DARK) */}\r\n            <aside style={{ width: '280px', background: '#1e293b', borderRight: '1px solid #334155', padding: '30px', display: 'flex', flexDirection: 'column' }}>\r\n                <div style={{ marginBottom: '50px', textAlign: 'center' }}>\r\n                    <img src=\"/course_images/eduvn.png\" alt=\"Logo\" style={{ height: '60px', filter: 'brightness(0) invert(1)', transform: 'scale(1.5)' }} />\r\n                    <div style={{ marginTop: '20px', fontSize: '0.75rem', color: '#94a3b8', letterSpacing: '2px', fontWeight: 800 }}>ADMIN CONTROL</div>\r\n                </div>\r\n\r\n                <nav style={{ flex: 1, display: 'flex', flexDirection: 'column', gap: '10px' }}>\r\n                    <div style={{ padding: '12px 20px', borderRadius: '12px', background: '#334155', cursor: 'pointer', fontWeight: 600 }}>Dashboard</div>\r\n                    <div style={{ padding: '12px 20px', borderRadius: '12px', color: '#94a3b8', cursor: 'not-allowed' }}>QuГҹв•‘Гәn lв”ңВў ngГЈв–‘Гҹв•—Гҳi dв”ңв•Јng</div>\r\n                    <div style={{ padding: '12px 20px', borderRadius: '12px', color: '#94a3b8', cursor: 'not-allowed' }}>Giao dГҹв•—ГҜch tв”ңГЎi chв”ңВЎnh</div>\r\n                    <div style={{ padding: '12px 20px', borderRadius: '12px', color: '#94a3b8', cursor: 'not-allowed' }}>Cв”ңГЎi в”ҖГҰГҹв•‘ГҖt hГҹв•—Г§ thГҹв•—ГҰng</div>\r\n                </nav>\r\n\r\n                <button onClick={() => navigate('/')} style={{ marginTop: 'auto', padding: '12px', background: 'rgba(239, 68, 68, 0.1)', color: '#ef4444', border: 'none', borderRadius: '10px', cursor: 'pointer', fontWeight: 700 }}>\r\n                   Г”ГҘГү Thoв”ңГӯt Admin\r\n                </button>\r\n            </aside>\r\n\r\n            {/* MAIN CONTENT */}\r\n            <main style={{ flex: 1, padding: '40px', overflowY: 'auto' }}>\r\n                <header style={{ display: 'flex', justifyContent: 'space-between', alignItems: 'center', marginBottom: '40px' }}>\r\n                    <div>\r\n                        <h1 style={{ fontSize: '2rem', margin: 0 }}>Giв”ңГӯm sв”ңГӯt HГҹв•—Г§ thГҹв•—ГҰng</h1>\r\n                        <p style={{ color: '#94a3b8', marginTop: '5px' }}>DГҹв•—В» liГҹв•—Г§u thГҹв•—Гҳi gian thГҹв•—в–’c в”ҖГҰГЈв–‘Гҹв•—Гәc cГҹв•‘ВЎp nhГҹв•‘ВЎt tГҹв•—ВҪ SSMS.</p>\r\n                    </div>\r\n                    <div style={{ display: 'flex', gap: '15px' }}>\r\n                        <div style={{ textAlign: 'right' }}>\r\n                            <div style={{ fontSize: '0.85rem', color: '#94a3b8' }}>Phiв”ңВ¬n в”ҖГҰв”ҖГўng nhГҹв•‘ВЎp</div>\r\n                            <div style={{ fontWeight: 700 }}>Root Admin VNU</div>\r\n                        </div>\r\n                        <div style={{ width: '45px', height: '45px', borderRadius: '50%', background: 'linear-gradient(135deg, #3b82f6, #06b6d4)', display: 'flex', alignItems: 'center', justifyContent: 'center', fontSize: '1.2rem' }}>ВӯЖ’ГҶГ„</div>\r\n                    </div>\r\n                </header>\r\n\r\n                {/* STATS ROW */}\r\n                <div style={{ display: 'grid', gridTemplateColumns: '1fr 1fr 1fr 1fr', gap: '25px', marginBottom: '40px' }}>\r\n                    {[\r\n                        { label: 'ChГҹв•—Гҳ phв”ңВ¬ duyГҹв•—Г§t', value: stats.pending, color: '#f59e0b', icon: 'ВӯЖ’ГІГҶ' },\r\n                        { label: 'в”ҖГүang hoГҹв•‘Гӯt в”ҖГҰГҹв•—Г–ng', value: stats.published, color: '#10b981', icon: 'ВӯЖ’ГңГҮ' },\r\n                        { label: 'HГҹв•—Г¬c viв”ңВ¬n VNU', value: stats.users, color: '#3b82f6', icon: 'ВӯЖ’ГҰГ‘' },\r\n                        { label: 'Doanh thu EduHub', value: `${(stats.revenue / 1000000).toFixed(1)}M`, color: '#ec4899', icon: 'ВӯЖ’ГҶв–‘' }\r\n                    ].map((s, i) => (\r\n                        <div key={i} style={{ padding: '25px', background: '#1e293b', borderRadius: '20px', border: '1px solid #334155', position: 'relative', overflow: 'hidden' }}>\r\n                            <div style={{ position: 'absolute', top: '-10px', right: '-10px', fontSize: '4rem', opacity: 0.1 }}>{s.icon}</div>\r\n                            <div style={{ color: '#94a3b8', fontSize: '0.9rem', fontWeight: 600 }}>{s.label}</div>\r\n                            <div style={{ fontSize: '1.8rem', fontWeight: 800, color: s.color, marginTop: '10px' }}>{s.value}</div>\r\n                        </div>\r\n                    ))}\r\n                </div>\r\n\r\n                {/* TABS & FILTER */}\r\n                <div style={{ display: 'flex', gap: '30px', borderBottom: '1px solid #334155', marginBottom: '30px' }}>\r\n                    {[\r\n                        { id: 'pending', label: 'Hв”ңГЎng chГҹв•—Гҳ duyГҹв•—Г§t' },\r\n                        { id: 'published', label: 'в”ҖГүв”ңГә xuГҹв•‘Г‘t bГҹв•‘Гәn' },\r\n                        { id: 'rejected', label: 'в”ҖГүв”ңГә tГҹв•—ВҪ chГҹв•—ГҰi' },\r\n                        { id: 'all', label: 'TГҹв•‘Г‘t cГҹв•‘Гә' }\r\n                    ].map(tab => (\r\n                        <div key={tab.id} onClick={() => setActiveTab(tab.id)} style={{\r\n                            padding: '15px 5px', cursor: 'pointer', fontWeight: 700,\r\n                            color: activeTab === tab.id ? '#3b82f6' : '#64748b',\r\n                            borderBottom: activeTab === tab.id ? '3px solid #3b82f6' : '3px solid transparent',\r\n                            transition: 'all 0.3s'\r\n                        }}>{tab.label}</div>\r\n                    ))}\r\n                </div>\r\n\r\n                {/* LIST CONTENT */}\r\n                <div style={{ display: 'flex', flexDirection: 'column', gap: '15px' }}>\r\n                    {loading ? (\r\n                        <p>Loading...</p>\r\n                    ) : filteredCourses.length === 0 ? (\r\n                        <div style={{ textAlign: 'center', padding: '100px', color: '#475569' }}>\r\n                            <div style={{ fontSize: '4rem' }}>ВӯЖ’Г…Г»ВҙВ©Г…</div>\r\n                            <p>MГҹв•—Г‘c nв”ңГЎy hiГҹв•—Г§n в”ҖГҰang trГҹв•—ГҰng.</p>\r\n                        </div>\r\n                    ) : (\r\n                        filteredCourses.map(course => (\r\n                            <div key={course.id} style={{\r\n                                padding: '20px', background: '#1e293b', border: '1px solid #334155', borderRadius: '16px',\r\n                                display: 'flex', alignItems: 'center', gap: '20px', transition: 'transform 0.2s',\r\n                                cursor: 'default'\r\n                            }} onMouseEnter={(e) => e.currentTarget.style.transform = 'scale(1.01)'}\r\n                               onMouseLeave={(e) => e.currentTarget.style.transform = 'scale(1)'}>\r\n                                \r\n                                <div style={{ position: 'relative' }}>\r\n                                    <img src={course.image || 'https://via.placeholder.com/150'} alt=\"\" style={{ width: '140px', height: '90px', borderRadius: '12px', objectFit: 'cover' }} />\r\n                                    <div style={{ position: 'absolute', top: '-8px', right: '-8px', background: course.status === 'published' ? '#10b981' : '#f59e0b', width: 24, height: 24, borderRadius: '50%', border: '3px solid #1e293b' }}></div>\r\n                                </div>\r\n\r\n                                <div style={{ flex: 1 }}>\r\n                                    <h3 style={{ margin: '0 0 5px 0', fontSize: '1.2rem' }}>{course.title}</h3>\r\n                                    <div style={{ display: 'flex', gap: '20px', fontSize: '0.85rem', color: '#94a3b8' }}>\r\n                                        <span>ВӯЖ’ГҰГұ {course.instructor_name || 'GiГҹв•‘Гәng viв”ңВ¬n VNU'}</span>\r\n                                        <span>ВӯЖ’Г…ГҖВҙВ©Г… {course.category?.name}</span>\r\n                                        <span>ВӯЖ’ГҶв–‘ {Number(course.price).toLocaleString()}Г”Г©ВҪ</span>\r\n                                    </div>\r\n                                    {course.rejection_reason && course.status === 'rejected' && (\r\n                                        <div style={{ marginTop: '10px', fontSize: '0.8rem', color: '#ef4444', padding: '8px 12px', background: 'rgba(239, 68, 68, 0.1)', borderRadius: '8px' }}>\r\n                                            Lв”ңВў do tГҹв•—ВҪ chГҹв•—ГҰi: {course.rejection_reason}\r\n                                        </div>\r\n                                    )}\r\n                                </div>\r\n\r\n                                <div style={{ display: 'flex', gap: '10px' }}>\r\n                                    <Link to={`/course/${course.id}`} target=\"_blank\" style={{ padding: '12px 20px', borderRadius: '10px', background: 'rgba(59, 130, 246, 0.1)', color: '#3b82f6', textDecoration: 'none', fontWeight: 700, fontSize: '0.9rem' }}>Review</Link>\r\n                                    \r\n                                    {course.status === 'pending' && (\r\n                                        <>\r\n                                            <button onClick={() => { setSelectedCourse(course); setShowRejectModal(true); }} style={{ padding: '12px 20px', borderRadius: '10px', border: '1px solid #ef4444', background: 'none', color: '#ef4444', fontWeight: 700, cursor: 'pointer' }}>TГҹв•—ВҪ chГҹв•—ГҰi</button>\r\n                                            <button onClick={() => handleApprove(course.id)} style={{ padding: '12px 25px', borderRadius: '10px', border: 'none', background: 'linear-gradient(to right, #3b82f6, #2563eb)', color: 'white', fontWeight: 700, cursor: 'pointer', boxShadow: '0 10px 15px -3px rgba(37, 99, 235, 0.3)' }}>DuyГҹв•—Г§t</button>\r\n                                        </>\r\n                                    )}\r\n                                </div>\r\n                            </div>\r\n                        ))\r\n                    )}\r\n                </div>\r\n            </main>\r\n\r\n            {/* MODAL NHГҹв•‘ВјP Lв”ңГҳ DO TГҹв•—В¬ CHГҹв•—ГүI (MODERN STYLE) */}\r\n            {showRejectModal && (\r\n                <div style={{ position: 'fixed', inset: 0, background: 'rgba(0,0,0,0.8)', backdropFilter: 'blur(10px)', display: 'flex', alignItems: 'center', justifyContent: 'center', zIndex: 2000 }}>\r\n                    <div style={{ background: '#1e293b', width: '100%', maxWidth: '500px', borderRadius: '24px', padding: '35px', border: '1px solid #334155' }}>\r\n                        <h2 style={{ fontSize: '1.5rem', marginBottom: '10px' }}>PhГҹв•‘Гәn hГҹв•—Гҙi giГҹв•‘Гәng viв”ңВ¬n</h2>\r\n                        <p style={{ color: '#94a3b8', fontSize: '0.9rem', marginBottom: '20px' }}>TГҹв•—ВҪ chГҹв•—ГҰi khв”ңв”Ӯa hГҹв•—Г¬c: <span style={{ color: '#fff' }}>{selectedCourse?.title}</span></p>\r\n                        \r\n                        <form onSubmit={handleRejectSubmit}>\r\n                            <textarea \r\n                                required rows=\"6\" \r\n                                value={rejectionReason} onChange={(e) => setRejectionReason(e.target.value)}\r\n                                placeholder=\"Hв”ңГәy giГҹв•‘Гәi thв”ңВЎch rв”ңГҒ lв”ңВў do в”ҖГҰГҹв•—Гў giГҹв•‘Гәng viв”ңВ¬n cв”ңв”Ӯ thГҹв•—Гў sГҹв•—ВЎa lГҹв•‘Гӯi...\"\r\n                                style={{ width: '100%', padding: '20px', background: '#0f172a', border: '1px solid #334155', borderRadius: '16px', color: '#fff', outline: 'none', resize: 'none' }}\r\n                            ></textarea>\r\n                            \r\n                            <div style={{ display: 'flex', justifyContent: 'flex-end', gap: '15px', marginTop: '30px' }}>\r\n                                <button type=\"button\" onClick={() => setShowRejectModal(false)} style={{ background: 'none', border: 'none', color: '#64748b', fontWeight: 600, cursor: 'pointer' }}>HГҹв•—Вәy</button>\r\n                                <button type=\"submit\" style={{ padding: '12px 30px', borderRadius: '12px', background: '#ef4444', color: 'white', border: 'none', fontWeight: 700, cursor: 'pointer' }}>TГҹв•—ВҪ chГҹв•—ГҰi khв”ңв”Ӯa hГҹв•—Г¬c</button>\r\n                            </div>\r\n                        </form>\r\n                    </div>\r\n                </div>\r\n            )}\r\n        </div>\r\n    );\r\n};\r\n\r\nexport default AdminDashboard;\r\n","usedDeprecatedRules":[]},{"filePath":"D:\\ThГЈв–‘ГЈГӯng mГҹв•‘Гӯi в”ҖГҰiГҹв•—Г§n tГҹв•—ВЎ\\frontend\\src\\pages\\Auth.jsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatal