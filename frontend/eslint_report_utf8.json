date\">{new Date(order.created_at).toLocaleDateString('vi-VN', {day:'2-digit',month:'2-digit',year:'numeric'})}</span>\r\n                </div>\r\n                <div className=\"crs-order-right\">\r\n                  <span className=\"crs-order-price\">{parseFloat(order.total_price).toLocaleString('vi-VN')} в”ҖГҰ</span>\r\n                  <span className={`crs-status-badge ${order.status}`}>\r\n                    {order.status === 'paid' ? 'Г”ВЈГҙ в”ҖГүв”ңГә thanh toв”ңГӯn' : order.status === 'pending' ? 'ChГҹв•—Гҳ xГҹв•—ВЎ lв”ңВў' : 'в”ҖГүв”ңГә hГҹв•—Вәy'}\r\n                  </span>\r\n                  <span className=\"crs-expand\">{expanded === order.id ? 'Г”Г»в–“' : 'Г”Г»в•қ'}</span>\r\n                </div>\r\n              </div>\r\n              {expanded === order.id && (\r\n                <div className=\"crs-order-detail\">\r\n                  {order.items?.map(item => (\r\n                    <div key={item.id} className=\"crs-order-item\">\r\n                      <div className=\"crs-oi-thumb\" style={{background:'linear-gradient(135deg,#0369a1,#0ea5e9)'}}>\r\n                        {item.course?.title?.[0]}\r\n                      </div>\r\n                      <div className=\"crs-oi-info\">\r\n                        <p className=\"crs-oi-title\">{item.course?.title}</p>\r\n                        <p className=\"crs-oi-org\">{item.course?.instructor?.username}</p>\r\n                      </div>\r\n                      <span className=\"crs-oi-price\">{parseFloat(item.price).toLocaleString('vi-VN')} в”ҖГҰ</span>\r\n                      <button className=\"crs-btn-outline sm\" onClick={() => navigate(`/learn/${item.course?.id}`)}>Vв”ңГЎo hГҹв•—Г¬c</button>\r\n                    </div>\r\n                  ))}\r\n                </div>\r\n              )}\r\n            </div>\r\n          ))}\r\n        </div>\r\n      )}\r\n    </div>\r\n  );\r\n}\r\n","usedDeprecatedRules":[]},{"filePath":"D:\\ThГЈв–‘ГЈГӯng mГҹв•‘Гӯi в”ҖГҰiГҹв•—Г§