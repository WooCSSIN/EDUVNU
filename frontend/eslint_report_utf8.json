bГҹв•‘Гәo mГҹв•‘ВЎt SSL.' });\r\n  const [items, setItems] = useState([]);\r\n  const [orders, setOrders] = useState([]);\r\n  const [loading, setLoading] = useState(true);\r\n  const [removing, setRemoving] = useState(null);\r\n  const [tab, setTab] = useState('cart');\r\n  const [expandedOrder, setExpandedOrder] = useState(null);\r\n  const [coupon, setCoupon] = useState('');\r\n  const [toast, setToast] = useState('');\r\n  const { user, loading: authLoading } = useAuth();\r\n  const navigate = useNavigate();\r\n\r\n  useEffect(() => {\r\n    if (authLoading) return;\r\n    if (!user) { navigate('/login'); return; }\r\n    loadData();\r\n  }, [user, authLoading]);\r\n\r\n  useEffect(() => {\r\n    if (toast) { const t = setTimeout(() => setToast(''), 3000); return () => clearTimeout(t); }\r\n  }, [toast]);\r\n\r\n  const loadData = async () => {\r\n    setLoading(true);\r\n    try {\r\n      const [cartRes, orderRes] = await Promise.all([\r\n        api.get('/cart/my_cart/').catch(() => ({ data: { items: [] } })),\r\n        api.get('/orders/').catch(() => ({ data: [] })),\r\n      ]);\r\n      setItems(cartRes.data.items || []);\r\n      setOrders(orderRes.data.results || orderRes.data || []);\r\n    } catch (err) {\r\n      console.error('Cart load error:', err);\r\n    } finally {\r\n      setLoading(false);\r\n    }\r\n  };\r\n\r\n  const removeItem = async (courseId) => {\r\n    setRemoving(courseId);\r\n    try {\r\n      await api.delete('/cart/remove_item/', { data: { course_id: courseId } });\r\n      setItems(p => p.filter(i => i.course?.id !== courseId));\r\n      setToast('в”ҖГүв”ңГә xв”ңв”Ӯa khГҹв•—Г…i giГҹв•—Г… hв”ңГЎng');\r\n    } catch {\r\n      setToast('Khв”ңв”Өng thГҹв•—Гў xв”ңв”Ӯa sГҹв•‘Гәn phГҹв•‘В®m');\r\n    } finally {\r\n      setRemoving(null);\r\n    }\r\n  };\r\n\r\n  const subtotal = items.reduce((s, i) => s + parseFloat(i.course?.price || 0), 0);\r\n  const discount = 0;\r\n  const total = subtotal - discount;\r\n\r\n  if (loading) return <Loading message=\"в”ҖГүang tГҹв•‘Гәi giГҹв•—Г… hв”ңГЎng...\" />;\r\n\r\n  return (\r\n    <div className=\"crs-cart-page\">\r\n      {/* Breadcrumb */}\r\n      <div className=\"crs-breadcrumb\">\r\n        <Link to=\"/\">Trang chГҹв•—Вә</Link>\r\n        <span>/</span>\r\n        <span>GiГҹв•—Г… hв”ңГЎng</span>\r\n      </div>\r\n\r\n      <h1 className=\"crs-page-header\" style={{fontSize:'28px',fontWeight:800,marginBottom:0}}>GiГҹв•—Г… hв”ңГЎng</h1>\r\n      <p style={{color:'var(--muted)',fontSize:14,marginBottom:28}}>{items.length} khв”ңв”Ӯa hГҹв•—Г¬c trong giГҹв•—Г… hв”ңГЎng</p>\r\n\r\n      {/* Tabs */}\r\n      <div className=\"crs-cart-tabs\">\r\n        <button className={`crs-cart-tab ${tab==='cart'?'active':''}`} onClick={()=>setTab('cart')}>\r\n          ВӯЖ’ГёГҶ GiГҹв•—Г… hв”ңГЎng ({items.length})\r\n        </button>\r\n        <button className={`crs-cart-tab ${tab==='orders'?'active':''}`} onClick={()=>setTab('orders')}>\r\n          ВӯЖ’ГҙВӘ LГҹв•—ГҜch sГҹв•—ВЎ mua hв”ңГЎng ({orders.length})\r\n        </button>\r\n      </div>\r\n\r\n      {/* Г”ГІГүГ”ГІГүГ”ГІГү TAB: GIГҹв•—Г„ Hв”ңГҮNG Г”ГІГүГ”ГІГүГ”ГІГү */}\r\n      {tab === 'cart' && (\r\n        items.length === 0 ? (\r\n          <div className=\"crs-cart-empty\" style={{padding:'80px 20px'}}>\r\n            <div style={{fontSize:72,marginBottom:16}}>ВӯЖ’ГёГҶ</div>\r\n            <h3>GiГҹв•—Г… hв”ңГЎng trГҹв•—ГҰng</h3>\r\n            <p style={{marginBottom:24,color:'var(--muted)'}}>Khв”ңГӯm phв”ңГӯ hв”ңГЎng trв”ҖГўm khв”ңв”Ӯa hГҹв•—Г¬c chГҹв•‘Г‘t lГЈв–‘Гҹв•—Гәng vв”ңГЎ bГҹв•‘В»t в”ҖГҰГҹв•‘Вәu hв”ңГЎnh trв”ңВјnh hГҹв•—Г¬c tГҹв•‘ВЎp cГҹв•—Вәa bГҹв•‘Гӯn.</p>\r\n            <button className=\"crs-btn-solid\" onClick={()=>navigate('/')} style={{padding:'14px 40px',fontSize:16}}>Khв”ңГӯm phв”ңГӯ khв”ңв”Ӯa hГҹв•—Г¬c</button>\r\n          </div>\r\n        ) : (\r\n          <div className=\"crs-cart-layout\">\r\n            {/* LEFT: Cart Items */}\r\n            <div className=\"crs-cart-items\">\r\n              {items.map((item, idx) => (\r\n                <div key={item.id} className=\"crs-cart-item\">\r\n                  <div className=\"crs-cart-thumb\" style={{background: GRADS[idx % GRADS.length]}}>\r\n                    {fixText(item.course?.title)?.[0] || '?'}\r\n                  </div>\r\n                  <div className=\"crs-cart-info\">\r\n                    <div className=\"crs-cart-title\">{fixText(item.course?.title)}</div>\r\n                    <div className=\"crs-cart-org\">{item.course?.partner_name || 'EduVNU Partner'}</div>\r\n                    <div style={{display:'flex',gap:6,marginBottom:4}}>\r\n                      <span className=\"badge\">Bestseller</span>\r\n                      <span style={{fontSize:12,color:'var(--muted)'}}>Г”ВЎГү 4.7 (2,340 в”ҖГҰв”ңГӯnh giв”ңГӯ)</span>\r\n                    </div>\r\n                    <div style={{fontSize:12,color:'var(--muted)'}}>5 bв”ңГЎi giГҹв•‘Гәng Г”ГҮГі TГҹв•‘Г‘t cГҹв•‘Гә trв”ңВјnh в”ҖГҰГҹв•—Г–</div>\r\n                    <div style={{display:'flex', gap:16, marginTop:10}}>\r\n                      <button\r\n                        onClick={() => removeItem(item.course?.id)}\r\n                        className=\"crs-cart-remove\"\r\n                        disabled={removing === item.course?.id}>\r\n                        {removing === item.course?.id ? 'в”ҖГүang xв”ңв”Ӯa...' : 'ВӯЖ’Г№ГҰ Xв”ңв”Ӯa'}\r\n                      </button>\r\n                      <button style={{background:'none',border:'none',color:'var(--blue)',cursor:'pointer',fontSize:13,padding:0}}>\r\n                        ВӯЖ’ГҶВҘ LГЈв–‘u в”ҖГҰГҹв•—Гў sau\r\n                      </button>\r\n                      <button onClick={()=>navigate(`/course/${item.course?.id}`)} style={{background:'none',border:'none',color:'var(--blue)',cursor:'pointer',fontSize:13,padding:0}}>\r\n                        ВӯЖ’ГҰГј Xem chi tiГҹв•‘в”җt\r\n                      </button>\r\n                    </div>\r\n                  </div>\r\n                  <div className=\"crs-cart-price\">\r\n                    {parseFloat(item.course?.price || 0) === 0 ? (\r\n                      <span className=\"free-tag\" style={{fontSize:16,padding:'4px 14px'}}>MiГҹв•—Г n phв”ңВЎ</span>\r\n                    ) : (\r\n                      <>\r\n                        <div>{parseFloat(item.course?.price || 0).toLocaleString('vi-VN')} Г”Г©ВҪ</div>\r\n                        <div style={{fontSize:13,color:'var(--muted)',textDecoration:'line-through'}}>\r\n                          {(parseFloat(item.course?.price || 0) * 1.5).toLocaleString('vi-VN')} Г”Г©ВҪ\r\n                        </div>\r\n                      </>\r\n                    )}\r\n                  </div>\r\n                </div>\r\n              ))}\r\n            </div>\r\n\r\n            {/* RIGHT: Order Summary */}\r\n            <div className=\"crs-cart-sidebar\">\r\n              <div className=\"crs-cart-summary\">\r\n                <h3>Tв”ңв”Ӯm tГҹв•‘В»t в”ҖГҰГЈГӯn hв”ңГЎng</h3>\r\n                <div className=\"crs-summary-row\">\r\n                  <span>TГҹв•‘Гӯm tв”ңВЎnh ({items.length} khв”ңв”Ӯa):</span>\r\n                  <strong>{subtotal.toLocaleString('vi-VN')} Г”Г©ВҪ</strong>\r\n                </div>\r\n                {discount > 0 && (\r\n                  <div className=\"crs-summary-row\" style={{color:'var(--success)'}}>\r\n                    <span>GiГҹв•‘Гәm giв”ңГӯ:</span>\r\n                    <strong>-{discount.toLocaleString('vi-VN')} Г”Г©ВҪ</strong>\r\n                  </div>\r\n                )}\r\n                <div className=\"crs-summary-total\">\r\n                  <span>TГҹв•—ГІng cГҹв•—Г–ng:</span>\r\n                  <span className=\"crs-summary-total-price\">{total.toLocaleString('vi-VN')} Г”Г©ВҪ</span>\r\n                </div>\r\n\r\n                <button className=\"crs-checkout-btn\" onClick={()=>navigate('/checkout')}>\r\n                  Thanh toв”ңГӯn ngay\r\n                </button>\r\n\r\n                {/* Coupon */}\r\n                <div style={{marginTop:16}}>\r\n                  <div style={{fontSize:13,fontWeight:600,marginBottom:8,color:'var(--text)'}}>Mв”ңГә giГҹв•‘Гәm giв”ңГӯ</div>\r\n                  <div style={{display:'flex',gap:8}}>\r\n                    <input\r\n                      value={coupon}\r\n                      onChange={e=>setCoupon(e.target.value)}\r\n                      placeholder=\"NhГҹв•‘ВЎp mв”ңГә coupon\"\r\n                      style={{flex:1,padding:'10px 14px',border:'1.5px solid var(--border)',borderRadius:4,fontSize:14,outline:'none'}}\r\n                    />\r\n                    <button className=\"crs-btn-outline\" style={{padding:'10px 16px',whiteSpace:'nowrap'}}>в”ңГјp dГҹв•—Г‘ng</button>\r\n                  </div>\r\n                </div>\r\n\r\n                <div className=\"crs-secure\">ВӯЖ’Г¶ГҶ Thanh toв”ңГӯn an toв”ңГЎn & bГҹв•‘Гәo mГҹв•‘ВЎt SSL</div>\r\n\r\n                {/* Trust Badges */}\r\n                <div style={{display:'flex',justifyContent:'center',gap:12,marginTop:14,flexWrap:'wrap'}}>\r\n                  {['ВӯЖ’ГҶв”Ӯ Visa','ВӯЖ’ГҶв”Ӯ MC','ВӯЖ’Гҙв–’ MoMo','ВӯЖ’Г…ВӘ Bank'].map(b => (\r\n                    <span key={b} style={{fontSize:11,color:'var(--muted)',background:'var(--bg)',padding:'4px 8px',borderRadius:4}}>{b}</span>\r\n                  ))}\r\n                </div>\r\n              </div>\r\n            </div>\r\n          </div>\r\n        )\r\n      )}\r\n\r\n      {/* Г”ГІГүГ”ГІГүГ”ГІГү TAB: LГҹв•—ГЁCH SГҹв•—Вј MUA Hв”ңГҮNG Г”ГІГүГ”ГІГүГ”ГІГү */}\r\n      {tab === 'orders' && (\r\n        orders.length === 0 ? (\r\n          <div className=\"crs-cart-empty\" style={{padding:'80px 20px'}}>\r\n            <div style={{fontSize:72,marginBottom:16}}>ВӯЖ’ГҙВӘ</div>\r\n            <h3>ChГЈв–‘a cв”ңв”Ӯ в”ҖГҰГЈГӯn hв”ңГЎng nв”ңГЎo</h3>\r\n            <p style={{color:'var(--muted)',marginBottom:20}}>BГҹв•‘В»t в”ҖГҰГҹв•‘Вәu hГҹв•—Г¬c в”ҖГҰГҹв•—Гў tГҹв•‘Гӯo в”ҖГҰГЈГӯn hв”ңГЎng в”ҖГҰГҹв•‘Вәu tiв”ңВ¬n.</p>\r\n            <button className=\"crs-btn-solid\" onClick={()=>navigate('/')}>Khв”ңГӯm phв”ңГӯ khв”ңв”Ӯa hГҹв•—Г¬c</button>\r\n          </div>\r\n        ) : (\r\n          <div className=\"crs-orders-list\" style={{marginTop:4}}>\r\n            {orders.map((order, idx) => {\r\n              const isPaid = order.status === 'paid';\r\n              const isExpanded = expandedOrder === order.id;\r\n              return (\r\n                <div key={order.id} className=\"crs-order-row\">\r\n                  <div className=\"crs-order-head\" onClick={()=>setExpandedOrder(isExpanded?null:order.id)}>\r\n                    <div className=\"crs-order-left\">\r\n                      <span className=\"crs-order-id\">#{order.id}</span>\r\n                      <span className=\"crs-order-date\">{new Date(order.created_at).toLocaleDateString('vi-VN')}</span>\r\n                    </div>\r\n                    <div className=\"crs-order-right\">\r\n                      <span className={`crs-status-badge ${isPaid ? 'paid' : 'pending'}`}>\r\n                        {isPaid ? 'Г”ВЈГҙ в”ҖГүв”ңГә thanh toв”ңГӯn' : 'Г”Г…в”Ӯ ChГҹв•—Гҳ xГҹв•—ВЎ lв”ңВў'}\r\n                      </span>\r\n                      <span className=\"crs-order-price\">{parseFloat(order.total_price||0).toLocaleString('vi-VN')} Г”Г©ВҪ</span>\r\n                      <span className=\"crs-expand\">{isExpanded ? 'Г”Г»в–“' : 'Г”Г»в•қ'}</span>\r\n                    </div>\r\n                  </div>\r\n                  {isExpanded && (\r\n                    <div className=\"crs-order-detail\">\r\n                      {order.items?.map((item, i) => (\r\n                        <div key={item.id} className=\"crs-order-item\">\r\n                          <div className=\"crs-oi-thumb\" style={{background: GRADS[i % GRADS.length]}}>\r\n                            {item.course?.title?.[0] || '?'}\r\n                          </div>\r\n                          <div className=\"crs-oi-info\">\r\n                            <div className=\"crs-oi-title\">{fixText(item.course?.title || 'Khв”ңв”Ӯa hГҹв•—Г¬c')}</div>\r\n                            <div className=\"crs-oi-org\">{item.course?.partner_name || 'EduVNU'}</div>\r\n                          </div>\r\n                          <span className=\"crs-oi-price\">{parseFloat(item.price||0).toLocaleString('vi-VN')} Г”Г©ВҪ</span>\r\n                          {isPaid && (\r\n                            <button className=\"crs-paid-learn-btn\" onClick={()=>navigate(`/learn/${item.course?.id}`)}>\r\n                              Vв”ңГЎo hГҹв•—Г¬c Г”ГҘГҶ\r\n                            </button>\r\n                          )}\r\n                        </div>\r\n                      ))}\r\n                    </div>\r\n                  )}\r\n                </div>\r\n              );\r\n            })}\r\n          </div>\r\n        )\r\n      )}\r\n\r\n      {/* Toast */}\r\n      {toast && <div className=\"toast\">{toast}</div>}\r\n    </div>\r\n  );\r\n}\r\n","usedDeprecatedRules":[]},{"filePath":"D:\\ThГЈв–‘ГЈГӯng mГҹв•‘Гӯi в”ҖГҰiГҹв•—Г§n tГҹв•—ВЎ\\frontend\\src\\pages\\Checkout.jsx","messages":[{"ruleId":"react-hooks/set-state-in-effect","severity":2,"message":"Error: Calling setState synchronously within an effect can trigger cascading renders\n\nEffects are intended to synchronize state between React and external systems such as manually updating the DOM, state management libraries, or other platform APIs. In general, the body of an effect should do one or both of the following:\n* Update external systems with the latest state from React.\n* Subscribe for updates from some external system, calling setState in a callback function when external state changes.\n\nCalling setState synchronously within an effect body causes cascading renders that can hurt performance, and is not recommended. (https://react.dev/learn/you-might-not-need-an-effect).\n\n  127 |     \n  128 |     if (isTrial) {\n> 129 |       setItems([{\n      |       ^^^^^^^^ Avoid calling setState() directly within an effect\n  130 |         id: 'trial_123',\n  131 |         course: { title: `${trialProgram?.title || 'ChГЈв–‘ГЈГӯng trв”ңВјnh'} - Dв”ңв•Јng thГҹв•—ВЎ miГҹв•—Г n phв”ңВЎ 7 ngв”ңГЎy`, price: 0 }\n  132 |       }]);","line":129,"column":7,"nodeType":null,"endLine":129,"endColumn":15},{"ruleId":"react-hooks/exhaustive-deps","severity":1,"message":"React Hook useEffect has missing dependencies: 'isTrial', 'navigate', and 'trialProgram?.title'. Either include them or remove the dependency array.","line":145,"column":6,"nodeType":"ArrayExpression","endLine":145,"endColumn":25,"suggestions":[{"desc":"Update the dependencies array to be: [user, authLoading, isTrial, navigate, trialProgram?.title]","fix":{"range":[6340,6359],"text":"[user, authLoading, isTrial, navigate, trialProgram?.title]"}}]}],"suppressedMessages":[],"errorCount":1,"fatalErrorCount":0,"warningCount":1,"fixableErrorCount":0,"fixableWarningCount":0,"source":"import { useState, useEffect, useRef, forwardRef, useImperativeHandle } from 'react';\r\nimport { useNavigate, useLocation } from 'react-router-dom';\r\nimport { loadStripe } from '@stripe/stripe-js';\r\nimport { Elements, CardNumberElement, CardExpiryElement, CardCvcElement, useStripe, useElements } from '@stripe/react-stripe-js';\r\nimport api from '../api/axios';\r\nimport { useAuth } from '../context/AuthContext';\r\nimport { fixText } from '../utils/fixEncoding';\r\nimport { Loading } from '../components/LoadingUI';\r\nimport usePageSEO from '../hooks/usePageSEO';\r\n\r\nconst stripePromise = loadStripe('pk_test_51TJ6jYCXDledMR05jGelboBqOpunHDDIB1tv63hrPBjtMsT0agZOLb1ssY2YQDR6GUht4ZR2QusKLcBjS2px798N008DFMTXT9');\r\n\r\nconst METHODS = [\r\n  { id: 'vnpay', icon: 'ВӯЖ’ГёГӯВҙВ©Г…', label: 'CГҹв•—ГІng thanh toв”ңГӯn VNPAY', desc: 'ATM nГҹв•—Г–i в”ҖГҰГҹв•—ГҜa, Internet Banking' },\r\n  { id: 'momo',  icon: 'ВӯЖ’Гҙв–’', label: 'Vв”ңВЎ в”ҖГҰiГҹв•—Г§n tГҹв•—ВЎ MoMo',       desc: 'Quв”ңВ®t mв”ңГә MoMo в”ҖГҰГҹв•—Гў thanh toв”ңГӯn' },\r\n  { id: 'card',  icon: 'ВӯЖ’ГҶв”Ӯ', label: 'ThГҹв•‘в•— Visa / Mastercard', desc: 'Thanh toв”ңГӯn an toв”ңГЎn qua Stripe' },\r\n  { id: 'chuyen_khoan', icon: 'ВӯЖ’Г…ВӘ', label: 'ChuyГҹв•—Гўn khoГҹв•‘Гәn QR', desc: 'Quв”ңВ®t VietQR, xв”ңГӯc nhГҹв•‘ВЎn tГҹв•—в–’ в”ҖГҰГҹв•—Г–ng' },\r\n];\r\n\r\nconst GRADS = [\r\n  'linear-gradient(135deg,#0369a1,#0ea5e9)',\r\n  'linear-gradient(135deg,#7c3aed,#a78bfa)',\r\n  'linear-gradient(135deg,#059669,#34d399)',\r\n  'linear-gradient(135deg,#b45309,#f59e0b)',\r\n];\r\n\r\nconst STRIPE_ELEM_STYLE = {\r\n  style: {\r\n    base: { fontSize: '15px', color: '#1e293b', fontFamily: '\"Inter\", sans-serif', '::placeholder': { color: '#94a3b8' } },\r\n    invalid: { color: '#ef4444' },\r\n  },\r\n};\r\n\r\nconst StripeCardForm = forwardRef(function StripeCardForm({ onSuccess, onError }, ref) {\r\n  const stripe = useStripe();\r\n  const elements = useElements();\r\n  useImperativeHandle(ref, () => ({\r\n    submit: async () => {\r\n      if (!stripe || !elements) return false;\r\n      onError('');\r\n      const cardNumberEl = elements.getElement(CardNumberElement);\r\n      const { error: pmError, paymentMethod } = await stripe.createPaymentMethod({\r\n        type: 'card',\r\n        card: cardNumberEl,\r\n      });\r\n      if (pmError) {\r\n        onError(pmError.message);\r\n        return false;\r\n      }\r\n      try {\r\n        const res = await api.post('/orders/checkout/', {\r\n          payment_method: 'card',\r\n          stripe_payment_method_id: paymentMethod.id,\r\n        });\r\n        if (res.data.status === 'success') {\r\n          onSuccess(res.data.order_id);\r\n          return true;\r\n        }\r\n        if (res.data.status === 'requires_action') {\r\n          const { error } = await stripe.handleNextAction({ clientSecret: res.data.client_secret });\r\n          if (error) { onError(error.message); return false; }\r\n          onSuccess(res.data.order_id);\r\n          return true;\r\n        }\r\n        onError(res.data.error || 'Thanh toв”ңГӯn thГҹв•‘Г‘t bГҹв•‘Гӯi');\r\n        return false;\r\n      } catch (e) {\r\n        onError(e.response?.data?.error || 'LГҹв•—Г№i kГҹв•‘в”җt nГҹв•—ГҰi server');\r\n        return false;\r\n      }\r\n    },\r\n  }));\r\n\r\n  return (\r\n    <div style={{ marginTop: 8 }}>\r\n      <div className=\"crs-field\" style={{ marginBottom: 14 }}>\r\n        <label style={{ fontSize: 12, fontWeight: 700, color: '#475569', textTransform: 'uppercase', display: 'block', marginBottom: 6 }}>SГҹв•—ГҰ thГҹв•‘в•—</label>\r\n        <div style={{ border: '1.5px solid #e2e8f0', borderRadius: 8, padding: '13px 14px', background: '#f8fafc', transition: '0.2s' }}>\r\n          <CardNumberElement options={STRIPE_ELEM_STYLE} />\r\n        </div>\r\n        <div style={{ display: 'flex', gap: 6, marginTop: 8 }}>\r\n          {['VISA', 'MASTERCARD', 'AMEX', 'JCB'].map(b => (\r\n            <span key={b} style={{ fontSize: 9, background: '#e2e8f0', padding: '2px 7px', borderRadius: 4, fontWeight: 700, letterSpacing: '0.05em' }}>{b}</span>\r\n          ))}\r\n        </div>\r\n      </div>\r\n      <div style={{ display: 'grid', gridTemplateColumns: '1fr 1fr', gap: 14 }}>\r\n        <div className=\"crs-field\">\r\n          <label style={{ fontSize: 12, fontWeight: 700, color: '#475569', textTransform: 'uppercase', display: 'block', marginBottom: 6 }}>HГҹв•‘в”җt hГҹв•‘Гӯn</label>\r\n          <div style={{ border: '1.5px solid #e2e8f0', borderRadius: 8, padding: '13px 14px', background: '#f8fafc' }}>\r\n            <CardExpiryElement options={STRIPE_ELEM_STYLE} />\r\n          </div>\r\n        </div>\r\n        <div className=\"crs-field\">\r\n          <label style={{ fontSize: 12, fontWeight: 700, color: '#475569', textTransform: 'uppercase', display: 'block', marginBottom: 6 }}>CVV</label>\r\n          <div style={{ border: '1.5px solid #e2e8f0', borderRadius: 8, padding: '13px 14px', background: '#f8fafc' }}>\r\n            <CardCvcElement options={STRIPE_ELEM_STYLE} />\r\n          </div>\r\n        </div>\r\n      </div>\r\n      <div style={{ marginTop: 14, fontSize: 12, color: '#64748b', display: 'flex', alignItems: 'center', gap: 6 }}>\r\n        ВӯЖ’Г¶Гү SГҹв•—ГҰ thГҹв•‘в•— в”ҖГҰГЈв–‘Гҹв•—Гәc mв”ңГә hв”ңв”Ӯa bГҹв•—Ж’i Stripe, EduVNU khв”ңв”Өng lГЈв–‘u thв”ңв”Өng tin thГҹв•‘в•— cГҹв•—Вәa bГҹв•‘Гӯn.\r\n      </div>\r\n    </div>\r\n  );\r\n});\r\n\r\nexport default function Checkout() {\r\n  usePageSEO({ title: 'Thanh toв”ңГӯn an toв”ңГЎn - EduVNU', description: 'Hoв”ңГЎn tГҹв•‘Г‘t в”ҖГҰГЈГӯn hв”ңГЎng cГҹв•—Вәa bГҹв•‘Гӯn в”ҖГҰГҹв•—Гў bГҹв•‘В»t в”ҖГҰГҹв•‘Вәu hГҹв•—Г¬c ngay.' });\r\n  const { user, loading: authLoading } = useAuth();\r\n  const navigate = useNavigate();\r\n  const location = useLocation();\r\n  const searchParams = new URLSearchParams(location.search);\r\n  const isTrial = searchParams.get('trial') === 'true';\r\n  const trialProgram = location.state?.program; // We can still try to get the title from state\r\n\r\n  const [items, setItems] = useState([]);\r\n  const [loading, setLoading] = useState(true);\r\n  const [method, setMethod] = useState('vnpay');\r\n  const [processing, setProcessing] = useState(false);\r\n  const [error, setError] = useState('');\r\n  const stripeFormRef = useRef(null);\r\n\r\n  useEffect(() => {\r\n    if (authLoading) return;\r\n    if (!user) { navigate('/login'); return; }\r\n    \r\n    if (isTrial) {\r\n      setItems([{\r\n        id: 'trial_123',\r\n        course: { title: `${trialProgram?.title || 'ChГЈв–‘ГЈГӯng trв”ңВјnh'} - Dв”ңв•Јng thГҹв•—ВЎ miГҹв•—Г n phв”ңВЎ 7 ngв”ңГЎy`, price: 0 }\r\n      }]);\r\n      setLoading(false);\r\n      return;\r\n    }\r\n\r\n    api.get('/cart/my_cart/')\r\n      .then(r => {\r\n        const cartItems = r.data.items || [];\r\n        if (cartItems.length === 0) { navigate('/cart'); return; }\r\n        setItems(cartItems);\r\n      })\r\n      .catch(() => {})\r\n      .finally(() => setLoading(false));\r\n  }, [user, authLoading]);\r\n\r\n  const subtotal = items.reduce((s, i) => s + parseFloat(i.course?.price || 0), 0);\r\n\r\n  const handleConfirm = async () => {\r\n    if (!items.length) return;\r\n    setProcessing(true);\r\n    setError('');\r\n    \r\n    if (isTrial) {\r\n       // Mock payment success for free trial checkout without hitting backend cart logic\r\n       setTimeout(() => {\r\n         navigate(`/payment-return?method=${method}&order_id=TRIAL_${Date.now()}&trial=true`);\r\n       }, 1500);\r\n       return;\r\n    }\r\n\r\n    if (method === 'card') {\r\n      if (stripeFormRef.current) {\r\n        const ok = await stripeFormRef.current.submit();\r\n        if (!ok) setProcessing(false);\r\n      } else {\r\n        setError('Stripe chГЈв–‘a sГҹв•‘ГҒn sв”ңГЎng, vui lв”ңв–“ng chГҹв•—Гҳ giв”ңГіy lв”ңГӯt.');\r\n        setProcessing(false);\r\n      }\r\n      return;\r\n    }\r\n    try {\r\n      const res = await api.post('/orders/checkout/', { payment_method: method });\r\n      if (res.data.payment_url) {\r\n        window.location.href = res.data.payment_url;\r\n        return;\r\n      }\r\n      navigate(`/payment-return?method=${method}&order_id=${res.data.id || ''}`);\r\n    } catch (e) {\r\n      setError(e.response?.data?.error || 'Thanh toв”ңГӯn thГҹв•‘Г‘t bГҹв•‘Гӯi. Vui lв”ңв–“ng thГҹв•—ВЎ lГҹв•‘Гӯi.');\r\n      setProcessing(false);\r\n    }\r\n  };\r\n\r\n  const handleStripeSuccess = (orderId) => {\r\n    navigate(`/payment-return?method=card&order_id=${orderId}`);\r\n  };\r\n\r\n  if (authLoading || loading) return <Loading message=\"в”ҖГүang xГҹв•—ВЎ lв”ңВў thв”ңв”Өng tin...\" />;\r\n\r\n  return (\r\n    <div className=\"crs-checkout-page\" style={{ backgroundColor: '#f5f7f8', minHeight: '100vh', padding: '40px 0' }}>\r\n      <div className=\"crs-checkout-layout\" style={{ alignItems: 'flex-start' }}>\r\n        <div style={{ display: 'flex', flexDirection: 'column', gap: '24px' }}>\r\n          <h1 style={{ fontSize: 32, fontWeight: 700, margin: '0 0 8px 0', color: '#1f2937' }}>Thanh toв”ңГӯn</h1>\r\n          <div className=\"crs-checkout-card\" style={{ padding: '24px' }}>\r\n            <h3 style={{ fontSize: 20, marginBottom: 16, display: 'flex', alignItems: 'center', gap: 8 }}>\r\n              <span>ВӯЖ’ГҰГұ</span> Thв”ңв”Өng tin tв”ңГЎi khoГҹв•‘Гәn\r\n            </h3>\r\n            <div style={{ background: '#f8fafc', padding: '16px', borderRadius: '8px', border: '1px solid #e2e8f0' }}>\r\n              <div style={{ fontSize: 16, fontWeight: 600, color: '#0f172a' }}>\r\n                {user?.first_name ? `${user.first_name} ${user.last_name}` : user?.username}\r\n              </div>\r\n              <div style={{ fontSize: 14, color: '#64748b', marginTop: 4 }}>{user?.email}</div>\r\n            </div>\r\n          </div>\r\n          <div className=\"crs-checkout-card\" style={{ padding: '0', overflow: 'hidden' }}>\r\n            <div style={{ padding: '24px 24px 16px', borderBottom: '1px solid #e5e7eb', background: '#fff' }}>\r\n              <h3 style={{ fontSize: 20, margin: 0, display: 'flex', alignItems: 'center', gap: 8 }}>\r\n                <span>ВӯЖ’ГҶв”Ӯ</span> PhГЈв–‘ГЈГӯng thГҹв•—В®c thanh toв”ңГӯn\r\n              </h3>\r\n            </div>\r\n            <div style={{ display: 'flex', flexDirection: 'column' }}>\r\n              {(isTrial ? METHODS.filter(m => m.id === 'vnpay' || m.id === 'card') : METHODS).map((m, index, arr) => {\r\n                const isActive = method === m.id;\r\n                return (\r\n                  <div key={m.id} style={{ borderBottom: index < arr.length - 1 ? '1px solid #e2e8f0' : 'none' }}>\r\n                    <label\r\n                      onClick={() => setMethod(m.id)}\r\n                      style={{\r\n                        padding: '20px 24px', display: 'flex', alignItems: 'center', cursor: 'pointer',\r\n                        background: isActive ? '#f0f9ff' : '#fff', transition: 'all 0.2s',\r\n                      }}\r\n                    >\r\n                      <input\r\n                        type=\"radio\" name=\"method\" value={m.id}\r\n                        checked={isActive} onChange={() => setMethod(m.id)}\r\n                        style={{ width: 20, height: 20, accentColor: '#0056d2', marginRight: 16 }}\r\n                      />\r\n                      <span style={{ fontSize: 24, marginRight: 12 }}>{m.icon}</span>\r\n                      <div style={{ flex: 1 }}>\r\n                        <div style={{ fontSize: 16, fontWeight: 600, color: '#1e293b' }}>{m.label}</div>\r\n                        <div style={{ fontSize: 13, color: '#64748b', marginTop: 2 }}>{m.desc}</div>\r\n                      </div>\r\n                    </label>\r\n                    {isActive && (\r\n                      <div style={{ padding: '0 24px 24px 58px', background: '#f0f9ff' }}>\r\n                        {m.id === 'vnpay' && (\r\n                          <div style={{ display: 'flex', alignItems: 'flex-start', gap: 12, padding: '16px', background: '#fff', borderRadius: 8, border: '1px solid #e0f2fe' }}>\r\n                            <span style={{ fontSize: 28 }}>ВӯЖ’ГёГӯВҙВ©Г…</span>\r\n                            <div>\r\n                               <div style={{ fontWeight: 700, color: '#0369a1', marginBottom: 4 }}>CГҹв•—ГІng thanh toв”ңГӯn VNPAY</div>\r\n                               <p style={{ color: '#64748b', margin: 0, fontSize: 14, lineHeight: 1.6 }}>Thanh toв”ңГӯn an toв”ңГЎn qua hГҹв•—Г§ thГҹв•—ГҰng VNPAY.</p>\r\n                            </div>\r\n                          </div>\r\n                        )}\r\n                        {m.id === 'momo' && (\r\n                          <div style={{ display: 'flex', alignItems: 'flex-start', gap: 12, padding: '16px', background: '#fff', borderRadius: 8, border: '1px solid #fae8ff' }}>\r\n                            <span style={{ fontSize: 28 }}>ВӯЖ’Гҙв–’</span>\r\n                            <div>\r\n                              <div style={{ fontWeight: 700, color: '#a21caf', marginBottom: 4 }}>Vв”ңВЎ в”ҖГҰiГҹв•—Г§n tГҹв•—ВЎ MoMo</div>\r\n                              <p style={{ color: '#64748b', margin: 0, fontSize: 14, lineHeight: 1.6 }}>Thanh toв”ңГӯn nhanh chв”ңв”Ӯng qua Гҹв•—В®ng dГҹв•—Г‘ng MoMo.</p>\r\n                            </div>\r\n                          </div>\r\n                        )}\r\n                        {m.id === 'card' && (\r\n                          <Elements stripe={stripePromise}>\r\n                            <StripeCardForm ref={stripeFormRef} onSuccess={handleStripeSuccess} onError={setError} />\r\n                          </Elements>\r\n                        )}\r\n                      </div>\r\n                    )}\r\n                  </div>\r\n                );\r\n              })}\r\n            </div>\r\n          </div>\r\n          {error && <div style={{ background: '#fee2e2', color: '#ef4444', padding: '16px', borderRadius: 8, borderLeft: '4px solid #ef4444', fontWeight: 600 }}>{error}</div>}\r\n        </div>\r\n        <div style={{ position: 'sticky', top: '100px' }}>\r\n          <div className=\"crs-order-summary-card\" style={{ padding: 0, overflow: 'hidden', borderRadius: 12, boxShadow: '0 4px 24px rgba(0,0,0,0.08)', border: '1px solid #e2e8f0' }}>\r\n            <div style={{ padding: '18px 24px', background: 'linear-gradient(135deg, #0056d2, #0041a8)' }}>\r\n              <h3 style={{ fontSize: 17, margin: 0, color: '#fff', fontWeight: 700, display: 'flex', alignItems: 'center', gap: 8 }}>ВӯЖ’ВәВҘ Tв”ңв”Ӯm tГҹв•‘В»t в”ҖГҰГЈГӯn hв”ңГЎng</h3>\r\n            </div>\r\n            <div style={{ padding: '20px 24px' }}>\r\n              {items.map((item, idx) => (\r\n                <div key={item.id} style={{ display: 'flex', alignItems: 'center', gap: 12, marginBottom: 14 }}>\r\n                  <div style={{ width: 42, height: 42, borderRadius: 8, background: GRADS[idx % GRADS.length], display: 'flex', alignItems: 'center', justifyContent: 'center', color: 'white', fontWeight: 700, fontSize: 17, flexShrink: 0 }}>\r\n                    {fixText(item.course?.title)?.[0] || '?'}\r\n                  </div>\r\n                  <div style={{ flex: 1 }}>\r\n                    <div style={{ fontSize: 13, fontWeight: 600, color: '#1e293b', display: '-webkit-box', WebkitLineClamp: 2, WebkitBoxOrient: 'vertical', overflow: 'hidden', lineHeight: 1.4 }}>\r\n                      {fixText(item.course?.title)}\r\n                    </div>\r\n                  </div>\r\n                  <div style={{ fontWeight: 700, color: '#0f172a', fontSize: 14 }}>{parseFloat(item.course?.price || 0).toLocaleString('vi-VN')}Г”Г©ВҪ</div>\r\n                </div>\r\n              ))}\r\n              <div style={{ height: 1, background: '#f1f5f9', margin: '14px 0' }} />\r\n              <div style={{ background: '#f0f7ff', borderRadius: 10, padding: '14px 16px', marginBottom: 18, display: 'flex', justifyContent: 'space-between', alignItems: 'center' }}>\r\n                <span style={{ fontWeight: 700, fontSize: 15 }}>TГҹв•—ГІng cГҹв•—Г–ng</span>\r\n                <span style={{ fontWeight: 800, fontSize: 22, color: '#0056d2' }}>{subtotal.toLocaleString('vi-VN')}Г”Г©ВҪ</span>\r\n              </div>\r\n              <button\r\n                id=\"checkout-confirm-btn\"\r\n                onClick={handleConfirm}\r\n                disabled={processing}\r\n                style={{\r\n                  width: '100%', padding: '15px 20px',\r\n                  background: processing ? '#94a3b8' : 'linear-gradient(135deg, #0056d2, #0041a8)',\r\n                  color: '#fff', border: 'none', borderRadius: 10, fontSize: 16, fontWeight: 700,\r\n                  cursor: processing ? 'not-allowed' : 'pointer',\r\n                  display: 'flex', alignItems: 'center', justifyContent: 'center', gap: 10,\r\n                  transition: 'all 0.25s ease',\r\n                  boxShadow: processing ? 'none' : '0 4px 16px rgba(0,86,210,0.35)',\r\n                }}\r\n              >\r\n                {processing ? 'Г”Г…в”Ӯ в”ҖГүang xГҹв•—ВЎ lв”ңВў...' : 'ВӯЖ’Г¶ГҶ Hoв”ңГЎn tГҹв•‘Г‘t thanh toв”ңГӯn'}\r\n              </button>\r\n              <div style={{ marginTop: 18, display: 'flex', flexDirection: 'column', gap: 9 }}>\r\n                {[{icon:'Г”ВЈГ ', text:'BГҹв•‘Гәo в”ҖГҰГҹв•‘Гәm hoв”ңГЎn tiГҹв•—Гјn 30 ngв”ңГЎy'}, {icon:'ВӯЖ’Г¶ГҶ', text:'Thanh toв”ңГӯn bГҹв•‘Гәo mГҹв•‘ВЎt SSL'}, {icon:'ВӯЖ’Г„Гҙ', text:'Truy cГҹв•‘ВЎp trГҹв•—Г¬n в”ҖГҰГҹв•—Гҳi'}].map(({icon,text}) => (\r\n                  <div key={text} style={{ display: 'flex', alignItems: 'center', gap: 8, fontSize: 12, color: '#64748b' }}>\r\n                    <span>{icon}</span><span>{text}</span>\r\n                  </div>\r\n                ))}\r\n              </div>\r\n            </div>\r\n          </div>\r\n        </div>\r\n      </div>\r\n      <style>{`@keyframes checkout-spin { from { transform: rotate(0deg); } to { transform: rotate(360deg); } }`}</style>\r\n    </div>\r\n  );\r\n}","usedDeprecatedRules":[]},{"filePath":"D:\\ThГЈв–‘ГЈГӯng mГҹв•‘Гӯi в”ҖГҰiГҹв•—Г§n tГҹв•—ВЎ\\frontend\\src\\pages\\Contact.jsx","messages":[{"ruleId":"no-unused-vars","severity":2,"message":"'error' is defined but never used.","line":21,"column":14,"nodeType":"Identifier","messageId":"unusedVar","endLine":21,"endColumn":19}],"suppressedMessages":[],"errorCount":1,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"source":"import { useState } from 'react';\r\nimport api from '../api/axios';\r\nimport usePageSEO from '../hooks/usePageSEO';\r\n\r\nexport default function Contact() {\r\n  usePageSEO({ title: 'Liв”ңВ¬n hГҹв•—Г§', description: 'Liв”ңВ¬n hГҹв•—Г§ vГҹв•—Гёi EduVNU в”ҖГҰГҹв•—Гў nhГҹв•‘ВЎn hГҹв•—Г№ trГҹв•—Гә' });\r\n  const [formData, setFormData] = useState({ name: '', email: '', subject: '', message: '' });\r\n  const [status, setStatus] = useState({ loading: false, message: '', type: '' });\r\n\r\n  const handleChange = (e) => {\r\n    setFormData({ ...formData, [e.target.name]: e.target.value });\r\n  };\r\n\r\n  const handleSubmit = async (e) => {\r\n    e.preventDefault();\r\n    setStatus({ loading: true, message: '', type: '' });\r\n    try {\r\n      await api.post('/courses/contact/', formData);\r\n      setStatus({ loading: false, message: 'ВӯЖ’Г„Г« CГҹв•‘Гәm ГЈГӯn bГҹв•‘Гӯn! LГҹв•—Гҳi nhГҹв•‘В»n в”ҖГҰв”ңГә в”ҖГҰГЈв–‘Гҹв•—Гәc gГҹв•—ВЎi thв”ңГЎnh cв”ңв”Өng.', type: 'success' });\r\n      setFormData({ name: '', email: '', subject: '', message: '' });\r\n    } catch (error) {\r\n      setStatus({ loading: false, message: 'Г”ГҳГ® Cв”ңв”Ӯ lГҹв•—Г№i xГҹв•‘Гәy ra, vui lв”ңв–“ng thГҹв•—ВЎ lГҹв•‘Гӯi sau.', type: 'error' });\r\n    }\r\n  };\r\n\r\n  return (\r\n    <div className=\"crs-contact-container\">\r\n      <div className=\"crs-contact-form-side\">\r\n        <h1 className=\"crs-contact-title\">Liв”ңВ¬n hГҹв•—Г§ vГҹв•—Гёi chв”ңв•‘ng tв”ңв”Өi</h1>\r\n        <p className=\"crs-contact-subtitle\">BГҹв•‘Гӯn cв”ңв”Ӯ cв”ңГіu hГҹв•—Г…i, в”ҖГҰГҹв•—Гј xuГҹв•‘Г‘t hoГҹв•‘ГҖc phГҹв•‘Гәn hГҹв•—Гҙi в”ҖГҰГЈГӯn hв”ңГЎng? Hв”ңГәy в”ҖГҰiГҹв•—Гјn vв”ңГЎo biГҹв•—Гўu mГҹв•‘ВҪu bв”ңВ¬n dГЈв–‘Гҹв•—Гёi vв”ңГЎ chв”ңв•‘ng tв”ңв”Өi sГҹв•‘Вў hГҹв•—Г№ trГҹв•—Гә bГҹв•‘Гӯn ngay.</p>\r\n        \r\n        {status.message && (\r\n          <div className={`crs-alert ${status.type}`}>\r\n            {status.message}\r\n          </div>\r\n        )}\r\n\r\n        <form onSubmit={handleSubmit} className=\"crs-form-grid\">\r\n          <div className=\"crs-field\">\r\n            <label>HГҹв•—Г¬ vв”ңГЎ tв”ңВ¬n</label>\r\n            <input type=\"text\" name=\"name\" value={formData.name} onChange={handleChange} required placeholder=\"NguyГҹв•—Г n Vв”ҖГўn A\" />\r\n          </div>\r\n          <div className=\"crs-field\">\r\n            <label>Email</label>\r\n            <input type=\"email\" name=\"email\" value={formData.email} onChange={handleChange} required placeholder=\"email@example.com\" />\r\n          </div>\r\n          <div className=\"crs-field\">\r\n            <label>ChГҹв•—Вә в”ҖГҰГҹв•—Гј</label>\r\n            <input type=\"text\" name=\"subject\" value={formData.subject} onChange={handleChange} required placeholder=\"Vв”ңВЎ dГҹв•—Г‘: Bв”ңГӯo lГҹв•—Г№i thanh toв”ңГӯn...\" />\r\n          </div>\r\n          <div className=\"crs-field\">\r\n            <label>NГҹв•—Г–i dung chi tiГҹв•‘в”җt</label>\r\n            <textarea name=\"message\" value={formData.message} onChange={handleChange} required placeholder=\"Mв”ңв”Ө tГҹв•‘Гә chi tiГҹв•‘в”җt vГҹв•‘Г‘n в”ҖГҰГҹв•—Гј bГҹв•‘Гӯn в”ҖГҰang gГҹв•‘ГҖp phГҹв•‘Гәi...\" />\r\n          </div>\r\n          <button type=\"submit\" className=\"crs-btn-solid crs-submit-btn\" disabled={status.loading}>\r\n            {status.loading ? 'Г”Г…в”Ӯ в”ҖГүang gГҹв•—ВЎi...' : 'GГҹв•—ВЎi lГҹв•—Гҳi nhГҹв•‘В»n'}\r\n          </button>\r\n        </form>\r\n      </div>\r\n      \r\n      <div className=\"crs-contact-info-side\">\r\n        <h2 className=\"crs-contact-subtitle\" style={{margin:0, color:'#1f1f1f', fontWeight:700}}>TrГҹв•—Г‘ sГҹв•—Ж’ vв”ҖГўn phв”ңв–“ng</h2>\r\n        <div className=\"crs-contact-address\">ВӯЖ’ГҙГ¬ 144 Xuв”ңГіn ThГҹв•—Вәy, DГҹв•—ГҜch VГҹв•—Г¬ng HГҹв•‘ВЎu, CГҹв•‘Вәu GiГҹв•‘Г‘y, Hв”ңГЎ NГҹв•—Г–i</div>\r\n        <div className=\"crs-map-container\">\r\n          <iframe \r\n            src=\"https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3723.9242961448834!2d105.78044731493264!3d21.035712585994246!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x3135ab4a40871ccf%3A0xcb030fac4fe18d96!2sVNU%20University%20of%20Engineering%20and%20Technology%20(UET)!5e0!3m2!1sen!2s!4v1689230559902!5m2!1sen!2s\" \r\n            allowFullScreen=\"\" loading=\"lazy\" referrerPolicy=\"no-referrer-when-downgrade\" title=\"Map\">\r\n          </iframe>\r\n        </div>\r\n      </div>\r\n    </div>\r\n  );\r\n}\r\n","usedDeprecatedRules":[]},{"filePath":"D:\\ThГЈв–‘ГЈГӯng mГҹв•‘Гӯi в”ҖГҰiГҹв•—Г§n tГҹв•—ВЎ\\frontend\\src\\pages\\CourseDetail.jsx","messages":[{"ruleId":"react-hooks/exhaustive-deps","severity":1,"message":"React Hook useEffect has a missing dependency: 'loadCourse'. Either include it or remove the dependency array.","line":58,"column":38,"nodeType":"ArrayExpression","endLine":58,"endColumn":48,"suggestions":[{"desc":"Update the dependencies array to be: [courseId, loadCourse]","fix":{"range":[2234,2244],"text":"[courseId, loadCourse]"}}]}],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":1,"fixableErrorCount":0,"fixableWarningCount":0,"source":"import { useState, useEffect, useRef } from 'react';\r\nimport { useParams, useNavigate, Link } from 'react-router-dom';\r\nimport api from '../api/axios';\r\nimport { useAuth } from '../context/AuthContext';\r\nimport { fixText } from '../utils/fixEncoding';\r\nimport usePageSEO from '../hooks/usePageSEO';\r\nimport { getCourseThumbnail } from '../utils/courseImages';\r\n\r\n/* Г”Г¶ГҮГ”Г¶ГҮ GRADIENT PALETTE Г”Г¶ГҮГ”Г¶ГҮ */\r\nconst GRADS = [\r\n  'linear-gradient(135deg,#0056D2 0%,#0099e0 100%)',\r\n  'linear-gradient(135deg,#7c3aed 0%,#a78bfa 100%)',\r\n  'linear-gradient(135deg,#0891b2 0%,#22d3ee 100%)',\r\n  'linear-gradient(135deg,#059669 0%,#34d399 100%)',\r\n  'linear-gradient(135deg,#b45309 0%,#f59e0b 100%)',\r\n];\r\n\r\n/* Г”Г¶ГҮГ”Г¶ГҮ STARS COMPONENT Г”Г¶ГҮГ”Г¶ГҮ */\r\nfunction Stars({ rating, size = 14 }) {\r\n  const n = parseFloat(rating) || 0;\r\n  return (\r\n    <span style={{ display: 'inline-flex', gap: 1 }}>\r\n      {[1, 2, 3, 4, 5].map(i => (\r\n        <span key={i} style={{ color: i <= n ? '#f59e0b' : '#d1d5db', fontSize: size }}>Г”ГҝГ </span>\r\n      ))}\r\n    </span>\r\n  );\r\n}\r\n\r\n/* Г”Г¶ГҮГ”Г¶ГҮ MAIN COMPONENT Г”Г¶ГҮГ”Г¶ГҮ */\r\nexport default function CourseDetail() {\r\n  const { courseId } = useParams();\r\n  const { user } = useAuth();\r\n  const navigate = useNavigate();\r\n  const stickyNavRef = useRef(null);\r\n  const sectionsRef = useRef({});\r\n\r\n  const [course, setCourse] = useState(null);\r\n  const [loading, setLoading] = useState(true);\r\n  const [isEnrolled, setIsEnrolled] = useState(false);\r\n  const [addingCart, setAddingCart] = useState(false);\r\n  const [toast, setToast] = useState('');\r\n  const [activeNav, setActiveNav] = useState('about');\r\n  const [expandedModule, setExpandedModule] = useState(0);\r\n  const [reviews, setReviews] = useState([]);\r\n  const [reviewsLoading, setReviewsLoading] = useState(false);\r\n  const [showFullDesc, setShowFullDesc] = useState(false);\r\n  const [stickyVisible, setStickyVisible] = useState(false);\r\n  const [showTrialModal, setShowTrialModal] = useState(false);\r\n\r\n  /* SEO Г”ГҮГ¶ must be before any early return */\r\n  usePageSEO({\r\n    title: course ? fixText(course.title) : 'Chi tiГҹв•‘в”җt khв”ңв”Ӯa hГҹв•—Г¬c',\r\n    description: course?.description?.slice(0, 160) || 'EduVNU - Xem chi tiГҹв•‘в”җt khв”ңв”Ӯa hГҹв•—Г¬c',\r\n  });\r\n\r\n  /* Load course data */\r\n  useEffect(() => { loadCourse(); }, [courseId]);\r\n\r\n  /* Sticky nav scroll watcher */\r\n  useEffect(() => {\r\n    const onScroll = () => setStickyVisible(window.scrollY > 380);\r\n    window.addEventListener('scroll', onScroll);\r\n    return () => window.removeEventListener('scroll', onScroll);\r\n  }, []);\r\n\r\n  /* Fetch reviews when tab active */\r\n  useEffect(() => {\r\n    if (activeNav === 'testimonials' && courseId) {\r\n      setReviewsLoading(true);\r\n      api.get(`/courses/courses/${courseId}/reviews/`)\r\n        .then(r => setReviews(r.data?.results || r.data || []))\r\n        .catch(() => setReviews([]))\r\n        .finally(() => setReviewsLoading(false));\r\n    }\r\n  }, [activeNav, courseId]);\r\n\r\n  const loadCourse = async () => {\r\n    setLoading(true);\r\n    try {\r\n      const res = await api.get(`/courses/courses/${courseId}/`);\r\n      setCourse(res.data);\r\n      if (user) {\r\n        try {\r\n          const enrollRes = await api.get(`/courses/progress/my_progress/?course_id=${courseId}`);\r\n          if (enrollRes.data?.length > 0) setIsEnrolled(true);\r\n          else {\r\n            await api.get(`/courses/courses/${courseId}/lessons/`);\r\n            setIsEnrolled(true);\r\n          }\r\n        } catch { setIsEnrolled(false); }\r\n      }\r\n    } catch { navigate('/'); }\r\n    finally { setLoading(false); }\r\n  };\r\n\r\n  const showToast = msg => { setToast(msg); setTimeout(() => setToast(''), 3000); };\r\n\r\n  const addToCart = async () => {\r\n    if (!user) { navigate('/login'); return; }\r\n    setAddingCart(true);\r\n    try {\r\n      await api.post('/cart/add_item/', { course_id: courseId });\r\n      showToast('Г”ВЈГ  в”ҖГүв”ңГә thв”ңВ¬m vв”ңГЎo giГҹв•—Г… hв”ңГЎng!');\r\n    } catch (err) {\r\n      showToast(err.response?.data?.message || err.response?.data?.error || 'Khв”ңв”Өng thГҹв•—Гў thв”ңВ¬m vв”ңГЎo giГҹв•—Г… hв”ңГЎng.');\r\n    } finally { setAddingCart(false); }\r\n  };\r\n\r\n  const scrollToSection = id => {\r\n    const el = sectionsRef.current[id];\r\n    if (el) el.scrollIntoView({ behavior: 'smooth', block: 'start' });\r\n    setActiveNav(id);\r\n  };\r\n\r\n  if (loading) return (\r\n    <div style={{ display: 'flex', justifyContent: 'center', alignItems: 'center', height: '60vh', flexDirection: 'column', gap: 16 }}>\r\n      <div style={{ width: 48, height: 48, border: '4px solid #e5e7eb', borderTopColor: '#0056D2', borderRadius: '50%', animation: 'spin 0.8s linear infinite' }} />\r\n      <p style={{ color: '#6b7280' }}>в”ҖГүang tГҹв•‘Гәi khв”ңв”Ӯa hГҹв•—Г¬c...</p>\r\n      <style>{`@keyframes spin { to { transform: rotate(360deg); } }`}</style>\r\n    </div>\r\n  );\r\n  if (!course) return null;\r\n\r\n  /* Derived data */\r\n  const title = fixText(course.title);\r\n  const instructor = course.instructor;\r\n  const org = fixText(\r\n    instructor?.full_name ||\r\n    (instructor?.first_name && instructor?.last_name ? `${instructor.first_name} ${instructor.last_name}` : null) ||\r\n    instructor?.first_name || instructor?.username ||\r\n    course.partner_name || 'EduVNU Partner'\r\n  );\r\n  const rating = parseFloat(course.rating) || 4.6;\r\n  const price = parseFloat(course.price) || 0;\r\n  const skills = Array.isArray(course.skills_list) ? course.skills_list : [];\r\n  const gradIdx = parseInt(courseId) % GRADS.length;\r\n  // Use user's local images\r\n  const thumbnailUrl = getCourseThumbnail({ ...course, id: courseId });\r\n  const reviewCount = course.review_count || '10,000+';\r\n  const enrollCount = course.enrollment_count || '150,000+';\r\n  const originalPrice = parseFloat(course.original_price) || 0;\r\n  const isDiscounted = originalPrice > price && price > 0;\r\n\r\n  /* Real curriculum from chapters */\r\n  const curriculum = (course.chapters || []).length > 0 \r\n    ? course.chapters.map(ch => ({\r\n        title: ch.title,\r\n        duration: `${ch.lessons?.length || 0} bв”ңГЎi hГҹв•—Г¬c`,\r\n        lessons: (ch.lessons || []).map(l => l.title)\r\n      }))\r\n    : [\r\n        { title: 'NГҹв•—Г–i dung в”ҖГҰang в”ҖГҰГЈв–‘Гҹв•—Гәc cГҹв•‘ВЎp nhГҹв•‘ВЎt', duration: '...', lessons: [] }\r\n      ];\r\n  \r\n  const totalLessons = (course.chapters || []).reduce((acc, ch) => acc + (ch.lessons?.length || 0), 0);\r\n\r\n  const whatYouLearn = skills.length >= 4\r\n    ? skills.slice(0, 8)\r\n    : ['KiГҹв•‘в”җn thГҹв•—В®c nГҹв•—Гјn tГҹв•‘Гәng vГҹв•—В»ng chГҹв•‘В»c', 'KГҹв•—в•Ј nв”ҖГўng thГҹв•—в–’c hв”ңГЎnh thГҹв•—в–’c tГҹв•‘в”җ', 'TГЈв–‘ duy phГҹв•‘Гәn biГҹв•—Г§n & giГҹв•‘Гәi quyГҹв•‘в”җt vГҹв•‘Г‘n в”ҖГҰГҹв•—Гј', 'Гҹв•—Вҝng tuyГҹв•—Гўn vв”ңГЎ phв”ңГӯt triГҹв•—Гўn sГҹв•—в–’ nghiГҹв•—Г§p', ...skills];\r\n\r\n  const DEMO_REVIEWS = [\r\n    { name: 'NguyГҹв•—Г n Vв”ҖГўn A', role: 'Software Engineer', rating: 5, text: 'Khв”ңв”Ӯa hГҹв•—Г¬c rГҹв•‘Г‘t hay, giГҹв•‘Гәng viв”ңВ¬n giГҹв•‘Гәi thв”ңВЎch rв”ңГҒ rв”ңГЎng vв”ңГЎ dГҹв•—Г  hiГҹв•—Гўu. KiГҹв•‘в”җn thГҹв•—В®c thГҹв•—в–’c tГҹв•‘в”җ, в”ңГӯp dГҹв•—Г‘ng в”ҖГҰГЈв–‘Гҹв•—Гәc ngay vв”ңГЎo cв”ңв”Өng viГҹв•—Г§c.' },\r\n    { name: 'TrГҹв•‘Вәn ThГҹв•—ГҜ B', role: 'Product Manager', rating: 5, text: 'NГҹв•—Г–i dung phong phв”ңв•‘, thГҹв•—в–’c hв”ңГЎnh nhiГҹв•—Гјu. RГҹв•‘Г‘t phв”ңв•Ј hГҹв•—Гәp cho ngГЈв–‘Гҹв•—Гҳi mГҹв•—Гёi bГҹв•‘В»t в”ҖГҰГҹв•‘Вәu lГҹв•‘ВҪn ngГЈв–‘Гҹв•—Гҳi muГҹв•—ГҰn nв”ңГіng cao kГҹв•—в•Ј nв”ҖГўng.' },\r\n    { name: 'Lв”ңВ¬ Minh C', role: 'Data Analyst', rating: 4, text: 'TuyГҹв•—Г§t vГҹв•—Гҳi! MГҹв•—Г–t trong nhГҹв•—В»ng khв”ңв”Ӯa hГҹв•—Г¬c tГҹв•—ГҰt nhГҹв•‘Г‘t tв”ңв”Өi tГҹв•—ВҪng tham gia. ChГҹв•—В®ng chГҹв•—Г« в”ҖГҰГЈв–‘Гҹв•—Гәc nhiГҹв•—Гјu cв”ңв”Өng ty cв”ңв”Өng nhГҹв•‘ВЎn.' },\r\n  ];\r\n\r\n  const NAV_ITEMS = [\r\n    { id: 'about', label: 'GiГҹв•—Гёi thiГҹв•—Г§u' },\r\n    { id: 'outcomes', label: 'KГҹв•‘в”җt quГҹв•‘Гә hГҹв•—Г¬c tГҹв•‘ВЎp' },\r\n    { id: 'courses', label: 'NГҹв•—Г–i dung' },\r\n    { id: 'testimonials', label: 'в”ҖГүв”ңГӯnh giв”ңГӯ' },\r\n  ];\r\n\r\n  /* Г”Г¶ГҮГ”Г¶ГҮ ENROLLMENT CARD Г”Г¶ГҮГ”Г¶ГҮ */\r\n  const EnrollCard = ({ compact = false }) => (\r\n    <div style={{\r\n      background: '#fff',\r\n      borderRadius: compact ? 0 : 12,\r\n      boxShadow: compact ? 'none' : '0 4px 24px rgba(0,0,0,0.12)',\r\n      overflow: 'hidden',\r\n      border: compact ? 'none' : '1px solid #e5e7eb',\r\n    }}>\r\n      {/* Thumbnail */}\r\n      {!compact && (\r\n        <div style={{ height: 180, background: GRADS[gradIdx], position: 'relative', display: 'flex', alignItems: 'center', justifyContent: 'center', overflow: 'hidden' }}>\r\n          {thumbnailUrl && (\r\n            <img src={thumbnailUrl} alt={title} style={{ width: '100%', height: '100%', objectFit: 'cover' }}\r\n              onError={e => { e.target.style.display = 'none'; if(e.target.nextSibling) e.target.nextSibling.style.display = 'flex'; }} />\r\n          )}\r\n          <span style={{ fontSize: 72, color: 'rgba(255,255,255,0.85)', fontWeight: 800, display: thumbnailUrl ? 'none' : 'flex', alignItems: 'center', justifyContent: 'center' }}>\r\n            {org[0]?.toUpperCase() || 'E'}\r\n          </span>\r\n        </div>\r\n      )}\r\n      <div style={{ padding: compact ? '12px 20px' : 24 }}>\r\n        {!compact && (\r\n          <div style={{ marginBottom: 16 }}>\r\n            {isDiscounted && (\r\n              <div style={{ marginBottom: 8, display: 'flex', alignItems: 'center', gap: 8 }}>\r\n                 <span style={{ fontSize: 16, textDecoration: 'line-through', color: '#6b7280' }}>\r\n                   {originalPrice.toLocaleString('vi-VN')} Г”Г©ВҪ\r\n                 </span>\r\n                 <span style={{ background: '#dc2626', color: 'white', padding: '4px 8px', borderRadius: 4, fontSize: 12, fontWeight: 700 }}>\r\n                   GiГҹв•‘Гәm {Math.round((1 - price / originalPrice) * 100)}%\r\n                 </span>\r\n              </div>\r\n            )}\r\n            <div style={{ fontSize: price === 0 ? 26 : 28, fontWeight: 800, color: '#111', lineHeight: 1 }}>\r\n              {price === 0 ? <span style={{ color: '#059669' }}>MiГҹв•—Г n phв”ңВЎ</span> : `${price.toLocaleString('vi-VN')} Г”Г©ВҪ`}\r\n            </div>\r\n            {price > 0 && <div style={{ fontSize: 12, color: '#6b7280', marginTop: 4 }}>Truy cГҹв•‘ВЎp trГҹв•—Г¬n в”ҖГҰГҹв•—Гҳi Г”ГҮГі ChГҹв•—В®ng chГҹв•—Г« hoв”ңГЎn thв”ңГЎnh</div>}\r\n          </div>\r\n        )}\r\n\r\n        {isEnrolled ? (\r\n          <button\r\n            onClick={() => navigate(`/learn/${courseId}`)}\r\n            style={{ width: '100%', padding: compact ? '10px 0' : '14px 0', background: '#0056D2', color: '#fff', border: 'none', borderRadius: 8, fontWeight: 700, fontSize: 15, cursor: 'pointer' }}>\r\n            Vв”ңГЎo hГҹв•—Г¬c ngay Г”ГҘГҶ\r\n          </button>\r\n        ) : (\r\n          <div style={{ display: 'flex', flexDirection: 'column', gap: 10 }}>\r\n            <button\r\n              onClick={price === 0 ? () => setShowTrialModal(true) : addToCart}\r\n              disabled={addingCart}\r\n              style={{ width: '100%', padding: compact ? '10px 0' : '14px 0', background: addingCart ? '#93c5fd' : '#0056D2', color: '#fff', border: 'none', borderRadius: 8, fontWeight: 700, fontSize: 15, cursor: addingCart ? 'not-allowed' : 'pointer', transition: 'background 0.2s' }}>\r\n              {addingCart ? 'в”ҖГүang thв”ңВ¬m...' : price === 0 ? 'в”ҖГүв”ҖГўng kв”ңВў miГҹв•—Г n phв”ңВЎ' : 'Thв”ңВ¬m vв”ңГЎo giГҹв•—Г… hв”ңГЎng'}\r\n            </button>\r\n            {price > 0 && !compact && (\r\n              <button\r\n                onClick={async () => { await addToCart(); navigate('/checkout'); }}\r\n                style={{ width: '100%', padding: '12px 0', background: '#fff', color: '#0056D2', border: '2px solid #0056D2', borderRadius: 8, fontWeight: 700, fontSize: 15, cursor: 'pointer' }}>\r\n                Mua ngay\r\n              </button>\r\n            )}\r\n          </div>\r\n        )}\r\n\r\n        {!compact && (\r\n          <div style={{ marginTop: 20, display: 'flex', flexDirection: 'column', gap: 8 }}>\r\n            {[\r\n              { icon: 'ВӯЖ’ГҙГң', text: `${totalLessons} bв”ңГЎi hГҹв•—Г¬c` },\r\n              { icon: 'Г”Г…в–’', text: course.duration || '20+ giГҹв•—Гҳ nГҹв•—Г–i dung' },\r\n              { icon: 'ВӯЖ’Гҙв–’', text: 'Truy cГҹв•‘ВЎp trв”ңВ¬n mГҹв•—Г¬i thiГҹв•‘в”җt bГҹв•—ГҜ' },\r\n              { icon: 'ВӯЖ’Г…ГҘ', text: 'ChГҹв•—В®ng chГҹв•—Г« hoв”ңГЎn thв”ңГЎnh' },\r\n              { icon: 'Г”Г–ВҘВҙВ©Г…', text: 'Truy cГҹв•‘ВЎp trГҹв•—Г¬n в”ҖГҰГҹв•—Гҳi' },\r\n            ].map((item, i) => (\r\n              <div key={i} style={{ display: 'flex', alignItems: 'center', gap: 10, fontSize: 13, color: '#374151' }}>\r\n                <span>{item.icon}</span>\r\n                <span>{item.text}</span>\r\n              </div>\r\n            ))}\r\n          </div>\r\n        )}\r\n\r\n        {!compact && price > 0 && (\r\n          <div style={{ marginTop: 16, padding: '10px 12px', background: '#f0fdf4', borderRadius: 8, display: 'flex', alignItems: 'center', gap: 8, fontSize: 12, color: '#15803d' }}>\r\n            ВӯЖ’Г¶ГҶ в”ҖГүГҹв•‘Гәm bГҹв•‘Гәo hoв”ңГЎn tiГҹв•—Гјn 30 ngв”ңГЎy nГҹв•‘в”җu khв”ңв”Өng hв”ңГЎi lв”ңв–“ng\r\n          </div>\r\n        )}\r\n      </div>\r\n    </div>\r\n  );\r\n\r\n  return (\r\n    <div style={{ background: '#f5f7f9', minHeight: '100vh' }}>\r\n      {/* TOAST */}\r\n      {toast && (\r\n        <div style={{ position: 'fixed', top: 80, right: 24, background: '#1f2937', color: '#fff', padding: '12px 20px', borderRadius: 10, zIndex: 9999, fontSize: 14, boxShadow: '0 8px 24px rgba(0,0,0,0.2)', animation: 'fadeIn 0.2s ease' }}>\r\n          {toast}\r\n          <style>{`@keyframes fadeIn { from { opacity: 0; transform: translateY(-8px); } to { opacity: 1; transform: translateY(0); } }`}</style>\r\n        </div>\r\n      )}\r\n\r\n      {/* Г”Г¶ГҮГ”Г¶ГҮ HERO SECTION Г”Г¶ГҮГ”Г¶ГҮ */}\r\n      <div style={{ background: '#1c1d1f', color: '#fff', padding: '48px 0 0' }}>\r\n        <div style={{ maxWidth: 1200, margin: '0 auto', padding: '0 24px', display: 'grid', gridTemplateColumns: '1fr 360px', gap: 40, alignItems: 'start' }}>\r\n          {/* LEFT CONTENT */}\r\n          <div style={{ paddingBottom: 40 }}>\r\n            {/* Breadcrumb */}\r\n            <nav style={{ marginBottom: 16, fontSize: 13, color: '#bbb' }}>\r\n              <Link to=\"/\" style={{ color: '#60a5fa', textDecoration: 'none' }}>Trang chГҹв•—Вә</Link>\r\n              <span style={{ margin: '0 8px', color: '#555' }}>/</span>\r\n              <span style={{ color: '#aaa' }}>{fixText(course.category?.name) || 'Khв”ңв”Ӯa hГҹв•—Г¬c'}</span>\r\n              <span style={{ margin: '0 8px', color: '#555' }}>/</span>\r\n              <span style={{ color: '#ddd' }}>{title.length > 40 ? title.slice(0, 40) + 'Г”ГҮВӘ' : title}</span>\r\n            </nav>\r\n\r\n            {/* Partner badge / VNU Faculty */}\r\n            <div style={{ display: 'inline-flex', alignItems: 'center', gap: 8, background: 'rgba(255,255,255,0.1)', padding: '6px 12px', borderRadius: 6, marginBottom: 16, fontSize: 13, color: '#e5e7eb' }}>\r\n              <span style={{ width: 28, height: 28, background: GRADS[gradIdx], borderRadius: 4, display: 'flex', alignItems: 'center', justifyContent: 'center', fontWeight: 800, fontSize: 13 }}>\r\n                {(course.faculty || org)[0]?.toUpperCase()}\r\n              </span>\r\n              {course.faculty || org}\r\n            </div>\r\n\r\n            {/* Title / VNU Subject Code */}\r\n            <h1 style={{ fontSize: 30, fontWeight: 800, lineHeight: 1.25, marginBottom: 16, color: '#fff', maxWidth: 680 }}>\r\n              {course.subject_code && <span style={{color: '#60a5fa', marginRight: '8px'}}>[{course.subject_code}]</span>}\r\n              {title}\r\n            </h1>\r\n\r\n            {/* Subtitle */}\r\n            <p style={{ fontSize: 16, color: '#d1d5db', lineHeight: 1.6, marginBottom: 20, maxWidth: 620 }}>\r\n              {course.description?.split('\\n')[0] || `Khв”ңв”Ӯa hГҹв•—Г¬c chuyв”ңВ¬n sв”ңГіu tГҹв•—ВҪ ${org} giв”ңв•‘p bГҹв•‘Гӯn nв”ңГіng cao kГҹв•—в•Ј nв”ҖГўng ${fixText(course.category?.name) || 'chuyв”ңВ¬n mв”ңв”Өn'}.`}\r\n            </p>\r\n\r\n            {/* Rating row */}\r\n            <div style={{ display: 'flex', alignItems: 'center', gap: 12, marginBottom: 16, flexWrap: 'wrap' }}>\r\n              {rating > 0 && (\r\n                <>\r\n                  <Stars rating={rating} size={16} />\r\n                  <span style={{ color: '#fbbf24', fontWeight: 700 }}>{rating.toFixed(1)}</span>\r\n                  <span style={{ color: '#9ca3af', fontSize: 13 }}>({typeof reviewCount === 'number' ? reviewCount.toLocaleString() : reviewCount} в”ҖГҰв”ңГӯnh giв”ңГӯ)</span>\r\n                </>\r\n              )}\r\n              <span style={{ color: '#9ca3af', fontSize: 13 }}>Г”ГҮГі</span>\r\n              <span style={{ color: '#9ca3af', fontSize: 13 }}>{typeof enrollCount === 'number' ? enrollCount.toLocaleString() : enrollCount} hГҹв•—Г¬c viв”ңВ¬n в”ҖГҰв”ңГә в”ҖГҰв”ҖГўng kв”ңВў</span>\r\n            </div>\r\n\r\n            {/* Meta badges */}\r\n            <div style={{ display: 'flex', gap: 8, flexWrap: 'wrap' }}>\r\n              {[\r\n                { icon: 'ВӯЖ’ГҙГЁ', label: course.level || 'MГҹв•—Г¬i trв”ңВјnh в”ҖГҰГҹв•—Г–' },\r\n                { icon: 'Г”Г…в–’', label: course.duration || '20+ giГҹв•—Гҳ' },\r\n                { icon: 'ВӯЖ’Г®Гү', label: 'TiГҹв•‘в”җng ViГҹв•—Г§t' },\r\n                { icon: 'ВӯЖ’Г…ГҘ', label: 'Cв”ңв”Ӯ chГҹв•—В®ng chГҹв•—Г«' },\r\n              ].map((b, i) => (\r\n                <span key={i} style={{ display: 'inline-flex', alignItems: 'center', gap: 6, background: 'rgba(255,255,255,0.1)', padding: '5px 12px', borderRadius: 20, fontSize: 12, color: '#e5e7eb' }}>\r\n                  {b.icon} {b.label}\r\n                </span>\r\n              ))}\r\n            </div>\r\n          </div>\r\n\r\n          {/* RIGHT: Enrollment Card (visible in hero) */}\r\n          <div style={{ position: 'sticky', top: 80, zIndex: 10 }}>\r\n            <EnrollCard />\r\n          </div>\r\n        </div>\r\n      </div>\r\n\r\n      {/* Г”Г¶ГҮГ”Г¶ГҮ STICKY SUB-NAV Г”Г¶ГҮГ”Г¶ГҮ */}\r\n      <div ref={stickyNavRef} style={{\r\n        position: 'sticky', top: 56, zIndex: 100,\r\n        background: '#fff',\r\n        borderBottom: '1px solid #e5e7eb',\r\n        boxShadow: stickyVisible ? '0 2px 8px rgba(0,0,0,0.08)' : 'none',\r\n        transition: 'box-shadow 0.2s',\r\n      }}>\r\n        <div style={{ maxWidth: 1200, margin: '0 auto', padding: '0 24px', display: 'flex', alignItems: 'center', justifyContent: 'space-between' }}>\r\n          <nav style={{ display: 'flex', gap: 0 }}>\r\n            {NAV_ITEMS.map(item => (\r\n              <button\r\n                key={item.id}\r\n                onClick={() => scrollToSection(item.id)}\r\n                style={{\r\n                  padding: '16px 20px',\r\n                  background: 'none',\r\n                  border: 'none',\r\n                  borderBottom: activeNav === item.id ? '3px solid #0056D2' : '3px solid transparent',\r\n                  color: activeNav === item.id ? '#0056D2' : '#374151',\r\n                  fontWeight: activeNav === item.id ? 700 : 500,\r\n                  fontSize: 14,\r\n                  cursor: 'pointer',\r\n                  transition: 'all 0.15s',\r\n                }}>\r\n                {item.label}\r\n              </button>\r\n            ))}\r\n          </nav>\r\n\r\n          {/* Compact enroll CTA (shows on scroll) */}\r\n          {stickyVisible && !isEnrolled && (\r\n            <button\r\n              onClick={price === 0 ? () => setShowTrialModal(true) : addToCart}\r\n              style={{ padding: '9px 20px', background: '#0056D2', color: '#fff', border: 'none', borderRadius: 6, fontWeight: 700, fontSize: 13, cursor: 'pointer' }}>\r\n              {price === 0 ? 'в”ҖГүв”ҖГўng kв”ңВў miГҹв•—Г n phв”ңВЎ' : 'Thв”ңВ¬m vв”ңГЎo giГҹв•—Г… hв”ңГЎng'}\r\n            </button>\r\n          )}\r\n          {stickyVisible && isEnrolled && (\r\n            <button\r\n              onClick={() => navigate(`/learn/${courseId}`)}\r\n              style={{ padding: '9px 20px', background: '#0056D2', color: '#fff', border: 'none', borderRadius: 6, fontWeight: 700, fontSize: 13, cursor: 'pointer' }}>\r\n              Vв”ңГЎo hГҹв•—Г¬c ngay Г”ГҘГҶ\r\n            </button>\r\n          )}\r\n        </div>\r\n      </div>\r\n\r\n      {/* Г”Г¶ГҮГ”Г¶ГҮ QUICK STATS BAR Г”Г¶ГҮГ”Г¶ГҮ */}\r\n      <div style={{ background: '#fff', borderBottom: '1px solid #f3f4f6' }}>\r\n        <div style={{ maxWidth: 1200, margin: '0 auto', padding: '0 24px' }}>\r\n          <div style={{ display: 'grid', gridTemplateColumns: 'repeat(5, 1fr)', borderTop: '1px solid #f3f4f6' }}>\r\n            {[\r\n              { icon: 'ВӯЖ’ГҙГң', value: `${totalLessons}`, label: 'Bв”ңГЎi hГҹв•—Г¬c' },\r\n              { icon: 'Г”ВЎГү', value: rating.toFixed(1), label: 'в”ҖГүв”ңГӯnh giв”ңГӯ trung bв”ңВјnh' },\r\n              { icon: 'ВӯЖ’ГҙГЁ', value: course.level || 'MГҹв•—Г¬i cГҹв•‘Г‘p в”ҖГҰГҹв•—Г–', label: 'Trв”ңВјnh в”ҖГҰГҹв•—Г–' },\r\n              { icon: 'Г”Г…в–’', value: course.duration || 'Linh hoГҹв•‘Гӯt', label: 'ThГҹв•—Гҳi lГЈв–‘Гҹв•—Гәng' },\r\n              { icon: 'ВӯЖ’Г®Гү', value: 'TiГҹв•‘в”җng ViГҹв•—Г§t', label: 'Ngв”ңв”Өn ngГҹв•—В»' },\r\n            ].map((stat, i) => (\r\n              <div key={i} style={{ padding: '20px 0', textAlign: 'center', borderRight: i < 4 ? '1px solid #f3f4f6' : 'none' }}>\r\n                <div style={{ fontSize: 22, marginBottom: 4 }}>{stat.icon}</div>\r\n                <div style={{ fontWeight: 800, fontSize: 15, color: '#111' }}>{stat.value}</div>\r\n                <div style={{ fontSize: 12, color: '#6b7280', marginTop: 2 }}>{stat.label}</div>\r\n              </div>\r\n            ))}\r\n          </div>\r\n        </div>\r\n      </div>\r\n\r\n      {/* Г”Г¶ГҮГ”Г¶ГҮ MAIN 2-COLUMN CONTENT Г”Г¶ГҮГ”Г¶ГҮ */}\r\n      <div style={{ maxWidth: 1200, margin: '0 auto', padding: '32px 24px', display: 'grid', gridTemplateColumns: '1fr 360px', gap: 32, alignItems: 'start' }}>\r\n\r\n        {/* Г”Г¶ГҮГ”Г¶ГҮ LEFT: MAIN CONTENT Г”Г¶ГҮГ”Г¶ГҮ */}\r\n        <div style={{ display: 'flex', flexDirection: 'column', gap: 28 }}>\r\n\r\n          {/* SECTION: ABOUT */}\r\n          <section ref={el => sectionsRef.current.about = el}>\r\n            {/* What you'll learn */}\r\n            <div style={{ background: '#fff', border: '1px solid #e5e7eb', borderRadius: 12, padding: 28 }}>\r\n              <h2 style={{ fontSize: 20, fontWeight: 800, marginBottom: 20, color: '#111' }}>BГҹв•‘Гӯn sГҹв•‘Вў hГҹв•—Г¬c в”ҖГҰГЈв–‘Гҹв•—Гәc gв”ңВј</h2>\r\n              <div style={{ display: 'grid', gridTemplateColumns: '1fr 1fr', gap: '10px 24px' }}>\r\n                {whatYouLearn.slice(0, 8).map((skill, i) => (\r\n                  <div key={i} style={{ display: 'flex', alignItems: 'flex-start', gap: 10, fontSize: 14, color: '#374151', lineHeight: 1.5 }}>\r\n                    <span style={{ color: '#0056D2', fontWeight: 700, fontSize: 16, marginTop: 1, flexShrink: 0 }}>Г”ВЈГҙ</span>\r\n                    <span>{skill}</span>\r\n                  </div>\r\n                ))}\r\n              </div>\r\n            </div>\r\n          </section>\r\n\r\n          {/* SECTION: SKILLS TAGS */}\r\n          {skills.length > 0 && (\r\n            <div style={{ background: '#fff', border: '1px solid #e5e7eb', borderRadius: 12, padding: 24 }}>\r\n              <h3 style={{ fontSize: 15, fontWeight: 700, marginBottom: 14, color: '#111' }}>KГҹв•—в•Ј nв”ҖГўng bГҹв•‘Гӯn sГҹв•‘Вў в”ҖГҰГҹв•‘Гӯt в”ҖГҰГЈв–‘Гҹв•—Гәc</h3>\r\n              <div style={{ display: 'flex', flexWrap: 'wrap', gap: 8 }}>\r\n                {skills.map((s, i) => (\r\n                  <span key={i} style={{ background: '#eff6ff', color: '#1d4ed8', border: '1px solid #bfdbfe', padding: '5px 14px', borderRadius: 20, fontSize: 13, fontWeight: 500 }}>\r\n                    {s}\r\n                  </span>\r\n                ))}\r\n              </div>\r\n            </div>\r\n          )}\r\n\r\n          {/* SECTION: OUTCOMES */}\r\n          <section ref={el => sectionsRef.current.outcomes = el}>\r\n            <div style={{ background: '#fff', border: '1px solid #e5e7eb', borderRadius: 12, padding: 28 }}>\r\n              <h2 style={{ fontSize: 20, fontWeight: 800, marginBottom: 20, color: '#111' }}>KГҹв•‘в”җt quГҹв•‘Гә hГҹв•—Г¬c tГҹв•‘ВЎp</h2>\r\n              <div style={{ display: 'grid', gridTemplateColumns: '1fr 1fr', gap: 16 }}>\r\n                {[\r\n                  { icon: 'ВӯЖ’Г…ГҘ', title: 'NhГҹв•‘ВЎn chГҹв•—В®ng chГҹв•—Г«', desc: 'ChГҹв•—В®ng chГҹв•—Г« в”ҖГҰГЈв–‘Гҹв•—Гәc cв”ңв”Өng nhГҹв•‘ВЎn bГҹв•—Ж’i doanh nghiГҹв•—Г§p, chia sГҹв•‘в•— lв”ңВ¬n LinkedIn' },\r\n                  { icon: 'ВӯЖ’ГҶв•қ', title: 'SГҹв•‘ГҒn sв”ңГЎng viГҹв•—Г§c lв”ңГЎm', desc: 'KГҹв•—в•Ј nв”ҖГўng thГҹв•—в–’c tiГҹв•—Г n в”ңГӯp dГҹв•—Г‘ng ngay vв”ңГЎo cв”ңв”Өng viГҹв•—Г§c thГҹв•—в–’c tГҹв•‘в”җ' },\r\n                  { icon: 'ВӯЖ’ГҙГӘ', title: 'Nв”ңГіng cao sГҹв•—в–’ nghiГҹв•—Г§p', desc: 'MГҹв•—Ж’ ra cГЈГӯ hГҹв•—Г–i thв”ҖГўng tiГҹв•‘в”җn vв”ңГЎ tв”ҖГўng lГЈв–‘ГЈГӯng trong lв”ҖВ®nh vГҹв•—в–’c nв”ңГЎy' },\r\n                  { icon: 'ВӯЖ’Г®Гү', title: 'CГҹв•—Г–ng в”ҖГҰГҹв•—Гҙng hГҹв•—Г¬c tГҹв•‘ВЎp', desc: 'KГҹв•‘в”җt nГҹв•—ГҰi vГҹв•—Гёi hв”ңГЎng nghв”ңВјn hГҹв•—Г¬c viв”ңВ¬n vв”ңГЎ chuyв”ңВ¬n gia trв”ңВ¬n toв”ңГЎn quГҹв•—ГҰc' },\r\n                ].map((item, i) => (\r\n                  <div key={i} style={{ padding: 16, background: '#f9fafb', borderRadius: 10, border: '1px solid #f3f4f6' }}>\r\n                    <div style={{ fontSize: 24, marginBottom: 10 }}>{item.icon}</div>\r\n                    <div style={{ fontWeight: 700, fontSize: 14, color: '#111', marginBottom: 6 }}>{item.title}</div>\r\n                    <div style={{ fontSize: 13, color: '#6b7280', lineHeight: 1.5 }}>{item.desc}</div>\r\n                  </div>\r\n                ))}\r\n              </div>\r\n            </div>\r\n          </section>\r\n\r\n          {/* SECTION: CURRICULUM */}\r\n          <section ref={el => sectionsRef.current.courses = el}>\r\n            <div style={{ background: '#fff', border: '1px solid #e5e7eb', borderRadius: 12, overflow: 'hidden' }}>\r\n              <div style={{ padding: '24px 28px', borderBottom: '1px solid #f3f4f6' }}>\r\n                <h2 style={{ fontSize: 20, fontWeight: 800, color: '#111', marginBottom: 6 }}>\r\n                  NГҹв•—Г–i dung khв”ңв”Ӯa hГҹв•—Г¬c\r\n                </h2>\r\n                <p style={{ fontSize: 13, color: '#6b7280' }}>\r\n                  {curriculum.length} phГҹв•‘Вәn Г”ГҮГі {totalLessons} bв”ңГЎi hГҹв•—Г¬c Г”ГҮГі {course.duration || '20+'} giГҹв•—Гҳ hГҹв•—Г¬c tГҹв•‘ВЎp\r\n                </p>\r\n              </div>\r\n              {curriculum.map((mod, mi) => (\r\n                <div key={mi} style={{ borderBottom: mi < curriculum.length - 1 ? '1px solid #f3f4f6' : 'none' }}>\r\n                  <button\r\n                    onClick={() => setExpandedModule(expandedModule === mi ? -1 : mi)}\r\n                    style={{ width: '100%', padding: '18px 28px', display: 'flex', alignItems: 'center', justifyContent: 'space-between', background: expandedModule === mi ? '#f9fafb' : '#fff', border: 'none', cursor: 'pointer', textAlign: 'left', transition: 'background 0.15s' }}>\r\n                    <div style={{ display: 'flex', alignItems: 'center', gap: 14 }}>\r\n                      <div style={{ width: 40, height: 40, borderRadius: 8, background: GRADS[gradIdx], display: 'flex', alignItems: 'center', justifyContent: 'center', color: '#fff', fontWeight: 800, fontSize: 14, flexShrink: 0 }}>\r\n                        {mi + 1}\r\n                      </div>\r\n                      <div>\r\n                        <div style={{ fontWeight: 700, fontSize: 14, color: '#111' }}>{mod.title}</div>\r\n                        <div style={{ fontSize: 12, color: '#6b7280', marginTop: 2 }}>\r\n                          {mod.lessons.length} bв”ңГЎi Г”ГҮГі {mod.duration}\r\n                        </div>\r\n                      </div>\r\n                    </div>\r\n                    <span style={{ color: '#6b7280', fontSize: 18, transition: 'transform 0.2s', transform: expandedModule === mi ? 'rotate(180deg)' : 'none' }}>Г”ГҮв•‘</span>\r\n                  </button>\r\n                  {expandedModule === mi && (\r\n                    <ul style={{ listStyle: 'none', margin: 0, padding: '0 28px 16px 82px' }}>\r\n                      {mod.lessons.map((lesson, li) => (\r\n                        <li key={li} style={{ padding: '10px 0', borderTop: '1px solid #f9fafb', display: 'flex', alignItems: 'center', gap: 12 }}>\r\n                          <span style={{ color: '#9ca3af', fontSize: 14 }}>Г”Г»ГӮ</span>\r\n                          <span style={{ fontSize: 14, color: '#374151', flex: 1 }}>{lesson}</span>\r\n                          {isEnrolled && (\r\n                            <button onClick={() => navigate(`/learn/${courseId}`)} style={{ fontSize: 12, color: '#0056D2', background: 'none', border: 'none', cursor: 'pointer', fontWeight: 600 }}>\r\n                              HГҹв•—Г¬c ngay Г”ГҘГҶ\r\n                            </button>\r\n                          )}\r\n                        </li>\r\n                      ))}\r\n                      {course.chapters?.[mi]?.quiz && (\r\n                        <li style={{ padding: '12px 15px', marginTop: '5px', background: '#f0f9ff', borderRadius: '8px', border: '1px dashed #0056d2', display: 'flex', alignItems: 'center', gap: 10 }}>\r\n                          <span style={{fontSize: '1.2rem'}}>ВӯЖ’ГҙГҳ</span>\r\n                          <div style={{flex: 1}}>\r\n                            <div style={{fontWeight: 700, fontSize: '13px', color: '#0369a1'}}>Bв”ңГЎi kiГҹв•—Гўm tra: {course.chapters[mi].quiz.title}</div>\r\n                            <div style={{fontSize: '11px', color: '#64748b'}}>{course.chapters[mi].quiz.questions?.length || 0} cв”ңГіu hГҹв•—Г…i trГҹв•‘В»c nghiГҹв•—Г§m</div>\r\n                          </div>\r\n                        </li>\r\n                      )}\r\n                    </ul>\r\n                  )}\r\n                </div>\r\n              ))}\r\n            </div>\r\n          </section>\r\n\r\n          {/* SECTION: DESCRIPTION */}\r\n          <div style={{ background: '#fff', border: '1px solid #e5e7eb', borderRadius: 12, padding: 28 }}>\r\n            <h2 style={{ fontSize: 20, fontWeight: 800, marginBottom: 16, color: '#111' }}>VГҹв•—Гј khв”ңв”Ӯa hГҹв•—Г¬c nв”ңГЎy</h2>\r\n            <div style={{ fontSize: 15, color: '#374151', lineHeight: 1.75, ...(showFullDesc ? {} : { maxHeight: 120, overflow: 'hidden', position: 'relative' }) }}>\r\n              {course.description ||\r\n                `Khв”ңв”Ӯa hГҹв•—Г¬c ${title} в”ҖГҰГЈв–‘Гҹв•—Гәc thiГҹв•‘в”җt kГҹв•‘в”җ bГҹв•—Ж’i ${org}, cung cГҹв•‘Г‘p kiГҹв•‘в”җn thГҹв•—В®c toв”ңГЎn diГҹв•—Г§n vв”ңГЎ kГҹв•—в•Ј nв”ҖГўng thГҹв•—в–’c tiГҹв•—Г n. Phв”ңв•Ј hГҹв•—Гәp cho cГҹв•‘Гә ngГЈв–‘Гҹв•—Гҳi mГҹв•—Гёi bГҹв•‘В»t в”ҖГҰГҹв•‘Вәu vв”ңГЎ nhГҹв•—В»ng ai muГҹв•—ГҰn nв”ңГіng cao kГҹв•—в•Ј nв”ҖГўng chuyв”ңВ¬n mв”ңв”Өn trong lв”ҖВ®nh vГҹв•—в–’c ${fixText(course.category?.name) || 'cв”ңв”Өng nghГҹв•—Г§'}. VГҹв•—Гёi phГЈв–‘ГЈГӯng phв”ңГӯp hГҹв•—Г¬c kГҹв•‘в”җt hГҹв•—Гәp lв”ңВў thuyГҹв•‘в”җt vв”ңГЎ thГҹв•—в–’c hв”ңГЎnh, khв”ңв”Ӯa hГҹв•—Г¬c nв”ңГЎy sГҹв•‘Вў giв”ңв•‘p bГҹв•‘Гӯn в”ҖГҰГҹв•‘Гӯt в”ҖГҰГЈв–‘Гҹв•—Гәc sГҹв•—в–’ tГҹв•—в–’ tin trong cв”ңв”Өng viГҹв•—Г§c.`}\r\n            </div>\r\n            {!showFullDesc && (\r\n              <button onClick={() => setShowFullDesc(true)} style={{ marginTop: 12, color: '#0056D2', background: 'none', border: 'none', cursor: 'pointer', fontWeight: 600, fontSize: 14 }}>\r\n                Xem thв”ңВ¬m Г”Г»ВҘ\r\n              </button>\r\n            )}\r\n          </div>\r\n\r\n          {/* SECTION: INSTRUCTOR */}\r\n          <div style={{ background: '#fff', border: '1px solid #e5e7eb', borderRadius: 12, padding: 28 }}>\r\n            <h2 style={{ fontSize: 20, fontWeight: 800, marginBottom: 20, color: '#111' }}>GiГҹв•‘Гәng viв”ңВ¬n</h2>\r\n            <div style={{ display: 'flex', gap: 20, alignItems: 'flex-start' }}>\r\n              <div style={{ width: 72, height: 72, borderRadius: '50%', background: GRADS[gradIdx], display: 'flex', alignItems: 'center', justifyContent: 'center', color: '#fff', fontWeight: 800, fontSize: 24, flexShrink: 0 }}>\r\n                {org[0]?.toUpperCase()}\r\n              </div>\r\n              <div>\r\n                <div style={{ fontWeight: 700, fontSize: 16, color: '#0056D2', marginBottom: 4 }}>{org}</div>\r\n                <div style={{ fontSize: 13, color: '#6b7280', marginBottom: 10 }}>\r\n                  {fixText(course.category?.name) || 'Chuyв”ңВ¬n gia'} Expert Г”ГҮГі EduVNU Partner\r\n                </div>\r\n                <div style={{ display: 'flex', gap: 16, fontSize: 13, color: '#374151', marginBottom: 10 }}>\r\n                  {rating > 0 && <span>Г”ВЎГү {rating.toFixed(1)} в”ҖГҰв”ңГӯnh giв”ңГӯ</span>}\r\n                  <span>ВӯЖ’ГҰГ‘ {typeof enrollCount === 'number' ? enrollCount.toLocaleString() : enrollCount} hГҹв•—Г¬c viв”ңВ¬n</span>\r\n                  <span>ВӯЖ’ГҙГң {totalLessons} bв”ңГЎi hГҹв•—Г¬c</span>\r\n                </div>\r\n                <p style={{ fontSize: 14, color: '#6b7280', lineHeight: 1.6 }}>\r\n                  {org} lв”ңГЎ chuyв”ңВ¬n gia hв”ңГЎng в”ҖГҰГҹв•‘Вәu trong lв”ҖВ®nh vГҹв•—в–’c {fixText(course.category?.name) || 'cв”ңв”Өng nghГҹв•—Г§'} vГҹв•—Гёi nhiГҹв•—Гјu nв”ҖГўm kinh nghiГҹв•—Г§m thГҹв•—в–’c tiГҹв•—Г n vв”ңГЎ в”ҖГҰв”ңГә в”ҖГҰв”ңГЎo tГҹв•‘Гӯo hв”ңГЎng nghв”ңВјn hГҹв•—Г¬c viв”ңВ¬n trв”ңВ¬n toв”ңГЎn quГҹв•—ГҰc.\r\n                </p>\r\n              </div>\r\n            </div>\r\n          </div>\r\n\r\n          {/* SECTION: REVIEWS */}\r\n          <section ref={el => sectionsRef.current.testimonials = el}>\r\n            <div style={{ background: '#fff', border: '1px solid #e5e7eb', borderRadius: 12, padding: 28 }}>\r\n              <h2 style={{ fontSize: 20, fontWeight: 800, marginBottom: 20, color: '#111' }}>в”ҖГүв”ңГӯnh giв”ңГӯ tГҹв•—ВҪ hГҹв•—Г¬c viв”ңВ¬n</h2>\r\n\r\n              {/* Rating overview */}\r\n              {rating > 0 && (\r\n                <div style={{ display: 'flex', gap: 32, alignItems: 'center', padding: '20px 24px', background: '#f9fafb', borderRadius: 10, marginBottom: 24 }}>\r\n                  <div style={{ textAlign: 'center', flexShrink: 0 }}>\r\n                    <div style={{ fontSize: 56, fontWeight: 800, color: '#111', lineHeight: 1 }}>{rating.toFixed(1)}</div>\r\n                    <Stars rating={rating} size={18} />\r\n                    <div style={{ fontSize: 12, color: '#6b7280', marginTop: 4 }}>в”ҖГүв”ңГӯnh giв”ңГӯ khв”ңв”Ӯa hГҹв•—Г¬c</div>\r\n                  </div>\r\n                  <div style={{ flex: 1 }}>\r\n                    {[5, 4, 3, 2, 1].map(star => {\r\n                      const pct = star === 5 ? 72 : star === 4 ? 19 : star === 3 ? 6 : star === 2 ? 2 : 1;\r\n                      return (\r\n                        <div key={star} style={{ display: 'flex', alignItems: 'center', gap: 10, marginBottom: 5 }}>\r\n                          <div style={{ flex: 1, height: 8, background: '#e5e7eb', borderRadius: 4, overflow: 'hidden' }}>\r\n                            <div style={{ width: `${pct}%`, height: '100%', background: '#f59e0b', borderRadius: 4 }} />\r\n                          </div>\r\n                          <span style={{ fontSize: 12, color: '#6b7280', width: 32, textAlign: 'right' }}>{star} Г”ГҝГ </span>\r\n                          <span style={{ fontSize: 12, color: '#9ca3af', width: 28 }}>{pct}%</span>\r\n                        </div>\r\n                      );\r\n                    })}\r\n                  </div>\r\n                </div>\r\n              )}\r\n\r\n              {/* Review cards */}\r\n              <div style={{ display: 'flex', flexDirection: 'column', gap: 16 }}>\r\n                {reviewsLoading ? (\r\n                  <div style={{ textAlign: 'center', color: '#6b7280', padding: '24px 0' }}>в”ҖГүang tГҹв•‘Гәi в”ҖГҰв”ңГӯnh giв”ңГӯ...</div>\r\n                ) : (reviews.length > 0 ? reviews : DEMO_REVIEWS).map((review, i) => {\r\n                  const name = reviews.length > 0\r\n                    ? (review.user?.first_name ? `${review.user.first_name} ${review.user.last_name || ''}`.trim() : review.user?.username || 'HГҹв•—Г¬c viв”ңВ¬n')\r\n                    : review.name;\r\n                  const role = review.role || '';\r\n                  const text = review.comment || review.text || '';\r\n                  const r = review.rating || 5;\r\n                  const initials = (name[0] || 'H').toUpperCase();\r\n                  return (\r\n                    <div key={i} style={{ padding: 20, border: '1px solid #f3f4f6', borderRadius: 10, background: '#fff' }}>\r\n                      <div style={{ display: 'flex', alignItems: 'flex-start', gap: 14, marginBottom: 12 }}>\r\n                        <div style={{ width: 44, height: 44, borderRadius: '50%', background: GRADS[(i + gradIdx) % GRADS.length], display: 'flex', alignItems: 'center', justifyContent: 'center', color: '#fff', fontWeight: 800, fontSize: 16, flexShrink: 0 }}>\r\n                          {initials}\r\n                        </div>\r\n                        <div>\r\n                          <div style={{ fontWeight: 700, fontSize: 14, color: '#111' }}>{name}</div>\r\n                          {role && <div style={{ fontSize: 12, color: '#6b7280' }}>{role}</div>}\r\n                          <div style={{ marginTop: 4 }}><Stars rating={r} size={13} /></div>\r\n                        </div>\r\n                      </div>\r\n                      <p style={{ fontSize: 14, color: '#374151', lineHeight: 1.65, margin: 0 }}>{text}</p>\r\n                    </div>\r\n                  );\r\n                })}\r\n              </div>\r\n            </div>\r\n          </section>\r\n\r\n          {/* SECTION: FAQ */}\r\n          <div style={{ background: '#fff', border: '1px solid #e5e7eb', borderRadius: 12, padding: 28 }}>\r\n            <h2 style={{ fontSize: 20, fontWeight: 800, marginBottom: 20, color: '#111' }}>Cв”ңГіu hГҹв•—Г…i thГЈв–‘Гҹв•—Гҳng gГҹв•‘ГҖp</h2>\r\n            {[\r\n              { q: 'Tв”ңв”Өi cв”ңв”Ӯ cГҹв•‘Вәn kinh nghiГҹв•—Г§m trГЈв–‘Гҹв•—Гёc khв”ңв”Өng?', a: 'Khв”ңв”Өng, khв”ңв”Ӯa hГҹв•—Г¬c в”ҖГҰГЈв–‘Гҹв•—Гәc thiГҹв•‘в”җt kГҹв•‘в”җ phв”ңв•Ј hГҹв•—Гәp cho ngГЈв–‘Гҹв•—Гҳi mГҹв•—Гёi bГҹв•‘В»t в”ҖГҰГҹв•‘Вәu. BГҹв•‘Гӯn chГҹв•—Г« cГҹв•‘Вәn mв”ңГӯy tв”ңВЎnh vв”ңГЎ kГҹв•‘в”җt nГҹв•—ГҰi internet.' },\r\n              { q: 'MГҹв•‘Г‘t bao lв”ңГіu в”ҖГҰГҹв•—Гў hoв”ңГЎn thв”ңГЎnh khв”ңв”Ӯa hГҹв•—Г¬c?', a: `VГҹв•—Гёi lГҹв•—ГҜch hГҹв•—Г¬c linh hoГҹв•‘Гӯt, bГҹв•‘Гӯn cв”ңв”Ӯ thГҹв•—Гў hoв”ңГЎn thв”ңГЎnh trong ${course.duration || '4-6 tuГҹв•‘Вәn'} nГҹв•‘в”җu hГҹв•—Г¬c khoГҹв•‘Гәng 5 giГҹв•—Гҳ mГҹв•—Г№i tuГҹв•‘Вәn.` },\r\n              { q: 'ChГҹв•—В®ng chГҹв•—Г« cГҹв•—Вәa tв”ңв”Өi cв”ңв”Ӯ в”ҖГҰГЈв–‘Гҹв•—Гәc cв”ңв”Өng nhГҹв•‘ВЎn khв”ңв”Өng?', a: 'ChГҹв•—В®ng chГҹв•—Г« EduVNU в”ҖГҰГЈв–‘Гҹв•—Гәc nhiГҹв•—Гјu doanh nghiГҹв•—Г§p trong nГЈв–‘Гҹв•—Гёc cв”ңв”Өng nhГҹв•‘ВЎn vв”ңГЎ bГҹв•‘Гӯn cв”ңв”Ӯ thГҹв•—Гў chia sГҹв•‘в•— trГҹв•—в–’c tiГҹв•‘в”җp lв”ңВ¬n LinkedIn.' },\r\n              { q: 'Tв”ңв”Өi cв”ңв”Ӯ thГҹв•—Гў truy cГҹв•‘ВЎp khв”ңв”Ӯa hГҹв•—Г¬c mв”ңГәi khв”ңв”Өng?', a: 'Sau khi mua, bГҹв•‘Гӯn cв”ңв”Ӯ quyГҹв•—Гјn truy cГҹв•‘ВЎp vв”ҖВ®nh viГҹв•—Г n vв”ңГЎo toв”ңГЎn bГҹв•—Г– nГҹв•—Г–i dung khв”ңв”Ӯa hГҹв•—Г¬c, kГҹв•—Гў cГҹв•‘Гә cв”ңГӯc cГҹв•‘ВЎp nhГҹв•‘ВЎt trong tГЈв–‘ГЈГӯng lai.' },\r\n            ].map((faq, i) => (\r\n              <div key={i} style={{ borderTop: '1px solid #f3f4f6', paddingTop: 16, marginBottom: 16 }}>\r\n                <div style={{ fontWeight: 700, fontSize: 14, color: '#111', marginBottom: 8 }}>Г”ГҳГҙ {faq.q}</div>\r\n                <div style={{ fontSize: 14, color: '#6b7280', lineHeight: 1.6 }}>{faq.a}</div>\r\n              </div>\r\n            ))}\r\n          </div>\r\n\r\n        </div>\r\n\r\n        {/* Г”Г¶ГҮГ”Г¶ГҮ RIGHT SIDEBAR (desktop sticky) Г”Г¶ГҮГ”Г¶ГҮ */}\r\n        <div style={{ display: 'flex', flexDirection: 'column', gap: 16, position: 'sticky', top: 120 }}>\r\n          <EnrollCard />\r\n\r\n          {/* Share card */}\r\n          <div style={{ background: '#fff', border: '1px solid #e5e7eb', borderRadius: 12, padding: 20 }}>\r\n            <div style={{ fontWeight