{
  "name": "Auto Push to GitHub",
  "version": "1.0.0",
  "description": "Tu dong commit va push len GitHub sau moi lan agent hoan thanh",
  "when": {
    "type": "agentStop"
  },
  "then": {
    "type": "runCommand",
    "command": "git add . && git commit -m \"update\" && git push origin main"
  }
}
